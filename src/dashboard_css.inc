":root {\n"
"  /* Backgrounds */\n"
"  --cr-bg:       #0c0c0e;\n"
"  --cr-bg-2:     #111116;\n"
"  --cr-bg-3:     #16161d;\n"
"\n"
"  /* Panels */\n"
"  --cr-panel:    #13131a;\n"
"  --cr-panel-2:  #19191f;\n"
"  --cr-panel-3:  #1f1f28;\n"
"\n"
"  /* Borders */\n"
"  --cr-line:         rgba(255,255,255,0.07);\n"
"  --cr-line-strong:  rgba(255,255,255,0.12);\n"
"  --cr-line-3:       rgba(255,255,255,0.18);\n"
"\n"
"  /* Brand / Accent — warm burnt-orange */\n"
"  --cr-brand:      #c2410c;\n"
"  --cr-brand-2:    #ea580c;\n"
"  --cr-brand-3:    #9a3412;\n"
"  --cr-brand-soft: rgba(234,88,12,0.10);\n"
"  --cr-brand-line: rgba(234,88,12,0.30);\n"
"  --cr-brand-glow: rgba(194,65,12,0.18);\n"
"\n"
"  /* Semantic aliases (kept for backward compat) */\n"
"  --cr-blue:      var(--cr-brand);\n"
"  --cr-blue-2:    var(--cr-brand-2);\n"
"  --cr-blue-3:    var(--cr-brand-3);\n"
"  --cr-blue-soft: var(--cr-brand-soft);\n"
"  --cr-blue-line: var(--cr-brand-line);\n"
"  --cr-blue-glow: var(--cr-brand-glow);\n"
"\n"
"  /* Text */\n"
"  --cr-white:   #f0f0f4;\n"
"  --cr-white-2: #b4b4c0;\n"
"  --cr-muted:   #a1a1aa;\n"
"  --cr-muted-2: #78788a;\n"
"\n"
"  /* Semantic colors */\n"
"  --cr-red:    #dc2626;\n"
"  --cr-yellow: #d97706;\n"
"  --cr-green:  #16a34a;\n"
"\n"
"  --cr-green-dark:   #15803d;\n"
"  --cr-green-soft:   rgba(22,163,74,0.10);\n"
"  --cr-green-border: rgba(22,163,74,0.28);\n"
"\n"
"  --cr-state-on:      #16a34a;\n"
"  --cr-state-on-2:    #15803d;\n"
"  --cr-state-on-glow: rgba(22,163,74,0.28);\n"
"\n"
"  --cr-state-off:      #dc2626;\n"
"  --cr-state-off-2:    #991b1b;\n"
"  --cr-state-off-glow: rgba(220,38,38,0.28);\n"
"\n"
"  --cr-switch-border: rgba(255,255,255,0.12);\n"
"\n"
"  /* Radius */\n"
"  --cr-radius:    10px;\n"
"  --cr-radius-sm: 6px;\n"
"  --cr-radius-lg: 14px;\n"
"\n"
"  /* Fonts */\n"
"  --cr-font-base:    Inter, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif;\n"
"  --cr-font-display: Inter, system-ui, sans-serif;\n"
"  --cr-font-mono:    ui-monospace, \"SF Mono\", Menlo, Consolas, monospace;\n"
"}\n"
"\n"
"/* ── Reset ───────────────────────────────────────────────── */\n"
"* { box-sizing: border-box; }\n"
"html, body { margin: 0; padding: 0; min-height: 100%; }\n"
"\n"
"body {\n"
"  font-family: var(--cr-font-base);\n"
"  color: var(--cr-white);\n"
"  background: var(--cr-bg);\n"
"  padding: 18px;\n"
"  overflow-x: hidden;\n"
"}\n"
"\n"
"/* ── Background layers ───────────────────────────────────── */\n"
".cr-command-bg {\n"
"  position: fixed;\n"
"  inset: 0;\n"
"  z-index: -3;\n"
"  background:\n"
"    radial-gradient(ellipse 900px 500px at 70% -10%, rgba(234,88,12,0.07) 0%, transparent 60%),\n"
"    radial-gradient(ellipse 600px 400px at -5% 95%,  rgba(234,88,12,0.04) 0%, transparent 55%),\n"
"    linear-gradient(160deg, #0c0c0e 0%, #0f0f14 50%, #0c0c0e 100%);\n"
"}\n"
"\n"
"/* Subtle dot grid — replaces heavy scan-line grid */\n"
".cr-scan-grid {\n"
"  position: fixed;\n"
"  inset: 0;\n"
"  z-index: -2;\n"
"  pointer-events: none;\n"
"  background-image: radial-gradient(circle, rgba(255,255,255,0.06) 1px, transparent 1px);\n"
"  background-size: 28px 28px;\n"
"  mask-image: linear-gradient(to bottom, rgba(0,0,0,0.50) 0%, transparent 80%);\n"
"  -webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,0.50) 0%, transparent 80%);\n"
"}\n"
"\n"
"/* Circuit lines removed — replaced by dot grid above */\n"
".cr-circuit-lines { display: none; }\n"
"\n"
"/* ── App shell ───────────────────────────────────────────── */\n"
".cr-app-shell {\n"
"  max-width: 1540px;\n"
"  margin: 0 auto;\n"
"  display: grid;\n"
"  grid-template-columns: minmax(0,1fr) 320px;\n"
"  gap: 12px;\n"
"}\n"
"\n"
"/* ── Panel base ──────────────────────────────────────────── */\n"
".cr-panel {\n"
"  background: var(--cr-panel-2);\n"
"  border: 1px solid var(--cr-line-strong);\n"
"  border-radius: var(--cr-radius-lg);\n"
"  box-shadow: 0 4px 24px -6px rgba(0,0,0,0.5);\n"
"  position: relative;\n"
"  overflow: hidden;\n"
"}\n"
"\n"
"/* Soft top shimmer — wide gradient, not a sharp glow line */\n"
".cr-panel::before {\n"
"  content: \"\";\n"
"  position: absolute;\n"
"  top: 0; left: 0; right: 0;\n"
"  height: 1px;\n"
"  background: linear-gradient(\n"
"    90deg,\n"
"    transparent 0%,\n"
"    rgba(255,255,255,0.08) 40%,\n"
"    rgba(255,255,255,0.04) 60%,\n"
"    transparent 100%\n"
"  );\n"
"  pointer-events: none;\n"
"  z-index: 1;\n"
"}\n"
"\n"
"/* Corner tick removed — cleaner without it */\n"
".cr-panel::after { display: none; }\n"
"\n"
"/* ── Topbar ──────────────────────────────────────────────── */\n"
".topbar {\n"
"  grid-column: 1 / -1;\n"
"  padding: 14px 16px;\n"
"  display: flex;\n"
"  align-items: center;\n"
"  justify-content: space-between;\n"
"  gap: 10px;\n"
"  flex-wrap: wrap;\n"
"}\n"
"\n"
".brand {\n"
"  display: flex;\n"
"  align-items: center;\n"
"  gap: 12px;\n"
"}\n"
"\n"
"/* Brand icon: gradient fill instead of image */\n"
".cr-brand-icon {\n"
"  width: 36px;\n"
"  height: 36px;\n"
"  border-radius: 9px;\n"
"  background: linear-gradient(135deg, var(--cr-brand), var(--cr-brand-3));\n"
"  border: 1px solid var(--cr-brand-line);\n"
"  display: flex;\n"
"  align-items: center;\n"
"  justify-content: center;\n"
"  flex-shrink: 0;\n"
"}\n"
"\n"
".brand h1 {\n"
"  margin: 0;\n"
"  font-size: clamp(1.1rem, 2vw, 1.3rem);\n"
"  font-weight: 600;\n"
"  letter-spacing: -0.02em;\n"
"  line-height: 1;\n"
"  font-family: var(--cr-font-display);\n"
"  color: var(--cr-white);\n"
"}\n"
"\n"
".brand .sub {\n"
"  margin-top: 3px;\n"
"  color: var(--cr-muted-2);\n"
"  font-size: 11px;\n"
"  font-family: var(--cr-font-mono);\n"
"}\n"
"\n"
".topbar-right {\n"
"  display: flex;\n"
"  align-items: center;\n"
"  gap: 8px;\n"
"  flex-wrap: wrap;\n"
"}\n"
"\n"
"/* ── Buttons ─────────────────────────────────────────────── */\n"
".cr-btn, .btn {\n"
"  display: inline-flex;\n"
"  align-items: center;\n"
"  justify-content: center;\n"
"  gap: 6px;\n"
"  border-radius: var(--cr-radius-sm);\n"
"  padding: 7px 13px;\n"
"  font-size: 12px;\n"
"  font-weight: 500;\n"
"  font-family: var(--cr-font-mono);\n"
"  letter-spacing: 0.02em;\n"
"  cursor: pointer;\n"
"  white-space: nowrap;\n"
"  border: 1px solid var(--cr-line-strong);\n"
"  background: var(--cr-panel-3);\n"
"  color: var(--cr-white-2);\n"
"  text-decoration: none;\n"
"  transition:\n"
"    border-color 0.15s ease,\n"
"    background   0.15s ease,\n"
"    color        0.15s ease,\n"
"    transform    0.15s cubic-bezier(0.2,0.8,0.2,1);\n"
"  position: relative;\n"
"  overflow: hidden;\n"
"  will-change: transform;\n"
"}\n"
"\n"
"/* No pseudo shimmer overlay — keep it flat */\n"
".cr-btn::before, .btn::before { display: none; }\n"
"\n"
".cr-btn:hover:not(:disabled),\n"
".btn:hover:not(:disabled) {\n"
"  border-color: var(--cr-line-3);\n"
"  color: var(--cr-white);\n"
"  background: #222230;\n"
"  transform: translateY(-1px);\n"
"}\n"
".cr-btn:active:not(:disabled),\n"
".btn:active:not(:disabled) { transform: scale(0.97); }\n"
"\n"
"/* Ghost variant */\n"
".btn.ghost {\n"
"  background: transparent;\n"
"  border-color: var(--cr-line);\n"
"}\n"
".btn.ghost:hover {\n"
"  background: var(--cr-panel-3);\n"
"  border-color: var(--cr-line-strong);\n"
"}\n"
"\n"
"/* Primary */\n"
".btn.primary, .btn[data-launch] {\n"
"  background: linear-gradient(135deg, var(--cr-brand-2) 0%, var(--cr-brand-3) 100%);\n"
"  border-color: var(--cr-brand-line);\n"
"  color: #fff;\n"
"}\n"
".btn.primary:hover:not(:disabled),\n"
".btn[data-launch]:hover:not(:disabled) {\n"
"  filter: brightness(1.08);\n"
"}\n"
"\n"
"/* Secondary / Danger / Compact */\n"
".btn.secondary { border-color: var(--cr-line); background: rgba(255,255,255,0.03); color: var(--cr-white); }\n"
".btn.danger     { background: rgba(220,38,38,0.10); border-color: rgba(220,38,38,0.28); color: #f87171; }\n"
".btn.compact    { padding: 5px 10px; font-size: 11px; border-radius: var(--cr-radius-sm); }\n"
"\n"
"/* Topbar social buttons share the base .btn style */\n"
".cr-support-button {\n"
"  composes: btn;\n"
"  border-color: rgba(220,38,38,0.35);\n"
"  background: rgba(127,29,29,0.20);\n"
"  border-radius: 9999px;\n"
"}\n"
".cr-support-button:hover {\n"
"  border-color: rgba(220,38,38,0.60);\n"
"  transform: translateY(-1px);\n"
"}\n"
"\n"
".cr-discord-button {\n"
"  border: 1px solid rgba(88,101,242,0.35);\n"
"  background: rgba(30,33,108,0.25);\n"
"  border-radius: 9999px;\n"
"  display: inline-flex; align-items: center; gap: 8px;\n"
"  padding: 7px 13px; font-size: 12px; font-weight: 500;\n"
"  text-decoration: none; color: #fff;\n"
"  transition: border-color 0.15s, transform 0.15s, filter 0.15s;\n"
"  white-space: nowrap;\n"
"}\n"
".cr-discord-button:hover { border-color: rgba(88,101,242,0.65); transform: translateY(-1px); filter: brightness(1.1); }\n"
"\n"
".cr-x-button {\n"
"  border: 1px solid rgba(255,255,255,0.16);\n"
"  background: rgba(24,24,27,0.80);\n"
"  border-radius: 9999px;\n"
"  display: inline-flex; align-items: center; gap: 8px;\n"
"  padding: 7px 13px; font-size: 12px; font-weight: 500;\n"
"  text-decoration: none; color: #fff;\n"
"  transition: border-color 0.15s, transform 0.15s, filter 0.15s;\n"
"  white-space: nowrap;\n"
"}\n"
".cr-x-button:hover { border-color: rgba(255,255,255,0.32); transform: translateY(-1px); filter: brightness(1.1); }\n"
".cr-x-button:active, .cr-discord-button:active, .cr-support-button:active { transform: scale(0.97); }\n"
"\n"
"/* Support modal */\n"
".cr-support-modal-overlay {\n"
"  position: fixed; inset: 0; z-index: 200;\n"
"  background: rgba(0,0,0,0.70); backdrop-filter: blur(6px);\n"
"  display: flex; align-items: center; justify-content: center;\n"
"}\n"
".cr-support-modal {\n"
"  background: var(--cr-panel-2); border: 1px solid var(--cr-line-strong);\n"
"  border-radius: var(--cr-radius-lg); padding: 28px 24px 20px;\n"
"  max-width: 360px; width: 90%; text-align: center;\n"
"  box-shadow: 0 24px 56px -12px rgba(0,0,0,0.65);\n"
"}\n"
".cr-support-modal h2   { margin: 0 0 8px; font-size: 18px; font-weight: 600; }\n"
".cr-support-modal p    { margin: 0 0 18px; color: var(--cr-muted); font-size: 13px; line-height: 1.55; }\n"
".cr-support-modal .kofi-link {\n"
"  display: inline-flex; align-items: center; gap: 8px;\n"
"  padding: 9px 20px; border-radius: 9999px;\n"
"  font-size: 13px; font-weight: 600; text-decoration: none; color: #fff;\n"
"  border: 1px solid rgba(220,38,38,0.40); background: rgba(127,29,29,0.22);\n"
"  transition: filter 0.15s, transform 0.15s;\n"
"}\n"
".cr-support-modal .kofi-link:hover { filter: brightness(1.12); transform: translateY(-1px); }\n"
".cr-support-modal .modal-close-row { margin-top: 16px; }\n"
"\n"
"/* ── Pills & Badges ──────────────────────────────────────── */\n"
".cr-pill, .badge {\n"
"  display: inline-flex;\n"
"  align-items: center;\n"
"  gap: 5px;\n"
"  border-radius: 9999px;\n"
"  padding: 3px 9px;\n"
"  font-size: 10px;\n"
"  font-family: var(--cr-font-mono);\n"
"  font-weight: 500;\n"
"  text-transform: uppercase;\n"
"  letter-spacing: 0.08em;\n"
"  border: 1px solid var(--cr-line-strong);\n"
"  background: var(--cr-panel-3);\n"
"  color: var(--cr-muted);\n"
"  white-space: nowrap;\n"
"}\n"
".cr-pill.blue, .badge.blue      { color: #f97316; border-color: var(--cr-brand-line); background: var(--cr-brand-soft); }\n"
".cr-pill.green, .badge.green    { color: #4ade80; border-color: var(--cr-green-border); background: var(--cr-green-soft); }\n"
".cr-pill.red, .badge.red        { color: #f87171; border-color: rgba(220,38,38,0.28); background: rgba(220,38,38,0.10); }\n"
".badge.yellow { color: #fbbf24; border-color: rgba(217,119,6,0.28); background: rgba(217,119,6,0.10); }\n"
".badge.gray   { color: var(--cr-muted); border-color: var(--cr-line); background: rgba(255,255,255,0.03); }\n"
"\n"
"/* ── Layout columns ──────────────────────────────────────── */\n"
".main, .side { display: flex; flex-direction: column; gap: 12px; min-width: 0; }\n"
"\n"
"/* ── Card (generic) ──────────────────────────────────────── */\n"
".card {\n"
"  border: 1px solid var(--cr-line-strong);\n"
"  background: var(--cr-panel-2);\n"
"  border-radius: var(--cr-radius);\n"
"  overflow: hidden;\n"
"  transition: border-color 200ms ease;\n"
"}\n"
".small { border-radius: var(--cr-radius); padding: 12px; }\n"
".small h3 {\n"
"  margin: 0 0 10px;\n"
"  font-size: 10px;\n"
"  letter-spacing: 0.12em;\n"
"  text-transform: uppercase;\n"
"  color: var(--cr-muted-2);\n"
"  font-family: var(--cr-font-mono);\n"
"  font-weight: 600;\n"
"}\n"
"\n"
"/* ── Toolbar ─────────────────────────────────────────────── */\n"
".toolbar {\n"
"  display: grid;\n"
"  grid-template-columns: minmax(0,1fr) auto auto auto;\n"
"  gap: 8px;\n"
"  padding: 12px;\n"
"}\n"
"\n"
".input, .select {\n"
"  border: 1px solid var(--cr-line-strong);\n"
"  background: var(--cr-bg-3);\n"
"  color: var(--cr-white);\n"
"  border-radius: var(--cr-radius-sm);\n"
"  padding: 8px 11px;\n"
"  font-size: 13px;\n"
"  font-family: var(--cr-font-mono);\n"
"  width: 100%;\n"
"  min-width: 0;\n"
"  transition: border-color 0.15s;\n"
"}\n"
".input:focus, .select:focus {\n"
"  outline: none;\n"
"  border-color: var(--cr-brand-2);\n"
"}\n"
".input::placeholder { color: var(--cr-muted-2); }\n"
"\n"
"/* Tabs */\n"
".tabs { display: flex; gap: 4px; }\n"
".tab {\n"
"  border: 1px solid transparent;\n"
"  background: transparent;\n"
"  color: var(--cr-muted-2);\n"
"  border-radius: var(--cr-radius-sm);\n"
"  padding: 6px 12px;\n"
"  font-family: var(--cr-font-mono);\n"
"  font-size: 11px;\n"
"  letter-spacing: 0.07em;\n"
"  text-transform: uppercase;\n"
"  font-weight: 500;\n"
"  cursor: pointer;\n"
"  transition: all 0.15s ease;\n"
"}\n"
".tab:hover { color: var(--cr-white-2); background: var(--cr-panel-3); }\n"
".tab.active { color: #f97316; border-color: var(--cr-brand-line); background: var(--cr-brand-soft); }\n"
"\n"
"/* ── Game grid ───────────────────────────────────────────── */\n"
".games {\n"
"  display: grid;\n"
"  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));\n"
"  gap: 10px;\n"
"  padding: 12px;\n"
"}\n"
"\n"
".cr-game-tile {\n"
"  border-radius: var(--cr-radius);\n"
"  border: 1px solid var(--cr-line-strong);\n"
"  background: var(--cr-panel);\n"
"  padding: 10px;\n"
"  cursor: pointer;\n"
"  transition:\n"
"    transform    0.18s cubic-bezier(0.2,0.8,0.2,1),\n"
"    border-color 0.18s ease;\n"
"  position: relative;\n"
"  overflow: hidden;\n"
"  will-change: transform;\n"
"}\n"
"\n"
"/* Left-edge accent strip — visible only on hover / active states */\n"
".cr-game-tile::before {\n"
"  content: \"\";\n"
"  position: absolute;\n"
"  left: 0; top: 0; bottom: 0;\n"
"  width: 2px;\n"
"  background: transparent;\n"
"  transition: background 0.18s ease;\n"
"}\n"
"\n"
".cr-game-tile:hover {\n"
"  border-color: var(--cr-line-3);\n"
"  transform: translateY(-2px);\n"
"}\n"
".cr-game-tile:hover::before { background: var(--cr-brand-2); }\n"
"\n"
".cr-game-tile.active { border-color: var(--cr-brand-line); }\n"
".cr-game-tile.active::before { background: var(--cr-brand-2); }\n"
"\n"
".cr-game-tile.running { border-color: var(--cr-green-border); }\n"
".cr-game-tile.running::before { background: var(--cr-green); }\n"
"\n"
".cr-game-tile.is-launching {\n"
"  border-color: var(--cr-brand-line);\n"
"  animation: crCardPulse 1.1s ease-in-out infinite;\n"
"}\n"
"\n"
"/* Launch overlay */\n"
".cr-launch-overlay {\n"
"  position: absolute; inset: 0; overflow: hidden;\n"
"  border-radius: var(--cr-radius);\n"
"  background: rgba(5,5,5,0.76);\n"
"  z-index: 4;\n"
"  display: flex; align-items: center; justify-content: center;\n"
"  font-family: var(--cr-font-mono); font-size: 11px;\n"
"  font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;\n"
"  color: #fed7aa;\n"
"}\n"
".cr-launch-overlay::before {\n"
"  content: \"\";\n"
"  position: absolute; left: 0; right: 0; height: 2px; top: 0;\n"
"  background: linear-gradient(90deg, transparent, rgba(234,88,12,0.80), transparent);\n"
"  animation: crVertScan 0.85s linear infinite;\n"
"  pointer-events: none;\n"
"}\n"
"\n"
".game-cover {\n"
"  width: 100%; aspect-ratio: 1/1;\n"
"  object-fit: cover;\n"
"  border-radius: var(--cr-radius-sm);\n"
"  background: var(--cr-bg-3);\n"
"  border: 1px solid var(--cr-line);\n"
"}\n"
"\n"
".game-name {\n"
"  margin-top: 9px;\n"
"  font-weight: 600;\n"
"  font-family: var(--cr-font-display);\n"
"  font-size: 13px;\n"
"  line-height: 1.3;\n"
"  color: var(--cr-white);\n"
"}\n"
".game-sub {\n"
"  margin-top: 4px;\n"
"  color: var(--cr-muted-2);\n"
"  font-size: 11px;\n"
"  display: flex; justify-content: space-between; gap: 8px;\n"
"  flex-wrap: wrap;\n"
"  font-family: var(--cr-font-mono);\n"
"}\n"
".game-badges { margin-top: 8px; display: flex; gap: 4px; flex-wrap: wrap; }\n"
"\n"
".running-dot {\n"
"  width: 6px; height: 6px;\n"
"  border-radius: 999px;\n"
"  background: var(--cr-green);\n"
"  display: inline-block;\n"
"  animation: crStatusTick 2s infinite;\n"
"}\n"
"\n"
"/* ── Status grid (sidebar) ───────────────────────────────── */\n"
".status-grid { display: grid; grid-template-columns: 1fr; gap: 6px; }\n"
".status-item {\n"
"  border: 1px solid var(--cr-line);\n"
"  border-radius: var(--cr-radius-sm);\n"
"  padding: 9px 11px;\n"
"  background: var(--cr-bg-3);\n"
"  display: flex; align-items: center; justify-content: space-between;\n"
"}\n"
".status-k {\n"
"  color: var(--cr-muted-2); font-size: 11px;\n"
"  text-transform: uppercase; letter-spacing: 0.10em;\n"
"  font-family: var(--cr-font-mono);\n"
"}\n"
".status-v { font-size: 12px; font-family: var(--cr-font-mono); color: var(--cr-white); }\n"
"\n"
"/* ── Logs ────────────────────────────────────────────────── */\n"
".logs-head {\n"
"  display: flex; align-items: center; justify-content: space-between;\n"
"  gap: 10px; margin-bottom: 10px;\n"
"}\n"
".logs-head h3 { margin: 0; }\n"
".logs-actions { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }\n"
"\n"
".cr-logs-console {\n"
"  min-height: 100px; max-height: 220px;\n"
"  overflow: auto;\n"
"  border: 1px solid var(--cr-line-strong);\n"
"  border-left: 2px solid var(--cr-brand-2);\n"
"  border-radius: var(--cr-radius-sm);\n"
"  padding: 10px;\n"
"  background: var(--cr-bg);\n"
"  color: var(--cr-white-2);\n"
"  font-family: var(--cr-font-mono);\n"
"  font-size: 11px;\n"
"  white-space: pre-wrap;\n"
"  word-break: break-word;\n"
"  line-height: 1.6;\n"
"}\n"
".logs-line.info    { color: #b4b4c0; }\n"
".logs-line.warn    { color: #fbbf24; }\n"
".logs-line.error   { color: #f87171; }\n"
".logs-line.success { color: #4ade80; }\n"
"\n"
"/* ── Restart status bar ──────────────────────────────────── */\n"
".restart-status {\n"
"  margin-top: 10px;\n"
"  border: 1px solid var(--cr-line);\n"
"  border-radius: var(--cr-radius-sm);\n"
"  padding: 10px;\n"
"  background: rgba(0,0,0,0.25);\n"
"  color: var(--cr-muted);\n"
"  font-family: var(--cr-font-mono);\n"
"  font-size: 11px;\n"
"  line-height: 1.45;\n"
"  display: none;\n"
"  white-space: pre-line;\n"
"}\n"
".restart-status.info    { border-color: var(--cr-brand-line); color: #fed7aa; }\n"
".restart-status.error   { border-color: rgba(220,38,38,0.40); color: #fecaca; }\n"
".restart-status.success { border-color: var(--cr-green-border); color: #bbf7d0; }\n"
"\n"
"/* ── Trainer overlay ─────────────────────────────────────── */\n"
".cr-trainer-overlay {\n"
"  position: fixed; inset: 0; z-index: 99999;\n"
"  display: none; align-items: center; justify-content: center;\n"
"  padding: 14px;\n"
"  background: rgba(5,5,5,0.85);\n"
"}\n"
".cr-trainer-overlay.show { display: flex; }\n"
"\n"
".cr-trainer-console {\n"
"  width: min(700px, 100%);\n"
"  max-height: 85vh;\n"
"  display: flex; flex-direction: column;\n"
"  overflow: hidden;\n"
"  background: var(--cr-panel);\n"
"  border: 1px solid var(--cr-line-strong);\n"
"  border-left: 3px solid var(--cr-brand-2);\n"
"  border-radius: var(--cr-radius-lg);\n"
"  box-shadow: 0 40px 80px rgba(0,0,0,0.80);\n"
"  animation: crPanelDeploy 0.22s cubic-bezier(0.16,1,0.3,1);\n"
"}\n"
".cr-trainer-console::before {\n"
"  content: \"Trainer Console\";\n"
"  display: block;\n"
"  padding: 4px 12px;\n"
"  font-family: var(--cr-font-mono);\n"
"  font-size: 10px;\n"
"  letter-spacing: 0.14em;\n"
"  text-transform: uppercase;\n"
"  color: #f97316;\n"
"  background: var(--cr-brand-soft);\n"
"  border-bottom: 1px solid var(--cr-brand-line);\n"
"}\n"
"\n"
".modal-header {\n"
"  display: flex; justify-content: space-between;\n"
"  align-items: flex-start; gap: 10px;\n"
"  padding: 14px 16px;\n"
"  border-bottom: 1px solid var(--cr-line);\n"
"}\n"
".modal-title {\n"
"  margin: 0;\n"
"  font-size: clamp(1.1rem, 2.2vw, 1.5rem);\n"
"  font-family: var(--cr-font-display);\n"
"  font-weight: 600; line-height: 1.2;\n"
"}\n"
".modal-sub { margin-top: 5px; color: var(--cr-muted-2); font-family: var(--cr-font-mono); font-size: 11px; }\n"
"\n"
".xbtn {\n"
"  width: 32px; height: 32px;\n"
"  border-radius: 999px;\n"
"  border: 1px solid var(--cr-line-strong);\n"
"  background: var(--cr-panel-2);\n"
"  color: var(--cr-white);\n"
"  cursor: pointer;\n"
"  flex: 0 0 auto;\n"
"  display: flex; align-items: center; justify-content: center;\n"
"  transition: background 0.15s;\n"
"}\n"
".xbtn:hover { background: var(--cr-panel-3); }\n"
"\n"
".modal-body {\n"
"  flex: 1; overflow: auto;\n"
"  padding: 14px; display: grid; gap: 10px;\n"
"  background: var(--cr-bg-2);\n"
"}\n"
".modal-footer {\n"
"  display: flex; justify-content: space-between;\n"
"  gap: 10px; flex-wrap: wrap;\n"
"  padding: 12px 16px;\n"
"  border-top: 1px solid var(--cr-line);\n"
"  background: var(--cr-panel);\n"
"}\n"
"\n"
"/* ── Cheat info / empty ──────────────────────────────────── */\n"
".cheat-info {\n"
"  border: 1px solid var(--cr-brand-line);\n"
"  border-left: 2px solid var(--cr-brand-2);\n"
"  border-radius: var(--cr-radius-sm);\n"
"  background: var(--cr-brand-soft);\n"
"  padding: 10px;\n"
"  font-family: var(--cr-font-mono);\n"
"  font-size: 12px;\n"
"  color: var(--cr-white-2);\n"
"}\n"
".cheat-empty {\n"
"  border: 1px dashed var(--cr-brand-line);\n"
"  border-radius: var(--cr-radius);\n"
"  background: var(--cr-brand-soft);\n"
"  padding: 16px;\n"
"  color: var(--cr-muted);\n"
"  font-family: var(--cr-font-mono);\n"
"  font-size: 12px;\n"
"}\n"
"\n"
".cr-cheat-dropzone {\n"
"  border: 1.5px dashed var(--cr-line-strong);\n"
"  border-radius: var(--cr-radius-sm);\n"
"  padding: 12px 16px;\n"
"  text-align: center;\n"
"  color: var(--cr-muted-2);\n"
"  font-family: var(--cr-font-mono);\n"
"  font-size: 11px;\n"
"  letter-spacing: 0.04em;\n"
"  cursor: pointer;\n"
"  transition: border-color 0.15s, background 0.15s, color 0.15s;\n"
"}\n"
".cr-cheat-dropzone:hover,\n"
".cr-cheat-dropzone.drag-over {\n"
"  border-color: var(--cr-brand-2);\n"
"  background: var(--cr-brand-soft);\n"
"  color: var(--cr-white-2);\n"
"}\n"
"\n"
"/* ── Modal tabs ──────────────────────────────────────────── */\n"
".cr-modal-tabs  { display: flex; gap: 6px; flex-wrap: wrap; }\n"
".cr-modal-tab {\n"
"  min-height: 32px; padding: 6px 14px;\n"
"  border-radius: 999px;\n"
"  border: 1px solid var(--cr-line-strong);\n"
"  background: var(--cr-panel-2);\n"
"  color: var(--cr-muted-2);\n"
"  font-size: 12px; font-weight: 500; cursor: pointer;\n"
"  transition: all 0.15s;\n"
"}\n"
".cr-modal-tab.active { color: #f97316; border-color: var(--cr-brand-line); background: var(--cr-brand-soft); }\n"
"\n"
".cr-modal-panel { display: grid; gap: 10px; }\n"
"\n"
"/* Source list */\n"
".cr-source-list  { display: grid; gap: 8px; }\n"
".cr-source-item  {\n"
"  border: 1px solid var(--cr-line-strong);\n"
"  border-radius: var(--cr-radius-sm);\n"
"  background: var(--cr-panel-2);\n"
"  padding: 10px 12px;\n"
"  display: grid; gap: 8px;\n"
"}\n"
".cr-source-main  { display: flex; justify-content: space-between; gap: 10px; align-items: center; flex-wrap: wrap; }\n"
".cr-source-name  { font-weight: 600; font-size: 12px; color: var(--cr-white-2); }\n"
".cr-source-meta  { font-size: 11px; color: var(--cr-muted-2); font-family: var(--cr-font-mono); word-break: break-word; }\n"
".cr-source-actions { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }\n"
".cr-panel-note   { font-size: 11px; color: var(--cr-muted-2); font-family: var(--cr-font-mono); }\n"
"\n"
"/* ── Cheat rows ──────────────────────────────────────────── */\n"
".cr-cheat-row {\n"
"  display: grid;\n"
"  grid-template-columns: 1fr auto;\n"
"  align-items: center;\n"
"  gap: 16px;\n"
"  min-height: 56px;\n"
"  padding: 11px 14px 11px 16px;\n"
"  border-radius: var(--cr-radius-sm);\n"
"  border: 1px solid var(--cr-line-strong);\n"
"  border-left: 2px solid transparent;\n"
"  background: var(--cr-panel-2);\n"
"  transition:\n"
"    background     200ms ease,\n"
"    border-color   180ms ease,\n"
"    border-left-color 180ms ease;\n"
"}\n"
"\n"
".cr-cheat-row.is-off  { border-left-color: var(--cr-muted-2); }\n"
".cr-cheat-row.is-off:hover { border-left-color: var(--cr-brand-2); }\n"
"\n"
".cr-cheat-row.is-on {\n"
"  background: linear-gradient(90deg, var(--cr-green-soft), rgba(13,13,16,0.80));\n"
"  border-color: var(--cr-green-border);\n"
"  border-left-color: var(--cr-green);\n"
"}\n"
"\n"
".cr-cheat-row.is-error {\n"
"  background: rgba(220,38,38,0.07);\n"
"  border-color: rgba(220,38,38,0.28);\n"
"  border-left-color: var(--cr-red);\n"
"}\n"
"\n"
".cr-cheat-row.is-mixed {\n"
"  background: linear-gradient(90deg, rgba(217,119,6,0.08), rgba(13,13,16,0.80));\n"
"  border-color: rgba(217,119,6,0.30);\n"
"  border-left-color: var(--cr-yellow);\n"
"}\n"
"\n"
".cr-cheat-row.is-unknown { border-left-color: var(--cr-muted-2); }\n"
"\n"
".cr-cheat-row.is-applying {\n"
"  opacity: 0.65;\n"
"  pointer-events: none;\n"
"  position: relative;\n"
"  overflow: hidden;\n"
"}\n"
".cr-cheat-row.is-applying::after {\n"
"  content: \"\";\n"
"  position: absolute; inset: 0;\n"
"  background: linear-gradient(90deg, transparent, rgba(234,88,12,0.08), transparent);\n"
"  animation: crScanSweep 0.9s linear infinite;\n"
"  pointer-events: none; z-index: 2;\n"
"}\n"
"\n"
"/* Row reveal animation */\n"
"#cheatMods.cr-mods-appear .cr-cheat-row { animation: crRowReveal 0.20s ease both; }\n"
"#cheatMods.cr-mods-appear .cr-cheat-row:nth-child(2) { animation-delay: 0.04s; }\n"
"#cheatMods.cr-mods-appear .cr-cheat-row:nth-child(3) { animation-delay: 0.08s; }\n"
"#cheatMods.cr-mods-appear .cr-cheat-row:nth-child(4) { animation-delay: 0.12s; }\n"
"#cheatMods.cr-mods-appear .cr-cheat-row:nth-child(5) { animation-delay: 0.16s; }\n"
"#cheatMods.cr-mods-appear .cr-cheat-row:nth-child(n+6) { animation-delay: 0.20s; }\n"
"\n"
".cr-cheat-main  { display: flex; flex-direction: column; gap: 3px; }\n"
".cr-cheat-name,\n"
".cr-cheat-title {\n"
"  font-family: var(--cr-font-display);\n"
"  font-weight: 600; font-size: 13px; line-height: 1.2;\n"
"  color: var(--cr-white);\n"
"}\n"
".cr-cheat-row.is-on   .cr-cheat-name,\n"
".cr-cheat-row.is-on   .cr-cheat-title { color: #4ade80; }\n"
".cr-cheat-row.is-mixed .cr-cheat-name,\n"
".cr-cheat-row.is-mixed .cr-cheat-title { color: #fde68a; }\n"
"\n"
".cr-cheat-status-chip {\n"
"  display: inline-block;\n"
"  font-size: 9px; font-weight: 600;\n"
"  font-family: var(--cr-font-mono);\n"
"  letter-spacing: 0.06em;\n"
"  padding: 1px 6px; border-radius: 4px; line-height: 1.6;\n"
"}\n"
".cr-chip-error { background: rgba(220,38,38,0.16); color: #fca5a5; border: 1px solid rgba(220,38,38,0.30); }\n"
".cr-chip-mixed { background: rgba(217,119,6,0.16); color: #fde68a; border: 1px solid rgba(217,119,6,0.30); }\n"
"\n"
"/* ── Cheat switch ────────────────────────────────────────── */\n"
".cr-cheat-switch {\n"
"  position: relative;\n"
"  width: 100px;\n"
"  height: 32px;\n"
"  padding: 0; border: 0;\n"
"  background: transparent;\n"
"  cursor: pointer;\n"
"  flex: 0 0 auto;\n"
"  -webkit-tap-highlight-color: transparent;\n"
"  transition: transform 0.18s ease, opacity 0.18s ease;\n"
"  will-change: transform;\n"
"}\n"
"\n"
".cr-cheat-switch-track {\n"
"  position: relative;\n"
"  display: grid;\n"
"  grid-template-columns: 1fr 1fr;\n"
"  align-items: center;\n"
"  width: 100%; height: 100%;\n"
"  border-radius: 999px;\n"
"  overflow: hidden;\n"
"  background: var(--cr-bg-3);\n"
"  border: 1px solid var(--cr-switch-border);\n"
"  box-shadow: inset 0 1px 0 rgba(255,255,255,0.04), inset 0 -1px 0 rgba(0,0,0,0.28);\n"
"}\n"
"\n"
".cr-cheat-switch-fill {\n"
"  position: absolute;\n"
"  top: 3px; left: 3px;\n"
"  width: calc(50% - 3px);\n"
"  height: calc(100% - 6px);\n"
"  border-radius: 999px;\n"
"  z-index: 1;\n"
"  background: linear-gradient(180deg, var(--cr-state-off), var(--cr-state-off-2));\n"
"  box-shadow: 0 0 12px var(--cr-state-off-glow);\n"
"  transform: translateX(0);\n"
"  transition:\n"
"    transform  0.22s cubic-bezier(0.2,0.8,0.2,1),\n"
"    background 0.18s ease,\n"
"    box-shadow 0.18s ease;\n"
"}\n"
".cr-cheat-switch.is-on .cr-cheat-switch-fill {\n"
"  transform: translateX(calc(100% - 3px));\n"
"  background: linear-gradient(180deg, var(--cr-state-on), var(--cr-state-on-2));\n"
"  box-shadow: 0 0 14px var(--cr-state-on-glow);\n"
"}\n"
"\n"
".cr-cheat-switch-label {\n"
"  position: relative; z-index: 2;\n"
"  font-family: var(--cr-font-mono);\n"
"  font-size: 9px; font-weight: 600;\n"
"  letter-spacing: 0.10em;\n"
"  text-align: center; text-transform: uppercase;\n"
"  color: rgba(255,255,255,0.30);\n"
"  user-select: none; pointer-events: none;\n"
"  transition: color 0.18s ease;\n"
"}\n"
".cr-cheat-switch.is-off .cr-cheat-switch-label-off { color: #fff; }\n"
".cr-cheat-switch.is-on  .cr-cheat-switch-label-on  { color: #fff; }\n"
"\n"
".cr-cheat-switch:hover:not(:disabled):not(.is-applying) { transform: translateY(-1px); }\n"
".cr-cheat-switch:hover:not(:disabled):not(.is-applying) .cr-cheat-switch-track {\n"
"  border-color: rgba(255,255,255,0.20);\n"
"}\n"
".cr-cheat-switch:active:not(:disabled):not(.is-applying) { transform: scale(0.97); }\n"
".cr-cheat-switch:disabled { opacity: 0.40; cursor: not-allowed; }\n"
".cr-cheat-switch:focus-visible { outline: 2px solid rgba(255,255,255,0.60); outline-offset: 3px; }\n"
"\n"
"/* ON track subtle glow */\n"
".cr-cheat-switch.is-on .cr-cheat-switch-track {\n"
"  box-shadow:\n"
"    inset 0 1px 0 rgba(255,255,255,0.04),\n"
"    inset 0 -1px 0 rgba(0,0,0,0.28),\n"
"    0 0 12px var(--cr-state-on-glow);\n"
"}\n"
"\n"
"/* Error / Mixed switch fill */\n"
".cr-cheat-switch.is-error .cr-cheat-switch-fill {\n"
"  background: linear-gradient(180deg, #f97316, #7c2d12);\n"
"  box-shadow: 0 0 12px rgba(249,115,22,0.35);\n"
"}\n"
".cr-cheat-switch.is-mixed .cr-cheat-switch-fill {\n"
"  background: linear-gradient(180deg, var(--cr-yellow), #92400e);\n"
"  box-shadow: 0 0 12px rgba(217,119,6,0.35);\n"
"}\n"
"\n"
"/* Applying shimmer */\n"
".cr-cheat-switch.is-applying {\n"
"  cursor: progress !important;\n"
"  pointer-events: none;\n"
"  opacity: 0.75;\n"
"}\n"
".cr-cheat-switch.is-applying .cr-cheat-switch-track::after {\n"
"  content: '';\n"
"  position: absolute; inset: 0; z-index: 4;\n"
"  border-radius: inherit;\n"
"  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.18), transparent);\n"
"  transform: translateX(-100%);\n"
"  animation: crSwitchScan 0.75s linear infinite;\n"
"  pointer-events: none;\n"
"}\n"
"@keyframes crSwitchScan { to { transform: translateX(100%); } }\n"
"\n"
"/* ── Candidate selector ──────────────────────────────────── */\n"
"#cheatCandidates { margin: 6px 0 10px 0; }\n"
".cr-cand-list { display: flex; flex-direction: column; gap: 5px; }\n"
".cr-cand-row {\n"
"  display: flex; align-items: center; gap: 8px;\n"
"  padding: 8px 12px;\n"
"  border-radius: var(--cr-radius-sm);\n"
"  background: rgba(255,255,255,0.02);\n"
"  border: 1px solid var(--cr-line);\n"
"  border-left: 2px solid transparent;\n"
"  font-size: 12px;\n"
"  transition:\n"
"    transform    150ms cubic-bezier(0.2,0.8,0.2,1),\n"
"    border-color 160ms ease,\n"
"    background   160ms ease;\n"
"  will-change: transform;\n"
"}\n"
".cr-cand-row:hover { transform: translateY(-1px); }\n"
".cr-cand-row.is-selected {\n"
"  border-color: var(--cr-green-border);\n"
"  border-left-color: var(--cr-green);\n"
"  background: var(--cr-green-soft);\n"
"}\n"
".cr-cand-row.is-wrong-ver {\n"
"  border-color: rgba(217,119,6,0.25);\n"
"  border-left-color: var(--cr-yellow);\n"
"  background: rgba(217,119,6,0.05);\n"
"}\n"
"\n"
".cr-cand-fname    { flex: 1; font-family: var(--cr-font-mono); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: var(--cr-white-2); }\n"
".cr-cand-meta     { font-size: 10px; color: var(--cr-muted-2); font-family: var(--cr-font-mono); white-space: nowrap; }\n"
".cr-cand-badge    { font-size: 10px; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; padding: 2px 7px; border-radius: 4px; white-space: nowrap; }\n"
".cr-cand-badge.fmt     { background: rgba(100,130,200,0.16); color: #93c5fd; border: 1px solid rgba(100,130,200,0.22); }\n"
".cr-cand-badge.exact   { background: var(--cr-green-soft); color: #86efac; border: 1px solid var(--cr-green-border); }\n"
".cr-cand-badge.generic { background: rgba(150,150,150,0.14); color: #a1a1aa; border: 1px solid rgba(150,150,150,0.20); }\n"
".cr-cand-badge.wrong   { background: rgba(217,119,6,0.16); color: #fcd34d; border: 1px solid rgba(217,119,6,0.28); }\n"
".cr-cand-badge.selected { background: rgba(22,163,74,0.22); color: #86efac; border: 1px solid var(--cr-green-border); }\n"
".cr-cand-badge.manual  { background: rgba(130,100,200,0.20); color: #c4b5fd; border: 1px solid rgba(130,100,200,0.30); }\n"
".cr-cand-select-btn { font-size: 11px; padding: 3px 10px; flex-shrink: 0; }\n"
".cr-cand-auto-btn   { font-size: 11px; padding: 3px 10px; flex-shrink: 0; background: rgba(130,100,200,0.16); }\n"
"\n"
"/* ── Toast ───────────────────────────────────────────────── */\n"
".toast {\n"
"  position: fixed;\n"
"  right: 16px; top: 16px;\n"
"  z-index: 100000;\n"
"  border: 1px solid var(--cr-line-strong);\n"
"  border-left: 2px solid var(--cr-brand-2);\n"
"  background: var(--cr-panel-2);\n"
"  color: var(--cr-white);\n"
"  border-radius: var(--cr-radius-sm);\n"
"  padding: 10px 14px;\n"
"  max-width: min(90vw, 360px);\n"
"  font-family: var(--cr-font-mono);\n"
"  font-size: 12px;\n"
"  opacity: 0;\n"
"  pointer-events: none;\n"
"}\n"
".toast.show   { animation: crToastIn 0.22s cubic-bezier(0.16,1,0.3,1) forwards; }\n"
".toast.info   { border-left-color: var(--cr-brand-2); background: var(--cr-brand-soft); }\n"
".toast.success { border-left-color: var(--cr-green); background: var(--cr-green-soft); color: #bbf7d0; }\n"
".toast.warn   { border-left-color: var(--cr-yellow); background: rgba(217,119,6,0.09); color: #fde68a; }\n"
".toast.error  { border-left-color: var(--cr-red); background: rgba(220,38,38,0.10); color: #fca5a5; }\n"
"\n"
"/* ── Misc ────────────────────────────────────────────────── */\n"
".muted { color: var(--cr-muted-2); font-size: 12px; }\n"
".row   { display: flex; gap: 8px; flex-wrap: wrap; }\n"
"\n"
"/* ── Keyframes ───────────────────────────────────────────── */\n"
"@keyframes crPanelDeploy  { from { opacity:0; transform:translateY(16px); } to { opacity:1; transform:translateY(0); } }\n"
"@keyframes crScanSweep    { from { transform:translateX(-120%); } to { transform:translateX(120%); } }\n"
"@keyframes crStatusTick   { 0%,100% { opacity:1; } 50% { opacity:.35; } }\n"
"@keyframes crToastIn      { from { opacity:0; transform:translateY(-5px) scale(.97); } to { opacity:1; transform:translateY(0) scale(1); } }\n"
"@keyframes crCardPulse    { 0%,100% { border-left-color:var(--cr-brand); } 50% { border-left-color:var(--cr-brand-2); box-shadow:0 0 22px rgba(234,88,12,0.22); } }\n"
"@keyframes crVertScan     { 0% { top:-4px; opacity:1; } 100% { top:100%; opacity:.4; } }\n"
"@keyframes crRowReveal    { from { opacity:0; transform:translateY(6px); } to { opacity:1; transform:translateY(0); } }\n"
"\n"
"/* ── Accessibility ───────────────────────────────────────── */\n"
"@media (prefers-reduced-motion: reduce) {\n"
"  .cr-cheat-switch, .cr-cheat-switch-track, .cr-cheat-switch-fill,\n"
"  .cr-cheat-switch *, .cr-cheat-row, .cr-cand-row,\n"
"  .cr-game-tile, .card, .btn, .cr-btn,\n"
"  .cr-support-button, .cr-discord-button, .cr-x-button {\n"
"    transition: none !important;\n"
"    animation: none !important;\n"
"  }\n"
"}\n"
"\n"
":focus-visible {\n"
"  outline: 2px solid rgba(234,88,12,0.65);\n"
"  outline-offset: 3px;\n"
"}\n"
"\n"
"/* ── Scrollbar ───────────────────────────────────────────── */\n"
"::-webkit-scrollbar { width: 5px; height: 5px; }\n"
"::-webkit-scrollbar-track { background: transparent; }\n"
"::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.08); border-radius: 10px; }\n"
"::-webkit-scrollbar-thumb:hover { background: rgba(234,88,12,0.50); }\n"
"\n"
"/* ── Responsive ──────────────────────────────────────────── */\n"
"@media (max-width: 1200px) {\n"
"  .cr-app-shell { grid-template-columns: 1fr; }\n"
"  .side { order: 2; }\n"
"}\n"
"@media (max-width: 768px) {\n"
"  body { padding: 12px; }\n"
"  .toolbar { grid-template-columns: 1fr; }\n"
"  .tabs { overflow: auto; }\n"
"  .modal-footer { justify-content: stretch; }\n"
"  .modal-footer .btn { flex: 1 1 160px; }\n"
"  .topbar { padding: 12px; }\n"
"}\n"
"@media (max-width: 640px) {\n"
"  .cr-support-button,\n"
"  .cr-discord-button,\n"
"  .cr-x-button { padding: 0; width: 36px; min-height: 36px; }\n"
"  .cr-support-label,\n"
"  .cr-discord-label,\n"
"  .cr-x-label { display: none; }\n"
"}\n"
