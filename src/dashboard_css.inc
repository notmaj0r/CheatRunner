"\n"
"    .cr-cheat-switch {\n"
"      position: relative;\n"
"      width: 108px;\n"
"      height: 36px;\n"
"      padding: 0;\n"
"      border: 0;\n"
"      background: transparent;\n"
"      cursor: pointer;\n"
"      flex: 0 0 auto;\n"
"      -webkit-tap-highlight-color: transparent;\n"
"    }\n"
"    .cr-cheat-switch-track {\n"
"      position: relative;\n"
"      display: grid;\n"
"      grid-template-columns: 1fr 1fr;\n"
"      align-items: center;\n"
"      width: 100%;\n"
"      height: 100%;\n"
"      border-radius: 999px;\n"
"      overflow: hidden;\n"
"      background: linear-gradient(180deg, rgba(15,23,42,0.98), rgba(2,6,23,0.98));\n"
"      border: 1px solid var(--cr-switch-border);\n"
"      box-shadow:\n"
"        inset 0 1px 0 rgba(255,255,255,0.06),\n"
"        inset 0 -1px 0 rgba(0,0,0,0.32),\n"
"        0 8px 20px rgba(0,0,0,0.30);\n"
"    }\n"
"    .cr-cheat-switch-fill {\n"
"      position: absolute;\n"
"      top: 3px;\n"
"      left: 3px;\n"
"      width: calc(50% - 3px);\n"
"      height: calc(100% - 6px);\n"
"      border-radius: 999px;\n"
"      z-index: 1;\n"
"      background: linear-gradient(180deg, var(--cr-state-off), var(--cr-state-off-2));\n"
"      box-shadow: 0 0 16px var(--cr-state-off-glow), inset 0 1px 0 rgba(255,255,255,0.20);\n"
"      transform: translateX(0);\n"
"      transition:\n"
"        transform .22s cubic-bezier(.2,.8,.2,1),\n"
"        background .18s ease,\n"
"        box-shadow .18s ease,\n"
"        filter .14s ease;\n"
"    }\n"
"    .cr-cheat-switch.is-on .cr-cheat-switch-fill {\n"
"      transform: translateX(calc(100% - 3px));\n"
"      background: linear-gradient(180deg, var(--cr-state-on), var(--cr-state-on-2));\n"
"      box-shadow: 0 0 18px var(--cr-state-on-glow), inset 0 1px 0 rgba(255,255,255,0.22);\n"
"    }\n"
"    .cr-cheat-switch-label {\n"
"      position: relative;\n"
"      z-index: 2;\n"
"      font-family: var(--cr-font-mono);\n"
"      font-size: 10px;\n"
"      font-weight: 900;\n"
"      letter-spacing: .10em;\n"
"      text-align: center;\n"
"      text-transform: uppercase;\n"
"      color: rgba(255,255,255,0.42);\n"
"      user-select: none;\n"
"      pointer-events: none;\n"
"      transition: color .18s ease, text-shadow .18s ease;\n"
"    }\n"
"    .cr-cheat-switch.is-off .cr-cheat-switch-label-off { color: #fff; text-shadow: 0 0 8px rgba(255,255,255,0.22); }\n"
"    .cr-cheat-switch.is-on .cr-cheat-switch-label-on { color: #fff; text-shadow: 0 0 8px rgba(255,255,255,0.22); }\n"
"    .cr-cheat-switch:hover .cr-cheat-switch-track { border-color: rgba(255,255,255,0.22); }\n"
"    .cr-cheat-switch:active .cr-cheat-switch-fill { filter: brightness(1.12); }\n"
"    .cr-cheat-switch:disabled { opacity: .45; cursor: not-allowed; }\n"
"    .cr-cheat-switch:focus-visible { outline: 2px solid rgba(255,255,255,0.70); outline-offset: 3px; }\n"
"    .cr-cheat-switch.is-pending { pointer-events: none; }\n"
"    .cr-cheat-switch.is-pending .cr-cheat-switch-track::after {\n"
"      content: '';\n"
"      position: absolute;\n"
"      inset: 0;\n"
"      z-index: 4;\n"
"      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.18), transparent);\n"
"      transform: translateX(-100%);\n"
"      animation: crSwitchScan .75s linear infinite;\n"
"    }\n"
"    @keyframes crSwitchScan { to { transform: translateX(100%); } }\n"
"    .cr-cheat-switch {\n"
"      transition:\n"
"        transform 180ms ease,\n"
"        filter 180ms ease,\n"
"        opacity 180ms ease;\n"
"      will-change: transform;\n"
"    }\n"
"    .cr-cheat-switch:hover:not(:disabled):not(.is-applying) { transform: translateY(-1px); }\n"
"    .cr-cheat-switch:hover:not(:disabled):not(.is-applying) .cr-cheat-switch-track {\n"
"      border-color: rgba(255,255,255,0.26);\n"
"      box-shadow:\n"
"        inset 0 1px 0 rgba(255,255,255,0.08),\n"
"        inset 0 -1px 0 rgba(0,0,0,0.32),\n"
"        0 10px 26px rgba(0,0,0,0.34);\n"
"    }\n"
"    .cr-cheat-switch:active:not(:disabled):not(.is-applying) { transform: scale(0.97); }\n"
"    .cr-cheat-switch.is-on .cr-cheat-switch-track {\n"
"      box-shadow:\n"
"        inset 0 1px 0 rgba(255,255,255,0.06),\n"
"        inset 0 -1px 0 rgba(0,0,0,0.32),\n"
"        0 8px 20px rgba(0,0,0,0.30),\n"
"        0 0 16px var(--cr-state-on-glow);\n"
"    }\n"
"    .cr-cheat-switch.is-error .cr-cheat-switch-fill {\n"
"      background: linear-gradient(180deg, #F97316, #7C2D12);\n"
"      box-shadow: 0 0 14px rgba(249,115,22,0.40), inset 0 1px 0 rgba(255,255,255,0.20);\n"
"    }\n"
"    .cr-cheat-switch.is-mixed .cr-cheat-switch-fill {\n"
"      background: linear-gradient(180deg, var(--cr-yellow), #B45309);\n"
"      box-shadow: 0 0 14px rgba(245,158,11,0.38), inset 0 1px 0 rgba(255,255,255,0.20);\n"
"    }\n"
"    .cr-cheat-switch.is-applying {\n"
"      cursor: progress !important;\n"
"      pointer-events: none;\n"
"      opacity: 0.78;\n"
"    }\n"
"    .cr-cheat-switch.is-applying .cr-cheat-switch-track::after {\n"
"      content: '';\n"
"      position: absolute;\n"
"      inset: 0;\n"
"      z-index: 4;\n"
"      border-radius: inherit;\n"
"      background: linear-gradient(90deg, transparent, rgba(255,255,255,.20), transparent);\n"
"      transform: translateX(-100%);\n"
"      animation: crSwitchScan .75s linear infinite;\n"
"      pointer-events: none;\n"
"    }\n"
"    @media (prefers-reduced-motion: reduce) {\n"
"      .cr-cheat-switch,\n"
"      .cr-cheat-switch-track,\n"
"      .cr-cheat-switch-fill,\n"
"      .cr-cheat-switch *,\n"
"      .cr-cheat-row,\n"
"      .cr-cand-row,\n"
"      .cr-game-tile,\n"
"      .card,\n"
"      .btn,\n"
"      .cr-btn,\n"
"      .kofi-link,\n"
"      .cr-support-button,\n"
"      .cr-discord-button,\n"
"      .cr-x-button { transition: none !important; animation: none !important; }\n"
"    }\n"
"\n"
"    /* Candidate selector */\n"
"    #cheatCandidates { margin: 6px 0 10px 0; }\n"
"    .cr-cand-list { display:flex; flex-direction:column; gap:5px; }\n"
"    .cr-cand-row {\n"
"      display:flex; align-items:center; gap:8px;\n"
"      padding:8px 12px;\n"
"      border-radius: var(--cr-radius-sm);\n"
"      background: rgba(255,255,255,0.03);\n"
"      border: 1px solid rgba(255,255,255,0.07);\n"
"      border-left: 3px solid transparent;\n"
"      font-size:12px;\n"
"      transition:\n"
"        transform 150ms cubic-bezier(.2,.8,.2,1),\n"
"        border-color 160ms ease,\n"
"        background 160ms ease,\n"
"        box-shadow 180ms ease;\n"
"      will-change: transform;\n"
"    }\n"
"    .cr-cand-row:hover { transform: translateY(-1px); box-shadow: 0 3px 10px rgba(0,0,0,.30); }\n"
"    .cr-cand-row.is-selected {\n"
"      border-color: rgba(34,197,94,0.40);\n"
"      border-left-color: var(--cr-green);\n"
"      background: rgba(34,197,94,0.07);\n"
"      box-shadow: 0 0 12px rgba(34,197,94,0.08);\n"
"    }\n"
"    .cr-cand-row.is-wrong-ver {\n"
"      border-color: rgba(245,158,11,0.30);\n"
"      border-left-color: var(--cr-yellow);\n"
"      background: rgba(245,158,11,0.05);\n"
"    }\n"
"    .cr-cand-fname { flex:1; font-family:var(--cr-font-mono); overflow:hidden; text-overflow:ellipsis; white-space:nowrap; color: var(--cr-white-2); }\n"
"    .cr-cand-meta { font-size:10px; color:var(--cr-muted); font-family:var(--cr-font-mono); white-space:nowrap; }\n"
"    .cr-cand-badge { font-size:10px; font-weight:700; letter-spacing:.06em; text-transform:uppercase;\n"
"      padding:2px 7px; border-radius:4px; white-space:nowrap; }\n"
"    .cr-cand-badge.fmt    { background:rgba(100,130,200,0.18); color:#aac4f0; border:1px solid rgba(100,130,200,0.22); }\n"
"    .cr-cand-badge.exact  { background:rgba(34,197,94,0.18); color:#86efac; border:1px solid rgba(34,197,94,0.30); }\n"
"    .cr-cand-badge.generic { background:rgba(150,150,150,0.18); color:#aaa; border:1px solid rgba(150,150,150,0.22); }\n"
"    .cr-cand-badge.wrong  { background:rgba(245,158,11,0.18); color:#fcd34d; border:1px solid rgba(245,158,11,0.30); }\n"
"    .cr-cand-badge.selected { background:rgba(34,197,94,0.28); color:#86efac; border:1px solid rgba(34,197,94,0.40); }\n"
"    .cr-cand-badge.manual { background:rgba(130,100,200,0.25); color:#c4b5fd; border:1px solid rgba(130,100,200,0.35); }\n"
"    .cr-cand-select-btn { font-size:11px; padding:3px 10px; flex-shrink:0; }\n"
"    .cr-cand-auto-btn   { font-size:11px; padding:3px 10px; background:rgba(130,100,200,0.18); flex-shrink:0; }\n"
"\n"
"    .toast {\n"
"      position: fixed;\n"
"      right: 14px;\n"
"      top: 14px;\n"
"      z-index: 100000;\n"
"      border: 1px solid var(--cr-line);\n"
"      border-left: 3px solid var(--cr-brand);\n"
"      background: var(--cr-panel-2);\n"
"      color: var(--cr-white);\n"
"      border-radius: var(--cr-radius-sm);\n"
"      padding: 10px 14px;\n"
"      max-width: min(90vw,380px);\n"
"      font-family: var(--cr-font-mono);\n"
"      font-size: 12px;\n"
"      opacity:0;\n"
"      pointer-events:none;\n"
"    }\n"
"    .toast.show { animation: crToastIn .22s cubic-bezier(.16,1,.3,1) forwards; }\n"
"    .toast.info { border-left-color: var(--cr-brand); background: var(--cr-brand-soft); }\n"
"    .toast.success { border-left-color: var(--cr-green); background: rgba(34,197,94,.09); color: #bbf7d0; }\n"
"    .toast.warn { border-left-color: var(--cr-yellow); background: rgba(245,158,11,.09); color: #fde68a; }\n"
"    .toast.error { border-left-color: var(--cr-red); background: rgba(239,68,68,.11); color: #fca5a5; }\n"
"\n"
"    .muted { color: var(--cr-muted); font-size: 13px; }\n"
"\n"
"    @keyframes crLineReveal { from { transform: scaleX(0); opacity:0; } to { transform: scaleX(1); opacity:1; } }\n"
"    @keyframes crPanelDeploy { from { opacity:0; transform: translateY(18px); clip-path: inset(8px 0 0 0 round 14px); } to { opacity:1; transform: translateY(0); clip-path: inset(0px round 14px); } }\n"
"    @keyframes crScanSweep { from { transform: translateX(-120%); } to { transform: translateX(120%); } }\n"
"    @keyframes crStatusTick { 0%,100% { opacity:1; } 50% { opacity:.35; } }\n"
"    @keyframes crToastSnap { from { opacity:0; transform: translateY(-8px); clip-path: inset(0 0 100% 0); } to { opacity:1; transform: translateY(0); clip-path: inset(0 0 0% 0); } }\n"
"    @keyframes crToastIn { from { opacity:0; transform: translateY(-6px) scale(.97); clip-path: inset(0 0 100% 0); } to { opacity:1; transform: translateY(0) scale(1); clip-path: inset(0 0 0% 0); } }\n"
"    @keyframes crCardPulse { 0%,100% { border-left-color: var(--cr-brand); box-shadow: 0 0 0 1px rgba(225,29,72,.14); } 50% { border-left-color: var(--cr-brand-2); box-shadow: 0 0 28px rgba(225,29,72,.30), 0 0 0 2px rgba(244,63,94,.18); } }\n"
"    @keyframes crVertScan { 0% { top: -4px; opacity: 1; } 100% { top: 100%; opacity: .4; } }\n"
"    @keyframes crModalScan { from { transform: translateY(-100%); opacity: .9; } to { transform: translateY(160%); opacity: 0; } }\n"
"    @keyframes crRowReveal { from { opacity:0; transform: translateY(7px); } to { opacity:1; transform: translateY(0); } }\n"
"\n"
"    :focus-visible {\n"
"      outline: 2px solid rgba(244,63,94,.68);\n"
"      outline-offset: 3px;\n"
"    }\n"
"    ::-webkit-scrollbar { width:6px; height:6px; }\n"
"    ::-webkit-scrollbar-track { background: transparent; }\n"
"    ::-webkit-scrollbar-thumb { background: rgba(255,255,255,.10); border-radius:10px; }\n"
"    ::-webkit-scrollbar-thumb:hover { background: rgba(244,63,94,.58); }\n"
"\n"
"    @media (max-width:1200px) { .cr-app-shell { grid-template-columns:1fr; } .side { order:2; } }\n"
"    @media (max-width:768px) {\n"
"      body { padding:12px; }\n"
"      .toolbar { grid-template-columns:1fr; }\n"
"      .tabs { overflow:auto; }\n"
"      .modal-footer { justify-content: stretch; }\n"
"      .modal-footer .btn { flex: 1 1 180px; }\n"
"      .topbar { padding: 12px; }\n"
"    }\n"
"    @media (max-width:640px) {\n"
"      .cr-support-button, .cr-discord-button, .cr-x-button { padding: 0; width: 36px; min-height: 36px; }\n"
"      .cr-support-label, .cr-discord-label, .cr-x-label { display: none; }\n"
"    }\n"
