"    #cheatMods.cr-mods-appear .cr-cheat-row:nth-child(n+6) { animation-delay: .20s; }\n"
"    .cr-cheat-main {\n"
"      display: flex;\n"
"      flex-direction: column;\n"
"      gap: 3px;\n"
"    }\n"
