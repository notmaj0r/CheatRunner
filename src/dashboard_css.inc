"      .cr-support-label, .cr-discord-label, .cr-x-label, .cr-bsky-label { display: none; }\n"
"    }\n"
"\n"
"    /* --- Mod search bar --- */\n"
"    .cr-mod-search { font-size:.85rem; height:36px; padding:8px 12px; }\n"
"    .cr-mod-search:focus { border-color:var(--cr-brand); box-shadow:0 0 0 1px var(--cr-brand-soft); }\n"
"\n"
"    /* --- Modal stats bar --- */\n"
"    .cr-modal-stats { display:flex; align-items:center; gap:6px; margin-top:6px; flex-wrap:wrap; }\n"
"    .cr-stat-pill {\n"
"      display:inline-flex; align-items:center; gap:4px;\n"
"      font-family:var(--cr-font-mono); font-size:10px; font-weight:700;\n"
"      letter-spacing:.08em; text-transform:uppercase;\n"
"      padding:2px 8px; border-radius:999px;\n"
"      border:1px solid var(--cr-line); background:rgba(255,255,255,.04); color:var(--cr-muted);\n"
"    }\n"
"    .cr-stat-pill.active { color:#86efac; border-color:rgba(34,197,94,.40); background:rgba(34,197,94,.10); }\n"
"    .cr-stat-pill.warn   { color:#fde68a; border-color:rgba(245,158,11,.40); background:rgba(245,158,11,.10); }\n"
"\n"
"    /* --- Mod type group headers --- */\n"
"    .cr-mod-group { display:grid; gap:6px; }\n"
"    .cr-mod-groups { display:grid; gap:12px; }\n"
"    .cr-mod-group-header {\n"
"      font-family:var(--cr-font-mono); font-size:10px; font-weight:700;\n"
"      letter-spacing:.12em; text-transform:uppercase; color:var(--cr-muted-2);\n"
"      padding:4px 0 4px 0; border-bottom:1px solid var(--cr-line);\n"
"    }\n"
"\n"
"    /* --- Cheat description --- */\n"
"    .cr-cheat-desc {\n"
"      font-size:11px; color:var(--cr-muted); font-family:var(--cr-font-base);\n"
"      line-height:1.4; margin-top:2px;\n"
"      display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;\n"
"    }\n"
"    .cr-cheat-row.is-on .cr-cheat-desc { color:rgba(187,247,208,.60); }\n"
"\n"
"    /* --- Inline reason for error states --- */\n"
"    .cr-cheat-reason {\n"
"      font-size:10px; font-family:var(--cr-font-mono); color:var(--cr-muted);\n"
"      margin-top:2px; line-height:1.35;\n"
"    }\n"
"    .cr-cheat-row.is-error .cr-cheat-reason  { color:#fca5a5; }\n"
"    .cr-cheat-row.is-mixed .cr-cheat-reason  { color:#fde68a; }\n"
"\n"
"    /* --- Setup / health panel --- */\n"
"    .cr-health-items { display:grid; gap:6px; }\n"
"    .cr-health-item {\n"
"      display:flex; align-items:center; gap:8px; font-size:12px;\n"
"      padding:6px 8px; border-radius:var(--cr-radius-sm);\n"
"      background:rgba(0,0,0,.20); border:1px solid var(--cr-line);\n"
"    }\n"
"    .cr-health-dot {\n"
"      width:8px; height:8px; border-radius:999px; flex-shrink:0;\n"
"      background:var(--cr-muted-2);\n"
"    }\n"
"    .cr-health-dot.ok   { background:var(--cr-green); box-shadow:0 0 6px rgba(34,197,94,.5); }\n"
"    .cr-health-dot.warn { background:var(--cr-yellow); }\n"
"    .cr-health-dot.err  { background:var(--cr-red); }\n"
"    .cr-health-label { flex:1; color:var(--cr-muted); }\n"
"    .cr-health-val { font-family:var(--cr-font-mono); font-size:11px; color:var(--cr-white-2); }\n"
"\n"
"    /* --- First-run onboarding panel --- */\n"
"    .cr-onboard {\n"
"      border:1px dashed var(--cr-brand-line); border-radius:var(--cr-radius);\n"
"      background:var(--cr-brand-soft); padding:22px 18px; display:grid; gap:14px;\n"
"    }\n"
"    .cr-onboard-title {\n"
"      font-family:var(--cr-font-display); font-size:1.05rem;\n"
"      font-weight:900; color:var(--cr-white);\n"
"    }\n"
"    .cr-onboard-subtitle { font-size:13px; color:var(--cr-muted); margin-top:-6px; }\n"
"    .cr-onboard-steps { display:grid; gap:8px; }\n"
"    .cr-onboard-step { display:flex; gap:10px; align-items:flex-start; font-size:13px; color:var(--cr-muted); }\n"
"    .cr-onboard-num {\n"
"      width:20px; height:20px; border-radius:999px;\n"
"      background:var(--cr-brand-soft); border:1px solid var(--cr-brand-line);\n"
"      font-size:10px; font-weight:900; font-family:var(--cr-font-mono); color:var(--cr-brand-2);\n"
"      display:flex; align-items:center; justify-content:center; flex-shrink:0;\n"
"    }\n"
"    .cr-onboard-actions { display:flex; gap:8px; flex-wrap:wrap; }\n"
"\n"
"    /* --- Patch entries --- */\n"
"    .cr-patch-info { font-size:12px; color:var(--cr-muted); font-family:var(--cr-font-mono); margin-bottom:8px; line-height:1.5; }\n"
"    .cr-patch-list { display:grid; gap:8px; }\n"
"    .cr-patch-row {\n"
"      display:flex; align-items:flex-start; gap:12px;\n"
"      padding:12px 14px; border-radius:var(--cr-radius-sm);\n"
"      border:1px solid var(--cr-line); border-left:3px solid transparent;\n"
"      background:var(--cr-panel-2);\n"
"      transition:border-color .18s ease, background .18s ease;\n"
"    }\n"
"    .cr-patch-row.ver-match  { border-left-color:var(--cr-green); }\n"
"    .cr-patch-row.ver-miss   { border-left-color:var(--cr-muted-2); opacity:.6; }\n"
"    .cr-patch-row.ver-mask   { border-left-color:var(--cr-brand); }\n"
"    .cr-patch-row.is-applied { background:linear-gradient(90deg,var(--cr-green-soft),rgba(3,7,18,.8)); border-color:var(--cr-green-border); border-left-color:var(--cr-green); }\n"
"    .cr-patch-body { flex:1; min-width:0; }\n"
"    .cr-patch-name { font-family:var(--cr-font-display); font-weight:800; font-size:14px; color:var(--cr-white); }\n"
"    .cr-patch-row.is-applied .cr-patch-name { color:#bbf7d0; }\n"
"    .cr-patch-meta { font-size:11px; color:var(--cr-muted); font-family:var(--cr-font-mono); margin-top:3px; }\n"
"    .cr-patch-note { font-size:11px; color:var(--cr-muted-2); margin-top:4px; font-style:italic; }\n"
"    .cr-patch-ver { display:inline-flex; align-items:center; gap:4px; font-size:10px; font-family:var(--cr-font-mono); font-weight:700; padding:2px 7px; border-radius:4px; margin-top:4px; }\n"
"    .cr-patch-ver.match { background:rgba(34,197,94,.15); color:#86efac; border:1px solid rgba(34,197,94,.35); }\n"
"    .cr-patch-ver.miss  { background:rgba(239,68,68,.10); color:#fca5a5; border:1px solid rgba(239,68,68,.30); }\n"
"    .cr-patch-ver.mask  { background:var(--cr-brand-soft); color:#ffe4e6; border:1px solid var(--cr-brand-line); }\n"
"    .cr-patch-ver.unk   { background:rgba(255,255,255,.04); color:var(--cr-muted); border:1px solid var(--cr-line); }\n"
"    .cr-patch-unsup { font-size:10px; color:var(--cr-yellow); margin-top:4px; }\n"
"    .cr-patch-action { flex-shrink:0; }\n"
"    .cr-patch-applied-chip { display:inline-flex; align-items:center; gap:4px; padding:6px 10px; border-radius:var(--cr-radius-sm); background:rgba(34,197,94,.18); color:#86efac; border:1px solid rgba(34,197,94,.40); font-size:11px; font-weight:700; font-family:var(--cr-font-mono); }\n"
"\n"
"    /* ---- Settings: gear button + top-level overlay ---- */\n"
"    .cr-gear-button { display:inline-flex; align-items:center; gap:8px; min-height:36px; padding:8px 14px; border-radius:9999px; font-size:13px; font-weight:800; letter-spacing:.02em; color:#fff; cursor:pointer; border:1px solid var(--cr-line-strong); background:var(--cr-panel-2); transition:transform .18s ease, border-color .18s ease, filter .18s ease; white-space:nowrap; }\n"
"    .cr-gear-button:hover { transform:translateY(-1px); border-color:var(--cr-brand-line); filter:brightness(1.12); }\n"
"    .cr-gear-button:active { transform:scale(.96); }\n"
"    .cr-settings-overlay { position:fixed; inset:0; z-index:200; background:rgba(0,0,0,.72); backdrop-filter:blur(6px); align-items:center; justify-content:center; padding:14px; }\n"
"    .cr-settings-console { width:min(640px,100%); max-height:88vh; display:flex; flex-direction:column; overflow:hidden; background:var(--cr-panel); border:1px solid var(--cr-line-strong); border-left:4px solid var(--cr-brand); border-radius:var(--cr-radius); box-shadow:0 40px 80px rgba(0,0,0,.85), 0 0 40px var(--cr-brand-glow); animation: crPanelDeploy .24s cubic-bezier(.16,1,.3,1); }\n"
"    .cr-settings-search-wrap { padding:10px 16px 0; }\n"
"    .cr-settings-search-wrap .input { width:100%; }\n"
"    /* presets */\n"
"    .cr-preset-row { display:flex; gap:10px; flex-wrap:wrap; }\n"
"    .cr-preset-card { flex:1 1 150px; text-align:left; cursor:pointer; padding:12px; border-radius:var(--cr-radius-sm); border:1px solid var(--cr-line-strong); background:var(--cr-panel-3); color:var(--cr-white); transition:border-color .15s ease, transform .15s ease, box-shadow .15s ease; }\n"
"    .cr-preset-card:hover { border-color:var(--cr-brand-line); transform:translateY(-1px); box-shadow:0 0 16px var(--cr-brand-glow); }\n"
"    .cr-preset-card:active { transform:scale(.98); }\n"
"    .cr-preset-title { font-weight:800; font-size:13px; margin-bottom:4px; }\n"
"    .cr-preset-desc { font-size:11px; color:var(--cr-muted); line-height:1.4; }\n"
"    /* setting badges */\n"
"    .cr-set-badge { display:inline-block; margin-left:8px; padding:1px 7px; border-radius:9999px; font-size:9px; font-weight:800; letter-spacing:.04em; text-transform:uppercase; vertical-align:middle; }\n"
"    .cr-set-badge.rec { background:var(--cr-green-soft); color:#86efac; border:1px solid var(--cr-green-border); }\n"
"    .cr-set-badge.risk { background:rgba(239,68,68,.14); color:#fca5a5; border:1px solid rgba(239,68,68,.40); }\n"
"    .cr-set-badge.mod { background:var(--cr-brand-soft); color:var(--cr-brand-2); border:1px solid var(--cr-brand-line); }\n"
"    @media (max-width:560px) {\n"
"      .cr-settings-row { flex-direction:column; align-items:stretch; }\n"
"      .cr-settings-ctrl { align-self:flex-start; }\n"
"      .cr-gear-label { display:none; }\n"
"    }\n"
"\n"
"    /* ---- Themes (data-theme on <html>; 'dark' is the :root baseline) ---- */\n"
"    html[data-theme=\"crimson\"] { --cr-brand:#FB1D4A; --cr-brand-2:#FF4D6D; --cr-bg:#0A0304; --cr-bg-2:#120406; --cr-bg-3:#180609; --cr-panel:#140609; --cr-panel-2:#1B080C; --cr-panel-3:#240B10; }\n"
"    html[data-theme=\"midnight\"] { --cr-brand:#3B82F6; --cr-brand-2:#60A5FA; --cr-brand-3:#1E40AF; --cr-brand-soft:rgba(59,130,246,.14); --cr-brand-line:rgba(96,165,250,.48); --cr-brand-glow:rgba(59,130,246,.26); --cr-bg:#04060A; --cr-bg-2:#070A12; --cr-bg-3:#0C111B; --cr-panel:#0A0E16; --cr-panel-2:#10151F; --cr-panel-3:#161D2A; }\n"
"\n"
"    /* ---- Favorites star on game tiles ---- */\n"
"    .cr-game-tile { position: relative; }\n"
"    .cr-fav-btn { position:absolute; top:8px; right:8px; z-index:5; width:30px; height:30px; border-radius:9999px; border:1px solid var(--cr-line-strong); background:rgba(5,5,5,.55); color:var(--cr-muted); font-size:15px; line-height:1; cursor:pointer; display:flex; align-items:center; justify-content:center; transition:transform .15s ease, color .15s ease, border-color .15s ease; }\n"
"    .cr-fav-btn:hover { transform:scale(1.12); color:var(--cr-yellow); border-color:var(--cr-yellow); }\n"
"    .cr-fav-btn.is-fav { color:var(--cr-yellow); border-color:rgba(245,158,11,.5); background:rgba(245,158,11,.14); }\n"
"\n"
"    /* ---- First-run onboarding ---- */\n"
"    .cr-onboard-step { padding:10px 0; border-bottom:1px solid var(--cr-line); }\n"
"    .cr-onboard-step:last-child { border-bottom:none; }\n"
"    .cr-onboard-step-title { font-size:12px; font-weight:800; text-transform:uppercase; letter-spacing:.08em; color:var(--cr-brand-2); margin-bottom:8px; }\n"
"    .cr-onboard-note { font-size:12px; color:var(--cr-muted); line-height:1.5; margin-top:8px; }\n"
"    .cr-onboard-note code { font-family:var(--cr-font-mono); font-size:11px; background:var(--cr-panel-3); padding:1px 5px; border-radius:4px; }\n"
"    .cr-preset-card.cr-preset-selected { border-color:var(--cr-brand); box-shadow:0 0 0 1px var(--cr-brand) inset, 0 0 16px var(--cr-brand-glow); }\n"
"\n"
"    /* ---- Collapsible panel headers ---- */\n"
"    .cr-panel-hdr {\n"
"      display: flex;\n"
"      align-items: center;\n"
"      justify-content: space-between;\n"
"      gap: 8px;\n"
"      margin-bottom: 10px;\n"
"      cursor: pointer;\n"
"      user-select: none;\n"
"      -webkit-user-select: none;\n"
"    }\n"
"    .cr-panel-hdr h3 { margin: 0; flex: 1; }\n"
"    .cr-collapse-btn {\n"
"      width: 26px;\n"
"      height: 26px;\n"
"      border-radius: 999px;\n"
"      border: 1px solid var(--cr-line);\n"
"      background: rgba(255,255,255,.04);\n"
"      color: var(--cr-muted);\n"
"      cursor: pointer;\n"
"      display: flex;\n"
"      align-items: center;\n"
"      justify-content: center;\n"
"      flex-shrink: 0;\n"
"      padding: 0;\n"
"      transition: border-color .18s ease, color .18s ease, background .18s ease;\n"
"    }\n"
"    .cr-collapse-btn:hover { border-color: var(--cr-line-strong); color: var(--cr-white); background: rgba(255,255,255,.08); }\n"
"    .cr-collapse-btn:active { transform: scale(.94); }\n"
"    .cr-chevron {\n"
"      transition: transform .28s cubic-bezier(.4,0,.2,1);\n"
"      flex-shrink: 0;\n"
"    }\n"
"    .cr-collapse-btn.collapsed .cr-chevron { transform: rotate(-90deg); }\n"
"    .cr-panel-body {\n"
"      overflow: hidden;\n"
"      max-height: 800px;\n"
"      opacity: 1;\n"
"      transition: max-height .3s cubic-bezier(.4,0,.2,1), opacity .15s ease;\n"
"    }\n"
"    .cr-panel-body.collapsed {\n"
"      max-height: 0 !important;\n"
"      opacity: 0;\n"
"    }\n"
"    @media (prefers-reduced-motion: reduce) {\n"
"      .cr-chevron, .cr-panel-body, .cr-collapse-btn { transition: none !important; }\n"
"    }\n"
"\n"
"    /* ---- Active cheats pulsing border on game tiles ---- */\n"
"    @keyframes crCheatGlow { 0%, 100% { opacity: .35; } 50% { opacity: 1; } }\n"
"    .cr-game-tile.has-active-cheats {\n"
"      border-left-color: var(--cr-green);\n"
"      box-shadow: 0 0 0 1px rgba(34,197,94,.18), 0 0 14px rgba(34,197,94,.10);\n"
"    }\n"
"    .cr-game-tile.has-active-cheats::after {\n"
"      content: \"\";\n"
"      position: absolute;\n"
"      inset: -1px;\n"
"      border-radius: var(--cr-radius);\n"
"      border: 1px solid rgba(34,197,94,.45);\n"
"      box-shadow: 0 0 28px rgba(34,197,94,.28);\n"
"      animation: crCheatGlow 2.4s ease-in-out infinite;\n"
"      pointer-events: none;\n"
"      will-change: opacity;\n"
"    }\n"
"    @media (prefers-reduced-motion: reduce) {\n"
"      .cr-running-pill-inner, .cr-game-tile.has-active-cheats { transition: none !important; animation: none !important; }\n"
"    }\n"
"    /* ---- PS5 WebKit overrides: strip GPU-expensive effects ---- */\n"
"    .ps5 .cr-command-bg,\n"
"    .ps5 .cr-scan-grid,\n"
"    .ps5 .cr-circuit-lines { display: none; }\n"
"    .ps5 .cr-support-modal-overlay,\n"
"    .ps5 .cr-crop-overlay { backdrop-filter: none !important; background: rgba(0,0,0,.92) !important; }\n"
"    .ps5 .cr-settings-overlay { backdrop-filter: none !important; background: rgba(0,0,0,.92) !important; }\n"
"    .ps5 .cr-game-tile.has-active-cheats::after { animation: none; }\n"
"    .ps5 .cr-pill.cr-live::before { animation: none; }\n"
"    .ps5 .cr-game-tile.cr-tile-enter { animation-delay: 0ms; }\n"
"    .ps5 .cr-game-tile { transition: transform 160ms cubic-bezier(.2,.8,.2,1) !important; background: var(--cr-panel) !important; }\n"
"    .ps5 .cr-game-tile.is-launching { animation: none !important; }\n"
"    .ps5 .cr-skel-tile::after { animation: none !important; }\n"
"    .ps5 .cr-cheat-switch.is-pending .cr-cheat-switch-track::after,\n"
"    .ps5 .cr-cheat-switch.is-applying .cr-cheat-switch-track::after { animation: none !important; }\n"
"    .ps5 .cr-launch-overlay::before { animation: none !important; }\n"
