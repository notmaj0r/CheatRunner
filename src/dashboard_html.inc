"      line-height: 1.15;\n"
"    }\n"
"    .modal-sub { margin-top:6px; color: var(--cr-muted); font-family:var(--cr-font-mono); font-size:.82rem; }\n"
"    .xbtn {\n"
"      width:36px;\n"
"      height:36px;\n"
"      border-radius:999px;\n"
"      border:1px solid var(--cr-line-strong);\n"
