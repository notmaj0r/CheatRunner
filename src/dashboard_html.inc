"<!doctype html>\n"
"<html lang=\"en\">\n"
"<head>\n"
"  <meta charset=\"utf-8\">\n"
"  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1,viewport-fit=cover\">\n"
"  <title>CheatRunner</title>\n"
"  <link rel=\"icon\" type=\"image/png\" href=\"/CheatRunner.png\">\n"
"  <link rel=\"shortcut icon\" type=\"image/png\" href=\"/CheatRunner.png\">\n"
"  <link rel=\"apple-touch-icon\" href=\"/CheatRunner.png\">\n"
"  <link rel=\"manifest\" href=\"/manifest.json\">\n"
"  <meta name=\"theme-color\" content=\"#E11D48\">\n"
"  <style>\n"
"    :root {\n"
"      --cr-bg: #050505;\n"
"      --cr-bg-2: #0A0A0B;\n"
"      --cr-bg-3: #111113;\n"
"      --cr-panel: #0D0D10;\n"
"      --cr-panel-2: #151518;\n"
"      --cr-panel-3: #1C1C21;\n"
"      --cr-line: rgba(255,255,255,0.10);\n"
"      --cr-line-strong: rgba(255,255,255,0.18);\n"
"      --cr-brand: #E11D48;\n"
"      --cr-brand-2: #F43F5E;\n"
"      --cr-brand-3: #991B1B;\n"
"      --cr-brand-soft: rgba(225,29,72,0.14);\n"
"      --cr-brand-line: rgba(244,63,94,0.48);\n"
"      --cr-brand-glow: rgba(225,29,72,0.26);\n"
"      --cr-blue: var(--cr-brand);\n"
"      --cr-blue-2: var(--cr-brand-2);\n"
"      --cr-blue-3: var(--cr-brand-3);\n"
"      --cr-blue-soft: var(--cr-brand-soft);\n"
"      --cr-blue-line: var(--cr-brand-line);\n"
"      --cr-blue-glow: var(--cr-brand-glow);\n"
"      --cr-white: #FAFAFA;\n"
"      --cr-white-2: #E7E7EA;\n"
"      --cr-muted: #A1A1AA;\n"
"      --cr-muted-2: #71717A;\n"
"      --cr-red: #EF4444;\n"
"      --cr-yellow: #F59E0B;\n"
"      --cr-green: #22C55E;\n"
"      --cr-green-dark: #15803D;\n"
"      --cr-green-soft: rgba(34,197,94,0.12);\n"
"      --cr-green-border: rgba(34,197,94,0.48);\n"
"      --cr-state-on: #22C55E;\n"
"      --cr-state-on-2: #15803D;\n"
"      --cr-state-on-glow: rgba(34,197,94,0.32);\n"
"      --cr-state-off: #EF4444;\n"
"      --cr-state-off-2: #991B1B;\n"
"      --cr-state-off-glow: rgba(239,68,68,0.32);\n"
"      --cr-switch-border: rgba(255,255,255,0.14);\n"
"      --cr-radius: 14px;\n"
"      --cr-radius-sm: 8px;\n"
"      --cr-radius-lg: 22px;\n"
"      --cr-font-base: Inter, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif;\n"
"      --cr-font-display: Outfit, Inter, system-ui, sans-serif;\n"
"      --cr-font-mono: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;\n"
"    }\n"
"\n"
"    * { box-sizing: border-box; }\n"
"    html, body { margin:0; padding:0; min-height:100%; }\n"
"    body {\n"
"      font-family: var(--cr-font-base);\n"
"      color: var(--cr-white);\n"
"      background: var(--cr-bg);\n"
"      padding: 18px;\n"
"      overflow-x: hidden;\n"
"    }\n"
"    .cr-command-bg {\n"
"      position: fixed;\n"
"      inset: 0;\n"
"      z-index: -3;\n"
"      background:\n"
"        radial-gradient(900px 480px at 78% -12%, rgba(225,29,72,0.16), transparent 62%),\n"
"        radial-gradient(760px 420px at -12% 108%, rgba(244,63,94,0.09), transparent 58%),\n"
"        linear-gradient(180deg, #050505 0%, #0A0A0B 54%, #050505 100%);\n"
"    }\n"
"    .cr-scan-grid {\n"
"      position: fixed;\n"
"      inset: 0;\n"
"      z-index: -2;\n"
"      pointer-events: none;\n"
"      background-size: 46px 46px;\n"
"      background-image:\n"
"        linear-gradient(rgba(255,255,255,0.035) 1px, transparent 1px),\n"
"        linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);\n"
"      opacity: 0.18;\n"
"      -webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,0.65) 0%, transparent 72%);\n"
"      mask-image: linear-gradient(to bottom, rgba(0,0,0,0.65) 0%, transparent 72%);\n"
"    }\n"
"    .cr-circuit-lines {\n"
"      position: fixed;\n"
"      inset: 0;\n"
"      z-index: -1;\n"
"      pointer-events: none;\n"
"      background:\n"
"        repeating-linear-gradient(135deg, rgba(225,29,72,0.025) 0px, rgba(225,29,72,0.025) 1px, transparent 1px, transparent 72px),\n"
"        repeating-linear-gradient(45deg, rgba(255,255,255,0.018) 0px, rgba(255,255,255,0.018) 1px, transparent 1px, transparent 92px);\n"
"      opacity: 0.75;\n"
"    }\n"
"\n"
"    .cr-app-shell {\n"
"      max-width: 1540px;\n"
"      margin: 0 auto;\n"
"      display: grid;\n"
"      grid-template-columns: minmax(0,1fr) 340px;\n"
"      gap: 14px;\n"
"    }\n"
"\n"
"    .cr-panel {\n"
"      background: linear-gradient(180deg, var(--cr-panel-2), var(--cr-panel));\n"
"      border: 1px solid var(--cr-line);\n"
"      border-top: 1px solid var(--cr-line-strong);\n"
"      border-radius: var(--cr-radius);\n"
"      box-shadow: 0 8px 32px -8px rgba(0,0,0,0.6);\n"
"      position: relative;\n"
"      overflow: hidden;\n"
"    }\n"
"    .cr-panel::before {\n"
"      content: \"\";\n"
"      position: absolute;\n"
"      top: 0; left: 0; right: 0;\n"
"      height: 1px;\n"
"      background: linear-gradient(90deg, transparent, var(--cr-brand-line), transparent);\n"
"      pointer-events: none;\n"
"      z-index: 1;\n"
"    }\n"
"    .cr-panel::after {\n"
"      content: \"\";\n"
"      position: absolute;\n"
"      top: 5px; left: 5px;\n"
"      width: 7px; height: 7px;\n"
"      border-top: 1px solid var(--cr-brand-2);\n"
"      border-left: 1px solid var(--cr-brand-2);\n"
"      opacity: 0.46;\n"
"      pointer-events: none;\n"
"      z-index: 1;\n"
"    }\n"
"\n"
"    .topbar {\n"
"      grid-column: 1 / -1;\n"
"      padding: 14px;\n"
"      display: flex;\n"
"      align-items: center;\n"
"      justify-content: space-between;\n"
"      gap: 10px;\n"
"      flex-wrap: wrap;\n"
"    }\n"
"    .brand {\n"
"      display: flex;\n"
"      align-items: center;\n"
"      gap: 12px;\n"
"    }\n"
"    .cr-brand-icon {\n"
"      width: 38px;\n"
"      height: 38px;\n"
"      border-radius: 10px;\n"
"      object-fit: cover;\n"
"      flex-shrink: 0;\n"
"      border: 1px solid rgba(244,63,94,0.30);\n"
"      box-shadow: 0 0 18px rgba(225,29,72,0.16);\n"
"      background: #050505;\n"
"    }\n"
"    .brand h1 {\n"
"      margin: 0;\n"
"      font-size: clamp(1.5rem, 2.3vw, 2.2rem);\n"
"      line-height: 1;\n"
"      font-family: var(--cr-font-display);\n"
"      letter-spacing: .01em;\n"
"    }\n"
"    .brand .sub {\n"
"      margin-top: 5px;\n"
"      color: var(--cr-muted);\n"
"      font-size: 15px;\n"
"    }\n"
"    .topbar-right {\n"
"      display: flex;\n"
"      align-items: center;\n"
"      gap: 8px;\n"
"      flex-wrap: wrap;\n"
"    }\n"
"    .cr-support-button {\n"
"      display: inline-flex;\n"
"      align-items: center;\n"
"      justify-content: center;\n"
"      gap: 8px;\n"
"      min-height: 36px;\n"
"      padding: 8px 14px;\n"
"      border-radius: 9999px;\n"
"      font-size: 13px;\n"
"      font-weight: 800;\n"
"      letter-spacing: .02em;\n"
"      cursor: pointer;\n"
"      color: #fff;\n"
"      border: 1px solid rgba(239,68,68,.55);\n"
"      background: rgba(127,29,29,.28);\n"
"      box-shadow: 0 0 18px rgba(239,68,68,.18);\n"
"      transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease, filter .18s ease;\n"
"      white-space: nowrap;\n"
"    }\n"
"    .cr-support-button:hover {\n"
"      transform: translateY(-1px);\n"
"      border-color: rgba(239,68,68,.8);\n"
"      box-shadow: 0 0 28px rgba(239,68,68,.35);\n"
"      filter: brightness(1.12);\n"
"    }\n"
"    .cr-support-button:active { transform: scale(.96); }\n"
"    .cr-discord-button {\n"
"      display: inline-flex;\n"
"      align-items: center;\n"
"      justify-content: center;\n"
"      gap: 8px;\n"
"      min-height: 36px;\n"
"      padding: 8px 14px;\n"
"      border-radius: 9999px;\n"
"      font-size: 13px;\n"
"      font-weight: 800;\n"
"      letter-spacing: .02em;\n"
"      text-decoration: none;\n"
"      color: #fff;\n"
"      border: 1px solid rgba(88,101,242,.55);\n"
"      background: rgba(30,33,108,.35);\n"
"      box-shadow: 0 0 18px rgba(88,101,242,.18);\n"
"      transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease, filter .18s ease;\n"
"      white-space: nowrap;\n"
"    }\n"
"    .cr-discord-button:hover {\n"
"      transform: translateY(-1px);\n"
"      border-color: rgba(88,101,242,.8);\n"
"      box-shadow: 0 0 28px rgba(88,101,242,.38);\n"
"      filter: brightness(1.1);\n"
"    }\n"
"    .cr-discord-button:active { transform: scale(.96); }\n"
"    .cr-x-button {\n"
"      display: inline-flex;\n"
"      align-items: center;\n"
"      justify-content: center;\n"
"      gap: 8px;\n"
"      min-height: 36px;\n"
"      padding: 8px 14px;\n"
"      border-radius: 9999px;\n"
"      font-size: 13px;\n"
"      font-weight: 800;\n"
"      letter-spacing: .02em;\n"
"      text-decoration: none;\n"
"      color: #fff;\n"
"      border: 1px solid rgba(255,255,255,.22);\n"
"      background: linear-gradient(180deg, rgba(24,24,27,.96), rgba(0,0,0,.96));\n"
"      box-shadow: 0 0 18px rgba(0,0,0,.34), inset 0 1px 0 rgba(255,255,255,.08);\n"
"      transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease, filter .18s ease, background .18s ease;\n"
"      white-space: nowrap;\n"
"    }\n"
"    .cr-x-button:hover {\n"
"      transform: translateY(-1px);\n"
"      border-color: rgba(255,255,255,.42);\n"
"      box-shadow: 0 0 24px rgba(255,255,255,.10), 0 0 28px rgba(0,0,0,.46), inset 0 1px 0 rgba(255,255,255,.12);\n"
"      filter: brightness(1.12);\n"
"    }\n"
"    .cr-x-button:active { transform: scale(.96); }\n"
"    .cr-x-icon { width: 16px; height: 16px; flex: 0 0 auto; color: #fff; }\n"
"    .cr-x-label { color: #fff; }\n"
"    .cr-support-modal-overlay {\n"
"      position: fixed; inset: 0; z-index: 200;\n"
"      background: rgba(0,0,0,.72); backdrop-filter: blur(6px);\n"
"      display: flex; align-items: center; justify-content: center;\n"
"    }\n"
"    .cr-support-modal {\n"
"      background: var(--cr-panel-2); border: 1px solid var(--cr-line-strong);\n"
"      border-radius: var(--cr-radius); padding: 32px 28px 24px;\n"
"      max-width: 380px; width: 90%; text-align: center;\n"
"      box-shadow: 0 24px 64px -12px rgba(0,0,0,.7);\n"
"    }\n"
"    .cr-support-modal h2 { margin: 0 0 8px; font-size: 20px; }\n"
"    .cr-support-modal p { margin: 0 0 20px; color: var(--cr-muted); font-size: 14px; line-height: 1.55; }\n"
"    .cr-support-modal .kofi-link {\n"
"      display: inline-flex; align-items: center; gap: 8px;\n"
"      padding: 10px 22px; border-radius: 9999px;\n"
"      font-size: 14px; font-weight: 800; text-decoration: none; color: #fff;\n"
"      border: 1px solid rgba(239,68,68,.55); background: rgba(127,29,29,.28);\n"
"      transition: filter .18s ease, transform .18s ease;\n"
"    }\n"
"    .cr-support-modal .kofi-link:hover { filter: brightness(1.15); transform: translateY(-1px); }\n"
"    .cr-support-modal .modal-close-row { margin-top: 18px; }\n"
"\n"
"    .cr-pill, .badge {\n"
"      display: inline-flex;\n"
"      align-items: center;\n"
"      gap: 6px;\n"
"      border-radius: 9999px;\n"
"      padding: 6px 10px;\n"
"      font-size: 11px;\n"
"      font-family: var(--cr-font-mono);\n"
"      font-weight: 800;\n"
"      text-transform: uppercase;\n"
"      letter-spacing: .12em;\n"
"      border: 1px solid var(--cr-line);\n"
"      background: rgba(255,255,255,.04);\n"
"      color: var(--cr-white-2);\n"
"      white-space: nowrap;\n"
"    }\n"
"    .cr-pill.blue, .badge.blue { color: #FFE4E6; border-color: var(--cr-brand-line); background: var(--cr-brand-soft); }\n"
"    .cr-pill.green, .badge.green { color: #BBF7D0; border-color: var(--cr-green-border); background: var(--cr-green-soft); }\n"
"    .cr-pill.red, .badge.red { color: #FCA5A5; border-color: rgba(239,68,68,.45); background: rgba(127,29,29,.18); }\n"
"    .badge.yellow { color: var(--cr-white); border-color: rgba(245,158,11,.40); background: rgba(245,158,11,.10); }\n"
"    .badge.gray { color: var(--cr-muted); border-color: var(--cr-line); background: rgba(255,255,255,.03); }\n"
"\n"
"    .main, .side { display:flex; flex-direction:column; gap:14px; min-width:0; }\n"
"    .card {\n"
"      border: 1px solid var(--cr-line);\n"
"      border-top-color: var(--cr-line-strong);\n"
"      background: linear-gradient(180deg, var(--cr-panel-2), var(--cr-panel));\n"
"      border-radius: var(--cr-radius);\n"
"      box-shadow: 0 8px 32px -8px rgba(0,0,0,.5);\n"
"      overflow: hidden;\n"
"    }\n"
"    .small {\n"
"      border-radius: var(--cr-radius);\n"
"      padding: 12px;\n"
"    }\n"
"    .small h3 {\n"
"      margin:0 0 10px;\n"
"      font-size: 13px;\n"
"      letter-spacing: .1em;\n"
"      text-transform: uppercase;\n"
"      color: var(--cr-muted);\n"
"      font-family: var(--cr-font-mono);\n"
"    }\n"
"\n"
"\n"
"    .toolbar {\n"
"      display:grid;\n"
"      grid-template-columns: minmax(0,1fr) auto auto auto;\n"
"      gap:10px;\n"
"      padding:12px;\n"
"    }\n"
"    .input, .select {\n"
"      border: 1px solid var(--cr-line);\n"
"      background: rgba(0,0,0,.40);\n"
"      color: var(--cr-white);\n"
"      border-radius: var(--cr-radius-sm);\n"
"      padding: 10px 12px;\n"
"      font-size: .94rem;\n"
"      font-family: var(--cr-font-mono);\n"
"      width:100%;\n"
"      min-width:0;\n"
"    }\n"
"    .input:focus, .select:focus {\n"
"      outline: none;\n"
"      border-color: var(--cr-brand);\n"
"      box-shadow: 0 0 0 1px var(--cr-brand-soft);\n"
"    }\n"
"    .tabs { display:flex; gap:8px; }\n"
"    .tab {\n"
"      border:1px solid var(--cr-line);\n"
"      background: rgba(255,255,255,.03);\n"
"      color: var(--cr-muted);\n"
"      border-radius: var(--cr-radius-sm);\n"
"      padding:8px 11px;\n"
"      font-family: var(--cr-font-mono);\n"
"      font-size:12px;\n"
"      letter-spacing:.08em;\n"
"      text-transform:uppercase;\n"
"      font-weight:800;\n"
"      cursor:pointer;\n"
"      transition: all .18s ease;\n"
"    }\n"
"    .tab.active { color: var(--cr-white); border-color: var(--cr-brand-line); background: var(--cr-brand-soft); }\n"
"\n"
"    .games {\n"
"      display:grid;\n"
"      grid-template-columns: repeat(auto-fill, minmax(220px,1fr));\n"
"      gap:12px;\n"
"      padding:12px;\n"
"    }\n"
"    .cr-game-tile {\n"
"      border-radius: var(--cr-radius);\n"
"      border: 1px solid var(--cr-line);\n"
"      border-left: 3px solid transparent;\n"
"      background: linear-gradient(180deg, var(--cr-panel-2), var(--cr-panel));\n"
"      padding: 10px;\n"
"      cursor:pointer;\n"
"      transition: border-color .2s ease, box-shadow .2s ease, border-left-color .2s ease;\n"
"      min-width:0;\n"
"      position: relative;\n"
"    }\n"
"    .cr-game-tile:hover { border-color: var(--cr-line-strong); border-left-color: var(--cr-brand); }\n"
"    .cr-game-tile.active { border-left-color: var(--cr-brand-2); border-color: var(--cr-brand-line); box-shadow: 0 0 0 1px rgba(225,29,72,.12); }\n"
"    .cr-game-tile.running { border-left-color: var(--cr-brand-2); border-color: var(--cr-brand-line); box-shadow: 0 0 0 1px rgba(225,29,72,.12), 0 0 22px rgba(225,29,72,.14); }\n"
"    .cr-game-tile.is-launching { border-left-color: var(--cr-brand); border-color: var(--cr-brand-line); animation: crCardPulse 1.1s ease-in-out infinite; overflow: hidden; }\n"
"    .cr-launch-overlay { position: absolute; inset: 0; overflow: hidden; border-radius: var(--cr-radius); background: rgba(5,5,5,.76); z-index: 4; display: flex; align-items: center; justify-content: center; font-family: var(--cr-font-mono); font-size: 11px; font-weight: 900; letter-spacing: .12em; text-transform: uppercase; color: #FFE4E6; }\n"
"    .cr-launch-overlay::before { content: \"\"; position: absolute; left: 0; right: 0; height: 2px; top: 0; background: linear-gradient(90deg, transparent, rgba(244,63,94,.86), transparent); animation: crVertScan .85s linear infinite; pointer-events: none; }\n"
"    .game-cover {\n"
"      width:100%;\n"
"      aspect-ratio:1/1;\n"
"      object-fit:cover;\n"
"      border-radius: var(--cr-radius-sm);\n"
"      background: var(--cr-bg-3);\n"
"      border:1px solid var(--cr-line);\n"
"    }\n"
"    .game-name {\n"
"      margin-top:8px;\n"
"      font-weight:800;\n"
"      font-family:var(--cr-font-display);\n"
"      font-size: 1rem;\n"
"      line-height:1.2;\n"
"      min-height:2.4em;\n"
"      color: var(--cr-white);\n"
"    }\n"
"    .game-sub {\n"
"      margin-top:4px;\n"
"      color: var(--cr-muted);\n"
"      font-size:.78rem;\n"
"      display:flex;\n"
"      justify-content:space-between;\n"
"      gap:8px;\n"
"      flex-wrap:wrap;\n"
"      font-family: var(--cr-font-mono);\n"
"    }\n"
"    .game-badges { margin-top:8px; display:flex; gap:6px; flex-wrap:wrap; }\n"
"    .running-dot {\n"
"      width:8px;\n"
"      height:8px;\n"
"      border-radius:999px;\n"
"      background: var(--cr-brand-2);\n"
"      display:inline-block;\n"
"      animation: crStatusTick 2s infinite;\n"
"    }\n"
"\n"
"    .row { display:flex; gap:8px; flex-wrap:wrap; }\n"
"    .cr-btn, .btn {\n"
"      display:inline-flex;\n"
"      align-items:center;\n"
"      justify-content:center;\n"
"      gap:8px;\n"
"      border-radius: var(--cr-radius-sm);\n"
"      padding: 10px 14px;\n"
"      font-size: 13px;\n"
"      font-weight:800;\n"
"      font-family: var(--cr-font-mono);\n"
"      letter-spacing: .04em;\n"
"      text-transform: uppercase;\n"
"      transition: border-color .18s ease, box-shadow .18s ease;\n"
"      border:1px solid var(--cr-line);\n"
"      background: rgba(255,255,255,.04);\n"
"      color: var(--cr-white-2);\n"
"      cursor:pointer;\n"
"      white-space: nowrap;\n"
"      position: relative;\n"
"      overflow: hidden;\n"
"    }\n"
"    .cr-btn::before, .btn::before {\n"
"      content: \"\";\n"
"      position: absolute;\n"
"      inset: 0;\n"
"      background: linear-gradient(135deg, rgba(244,63,94,.08), rgba(255,255,255,.04));\n"
"      opacity: 0;\n"
"      transition: opacity .18s ease;\n"
"      pointer-events: none;\n"
"    }\n"
"    .cr-btn:hover::before, .btn:hover::before { opacity: 1; }\n"
"    .cr-btn:hover, .btn:hover { border-color: var(--cr-line-strong); }\n"
"    .btn:active { transform: scale(.96); }\n"
"    .btn.secondary { border-color: var(--cr-line); background: rgba(255,255,255,.03); color: var(--cr-white); }\n"
"    .btn.primary, .btn[data-launch] {\n"
"      background: linear-gradient(135deg, var(--cr-brand-2), var(--cr-brand-3));\n"
"      border-color: var(--cr-brand-line);\n"
"      color:white;\n"
"      box-shadow: 0 0 18px var(--cr-brand-glow);\n"
"    }\n"
"    .btn.danger { background: rgba(239,68,68,.10); border-color: rgba(239,68,68,.30); color: #FCA5A5; }\n"
"    .btn.compact { padding: 7px 10px; font-size: 11px; border-radius: var(--cr-radius-sm); }\n"
"\n"
