"          <div class=\"row\" style=\"margin-top:12px;\">\n"
"            <label style=\"align-self:center;margin-right:6px;\">Source:</label>\n"
"            <select id=\"repoSource\" class=\"input\" style=\"flex:0 0 auto;width:auto;\">\n"
"              <option value=\"hencollection\">HEN Cheats Collection</option>\n"
"              <option value=\"ps5cheats\">PS5 Cheats</option>\n"
"              <option value=\"goldhen\">GoldHEN Cheats</option>\n"
"              <option value=\"henppsa\">HEN PPSA Cheats</option>\n"
