"      animation: crModalScan .55s cubic-bezier(.16,1,.3,1) 1 forwards;\n"
"      z-index: 10;\n"
"    }\n"
"    .modal-header {\n"
"      display:flex;\n"
"      justify-content:space-between;\n"
"      align-items:flex-start;\n"
"      gap:10px;\n"
"      padding:16px;\n"
"      border-bottom: 1px solid var(--cr-line);\n"
"    }\n"
"    .modal-title {\n"
"      margin:0;\n"
"      font-size: clamp(1.2rem,2.3vw,1.7rem);\n"
