"            <div id=\"repoStatusLine\" style=\"margin-top:6px;font-size:13px;opacity:.85;\"></div>\n"
"            <div id=\"repoCurrentFile\" style=\"margin-top:2px;font-size:12px;opacity:.6;word-break:break-all;\"></div>\n"
