"<!doctype html>\n"
"<html lang=\"en\">\n"
"<head>\n"
"  <meta charset=\"utf-8\">\n"
"  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1,viewport-fit=cover\">\n"
"  <title>CheatRunner</title>\n"
"  <link rel=\"icon\" type=\"image/png\" href=\"/CheatRunner.png\">\n"
"  <link rel=\"shortcut icon\" type=\"image/png\" href=\"/CheatRunner.png\">\n"
"  <link rel=\"apple-touch-icon\" href=\"/CheatRunner.png\">\n"
"  <link rel=\"manifest\" href=\"/manifest.json\">\n"
"  <meta name=\"theme-color\" content=\"#E11D48\">\n"
"  <link rel=\"stylesheet\" href=\"/dashboard.css\">\n"
"</head>\n"
"<body>\n"
"  <div class=\"cr-command-bg\"></div>\n"
"  <div class=\"cr-scan-grid\"></div>\n"
"  <div class=\"cr-circuit-lines\"></div>\n"
"\n"
"  <main class=\"cr-app-shell\">\n"
"    <header class=\"topbar cr-panel\">\n"
"      <div class=\"brand\">\n"
"        <img class=\"cr-brand-icon\" src=\"/CheatRunner.png\" alt=\"CheatRunner\">\n"
"        <div>\n"
"          <h1>CheatRunner</h1>\n"
"          <div class=\"sub\">Web Cheat Trainer by maj0r&JX</div>\n"
"        </div>\n"
"      </div>\n"
"      <div class=\"topbar-right\">\n"
"        <span class=\"cr-pill\" id=\"headVersion\">v0.11</span>\n"
"        <span class=\"cr-pill\" id=\"headRunning\">No game</span>\n"
"        <span class=\"cr-pill\" id=\"headEngine\">Engine ?</span>\n"
"        <a class=\"cr-discord-button\" href=\"https://discord.gg/E4g6fEqp46\" target=\"_blank\" rel=\"noopener noreferrer\" title=\"Join the Discord\" aria-label=\"Join the Discord server\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"currentColor\" aria-hidden=\"true\"><path d=\"M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057c.002.022.015.043.03.056a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z\"/></svg><span class=\"cr-discord-label\">Discord</span></a>\n"
"        <a class=\"cr-x-button\" href=\"https://x.com/callmemaj0r\" target=\"_blank\" rel=\"noopener noreferrer\" title=\"Follow maj0r on X\" aria-label=\"Follow maj0r on X\"><svg class=\"cr-x-icon\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"currentColor\" aria-hidden=\"true\"><path d=\"M18.244 2H21.5l-7.11 8.13L22.75 22h-6.55l-5.13-6.7L5.2 22H1.94l7.6-8.69L1.5 2h6.72l4.64 6.14L18.244 2Zm-1.14 17.91h1.8L7.24 3.99H5.31l11.793 15.92Z\"/></svg><span class=\"cr-x-label\">X</span></a>\n"
"        <button class=\"cr-support-button\" id=\"supportBtn\" title=\"Support this project\" aria-label=\"Support this project\"><span aria-hidden=\"true\">&#9829;</span><span class=\"cr-support-label\">Support this project</span></button>\n"
"      </div>\n"
"    </header>\n"
"\n"
"    <section class=\"main\">\n"
"      <div class=\"card toolbar\">\n"
"        <input class=\"input\" id=\"searchInput\" placeholder=\"Search games by name/title ID\">\n"
"        <div class=\"tabs\" id=\"platformTabs\">\n"
"          <button class=\"tab active\" data-filter=\"ALL\">All</button>\n"
"          <button class=\"tab\" data-filter=\"PS5\">PS5</button>\n"
"          <button class=\"tab\" data-filter=\"PS4\">PS4</button>\n"
"          <button class=\"tab\" data-filter=\"APP\">Apps</button>\n"
"        </div>\n"
"        <select class=\"select\" id=\"sortSelect\">\n"
"          <option value=\"name_asc\">Name (A-Z)</option>\n"
"          <option value=\"name_desc\">Name (Z-A)</option>\n"
"          <option value=\"id_asc\">Title ID</option>\n"
"        </select>\n"
"        <button class=\"btn secondary\" id=\"refreshGamesBtn\">Refresh</button>\n"
"      </div>\n"
"\n"
"      <div class=\"card\">\n"
"        <div class=\"games\" id=\"games\"></div>\n"
"      </div>\n"
"    </section>\n"
"\n"
"    <aside class=\"side\">\n"
"      <div class=\"small cr-panel\">\n"
"        <h3>Live Status</h3>\n"
"        <div class=\"status-grid\">\n"
"          <div class=\"status-item\"><div class=\"status-k\">Current Title</div><div class=\"status-v\" id=\"sTitle\">Loading...</div></div>\n"
"          <div class=\"status-item\"><div class=\"status-k\">Browser URL</div><div class=\"status-v\" id=\"sUrl\">Loading...</div></div>\n"
"          <div class=\"status-item\"><div class=\"status-k\">Cheat Engine</div><div class=\"status-v\" id=\"sEngine\">Loading...</div></div>\n"
"        </div>\n"
"        <div class=\"row\" style=\"margin-top:10px;\">\n"
"          <button class=\"btn\" id=\"refreshStatusBtn\">Refresh Status</button>\n"
"          <button class=\"btn secondary\" id=\"copyUrlBtn\">Copy URL</button>\n"
"        </div>\n"
"      </div>\n"
"\n"
"      <div class=\"small cr-panel\">\n"
"        <div class=\"logs-head\">\n"
"          <h3>Logs</h3>\n"
"          <div class=\"logs-actions\">\n"
"            <button class=\"btn danger compact\" id=\"restartPayloadBtn\" title=\"Shutdown CheatRunner so you can send a new ELF from your PC.\" aria-label=\"Shutdown Payload\" style=\"display:none\">Shutdown Payload</button>\n"
"            <button class=\"btn secondary compact\" id=\"copyLogsBtn\" title=\"Copy all logs\" aria-label=\"Copy all logs\">Copy Logs</button>\n"
"          </div>\n"
"        </div>\n"
"        <div id=\"logsOut\" class=\"cr-logs-console\">No logs.</div>\n"
"        <div id=\"restartPayloadStatus\" class=\"restart-status\"></div>\n"
"      </div>\n"
"    </aside>\n"
"  </main>\n"
"\n"
"  <div class=\"cr-trainer-overlay\" id=\"cheatModal\">\n"
"    <div class=\"cr-trainer-console\">\n"
"      <div class=\"modal-header\">\n"
"        <div>\n"
"          <h3 class=\"modal-title\">CheatRunner Trainer</h3>\n"
"          <div class=\"modal-sub\" id=\"cheatModalSub\">No game selected</div>\n"
"        </div>\n"
"        <button class=\"xbtn\" id=\"cheatModalCloseBtn\" aria-label=\"Close\">X</button>\n"
"      </div>\n"
"      <div class=\"modal-body\" id=\"cheatModalBody\">\n"
"        <div class=\"cr-modal-tabs\">\n"
"          <button class=\"cr-modal-tab active\" id=\"modalTabCheats\" data-modal-tab=\"cheats\">Cheats</button>\n"
"          <button class=\"cr-modal-tab\" id=\"modalTabRepos\" data-modal-tab=\"repos\">Repositories</button>\n"
"        </div>\n"
"        <div id=\"cheatPanel\" class=\"cr-modal-panel\">\n"
"          <div class=\"cheat-info\" id=\"cheatMeta\">No cheat loaded.</div>\n"
"          <div id=\"cheatCandidates\" style=\"display:none;\"></div>\n"
"          <div class=\"row\">\n"
"            <input id=\"titleId\" class=\"input\" placeholder=\"Title ID (PPSA12345 / CUSA00004)\">\n"
"            <button class=\"btn\" id=\"findBtn\">Find</button>\n"
"            <button class=\"btn\" id=\"loadBtn\">Load</button>\n"
"            <button class=\"btn danger\" id=\"deleteBtn\">Delete Local</button>\n"
"          </div>\n"
"          <div id=\"cheatMods\"></div>\n"
"          <div id=\"cheatEmpty\" class=\"cheat-empty\" style=\"display:none;\">No local cheat file found. Place .mc4, .shn, or .json files in /data/cheatrunner/cheats or download available cheats.</div>\n"
"          <div class=\"row\" id=\"cheatEmptyActions\" style=\"display:none;\">\n"
"            <button class=\"btn\" id=\"downloadCheatsBtn\">Download Cheats</button>\n"
"            <button class=\"btn secondary\" id=\"copyCheatPathBtn\">Copy Cheats Path</button>\n"
"          </div>\n"
"          <div id=\"cheatRemoteCandidates\"></div>\n"
"          <div id=\"cheatDropzone\" class=\"cr-cheat-dropzone\">Drop .mc4 / .shn / .json cheat file here &mdash; or click to browse</div>\n"
"        </div>\n"
"        <div id=\"repoPanel\" class=\"cr-modal-panel\" style=\"display:none;\">\n"
"          <div class=\"cheat-info\">Download cheat files from a community repository into /data/cheatrunner/cheats/.</div>\n"
"          <div class=\"row\" style=\"margin-top:12px;\">\n"
"            <label style=\"align-self:center;margin-right:6px;\">Source:</label>\n"
"            <select id=\"repoSource\" class=\"input\" style=\"flex:0 0 auto;width:auto;\">\n"
"              <option value=\"hencollection\">HEN Cheats Collection</option>\n"
"              <option value=\"ps5cheats\">PS5 Cheats</option>\n"
"              <option value=\"goldhen\">GoldHEN Cheats</option>\n"
"              <option value=\"PPSAonly\">PPSA-Only RDX-Cheats</option>\n"
"            </select>\n"
"            <label style=\"align-self:center;margin:0 6px;\">\n"
"              <input type=\"checkbox\" id=\"repoOverwrite\"> Overwrite existing\n"
"            </label>\n"
"            <button class=\"btn\" id=\"repoDownloadBtn\">Download Selected Source</button>\n"
"            <button class=\"btn secondary\" id=\"repoDownloadAllBtn\">Download All Sources</button>\n"
"          </div>\n"
"          <div id=\"repoProgress\" style=\"display:none;margin-top:12px;\">\n"
"            <div style=\"background:var(--bg3,#333);border-radius:4px;height:8px;overflow:hidden;\">\n"
"              <div id=\"repoProgressBar\" style=\"height:100%;background:var(--accent,#4a9eff);width:0%;transition:width .3s;\"></div>\n"
"            </div>\n"
"            <div id=\"repoStatusLine\" style=\"margin-top:6px;font-size:13px;opacity:.85;\"></div>\n"
"            <div id=\"repoCurrentFile\" style=\"margin-top:2px;font-size:12px;opacity:.6;word-break:break-all;\"></div>\n"
"          </div>\n"
"          <div id=\"repoResult\" style=\"margin-top:10px;font-size:13px;\"></div>\n"
"          <div class=\"cr-panel-note\">Downloads happen in the background. Files are saved per-format to cheats/json, cheats/shn, cheats/mc4. The page remains responsive during download.</div>\n"
"        </div>\n"
"      </div>\n"
"      <div class=\"modal-footer\">\n"
"        <button class=\"btn\" id=\"reloadStateBtn\">Refresh State</button>\n"
"        <button class=\"btn danger compact\" id=\"clearCrashFlagsBtn\" style=\"display:none\">Clear Crash Flags</button>\n"
"        <button class=\"btn secondary\" id=\"copyCheatDebugBtn\">Copy Cheat Debug</button>\n"
"        <button class=\"btn secondary\" id=\"copyDiagBundleBtn\">Copy Diagnostic Bundle</button>\n"
"        <button class=\"btn secondary\" id=\"modalDoneBtn\">Done</button>\n"
"      </div>\n"
"    </div>\n"
"  </div>\n"
"\n"
"  <div class=\"cr-support-modal-overlay\" id=\"supportModal\" style=\"display:none;\" role=\"dialog\" aria-modal=\"true\" aria-label=\"Support this project\">\n"
"    <div class=\"cr-support-modal\">\n"
"      <h2>&#9829; Support this project</h2>\n"
"      <p>CheatRunner is free and open-source. If this project helps you, you can support its development.</p>\n"
"      <a class=\"kofi-link\" href=\"https://ko-fi.com/maj0r\" target=\"_blank\" rel=\"noopener noreferrer\"><span aria-hidden=\"true\">&#9829;</span> Buy me a Ko-fi</a>\n"
"      <a class=\"kofi-link\" href=\"https://buymeacoffee.com/maj0r\" target=\"_blank\" rel=\"noopener noreferrer\" style=\"margin-top:10px;\"><span aria-hidden=\"true\">&#9749;</span> Buy Me a Coffee</a>\n"
"      <div class=\"modal-close-row\"><button class=\"btn secondary\" id=\"supportModalCloseBtn\">Close</button></div>\n"
"    </div>\n"
"  </div>\n"
"\n"
"  <div id=\"toast\" class=\"toast\"></div>\n"
"\n"
"  <script src=\"/dashboard.js\" defer></script>\n"
"</body>\n"
"</html>\n"


