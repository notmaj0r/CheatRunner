"    const DEFAULT_VERSION = '0.1';\n"
"    function normalizeVersion(v) {\n"
"      if (!v || v === 'unknown' || String(v).trim() === '') return DEFAULT_VERSION;\n"
"      v = String(v).trim();\n"
"      return v.startsWith('v') ? v.slice(1) : v;\n"
"    }\n"
"    function formatVersion(v) {\n"
"      return 'v' + normalizeVersion(v);\n"
"    }\n"
"\n"
"    let gamesRaw = [];\n"
"    let gamesView = [];\n"
"    let current = null;\n"
"    let lastRunningTitle = '';\n"
"    let platformFilter = 'ALL';\n"
"    let cheatDoc = null;\n"
"    let cheatTitleId = '';\n"
"    let cheatState = {};\n"
"    let cheatStateRows = [];\n"
"    let cheatDebugData = null;\n"
"    let cheatRemoteCandidates = [];\n"
"    let modalTab = 'cheats';\n"
"    let launchBusy = false;\n"
"    let gamesRefreshInFlight = null;\n"
"    let statusRefreshInFlight = false;\n"
"    let launchStatusRefreshInFlight = false;\n"
"    let globalStateRefreshInFlight = false;\n"
"    let logsRefreshInFlight = false;\n"
"    let launchingId = null;\n"
"    let cheatModalJustOpened = false;\n"
"    const applyingMods = new Set();\n"
"    const LOG_RENDER_LIMIT = 500;\n"
"    let devReloadEnabled = false;\n"
"    let devShutdownDelayMs = 700;\n"
"    let restartWaitTimer = null;\n"
"    const nameOverrides = Object.create(null);\n"
"    const unresolvedLookupQueued = new Set();\n"
"    const unresolvedLookupDone = new Set();\n"
"    const unresolvedLookupQueue = [];\n"
"    let unresolvedLookupBusy = false;\n"
"\n"
"    const sleep = ms => new Promise(r => setTimeout(r, ms));\n"
"    const SWITCH_MIN_MS = 0;\n"
"\n"
"    function escapeHtml(s) {\n"
"      return String(s || '')\n"
"        .replace(/&/g, '&amp;')\n"
"        .replace(/</g, '&lt;')\n"
"        .replace(/>/g, '&gt;')\n"
"        .replace(/\"/g, '&quot;')\n"
"        .replace(/'/g, '&#39;');\n"
"    }\n"
"\n"
"    function normalizeNextOn(v) {\n"
"      if (v === true || v === 1 || v === '1') return 1;\n"
"      if (v === false || v === 0 || v === '0') return 0;\n"
"      return null;\n"
"    }\n"
"\n"
"    function showToast(msg, level) {\n"
"      const t = document.getElementById('toast');\n"
"      const lv = level || 'info';\n"
"      const prefix = lv === 'success' ? '[OK] ' : lv === 'warn' ? '[WARN] ' : lv === 'error' ? '[ERROR] ' : '[INFO] ';\n"
"      t.textContent = prefix + String(msg || '');\n"
"      t.className = 'toast ' + lv;\n"
"      t.classList.add('show');\n"
"      clearTimeout(showToast.t);\n"
"      showToast.t = setTimeout(() => t.classList.remove('show'), 2300);\n"
"    }\n"
"\n"
"    function setRestartPayloadStatus(message, level) {\n"
"      const box = document.getElementById('restartPayloadStatus');\n"
"      if (!box) return;\n"
"      if (!message) {\n"
"        box.textContent = '';\n"
"        box.style.display = 'none';\n"
"        box.className = 'restart-status';\n"
"        return;\n"
"      }\n"
"      box.textContent = String(message);\n"
"      box.className = 'restart-status ' + (level || 'info');\n"
"      box.style.display = 'block';\n"
"    }\n"
"\n"
"    async function waitForCheatRunnerOnline() {\n"
"      if (restartWaitTimer) return;\n"
"      restartWaitTimer = true;\n"
"      setRestartPayloadStatus('CheatRunner is shutting down.\\nSend the new CheatRunner.elf from your PC.\\n\\nWaiting for CheatRunner to come back online...', 'info');\n"
"      for (;;) {\n"
"        await sleep(2000);\n"
"        try {\n"
"          const r = await fetch('/api/state?ts=' + Date.now(), { cache: 'no-store' });\n"
"          if (r && r.ok) {\n"
"            setRestartPayloadStatus('CheatRunner is back online. Reloading page...', 'success');\n"
"            showToast('CheatRunner is back online.', 'success');\n"
"            setTimeout(() => location.reload(), 1000);\n"
"            return;\n"
"          }\n"
"        } catch (_) {}\n"
"      }\n"
"    }\n"
"\n"
"    function cleanTitleId(v) {\n"
"      return (v || '').trim().toUpperCase();\n"
"    }\n"
"\n"
"    function selectedTitleId() {\n"
"      const inputId = cleanTitleId(document.getElementById('titleId').value);\n"
"      if (inputId) return inputId;\n"
"      return current ? gameId(current) : '';\n"
"    }\n"
"\n"
"    const _apiSema = { n: 2, q: [] };\n"
"    function _apiAcquire() {\n"
"      return new Promise(res => {\n"
"        if (_apiSema.n > 0) { _apiSema.n--; res(); }\n"
"        else _apiSema.q.push(res);\n"
"      });\n"
"    }\n"
"    function _apiRelease() {\n"
"      if (_apiSema.q.length) _apiSema.q.shift()();\n"
"      else _apiSema.n++;\n"
"    }\n"
"\n"
"    async function getJson(url, opts) {\n"
"      const ms = typeof opts === 'number' ? opts : (opts && opts.timeoutMs ? opts.timeoutMs : 10000);\n"
"      const maxRetries = (opts && typeof opts.retries === 'number') ? opts.retries : 2;\n"
"      await _apiAcquire();\n"
"      try {\n"
"        for (let attempt = 0; ; attempt++) {\n"
"          if (attempt > 0) await new Promise(r => setTimeout(r, attempt * 500));\n"
"          const ctrl = new AbortController();\n"
"          const to = setTimeout(() => ctrl.abort(), ms);\n"
"          try {\n"
"            const res = await fetch(url, { signal: ctrl.signal, cache: 'no-store' });\n"
"            const txt = await res.text();\n"
"            let js;\n"
"            try { js = JSON.parse(txt); } catch (_) { js = null; }\n"
"            if (!res.ok) {\n"
"              const err = new Error(js && js.error ? js.error : ('HTTP ' + res.status));\n"
"              err.status = res.status;\n"
"              err.body = js;\n"
"              if (res.status === 503 && js && js.error === 'too_many_requests' && attempt < maxRetries) {\n"
"                continue;\n"
"              }\n"
"              throw err;\n"
"            }\n"
"            return js || { ok: res.ok, raw: txt };\n"
"          } finally {\n"
"            clearTimeout(to);\n"
"          }\n"
"        }\n"
"      } finally {\n"
"        _apiRelease();\n"
"      }\n"
"    }\n"
"\n"
"    async function postJson(url, body, opts) {\n"
"      const ms = typeof opts === 'number' ? opts : (opts && opts.timeoutMs ? opts.timeoutMs : 15000);\n"
"      const ctrl = new AbortController();\n"
"      const to = setTimeout(() => ctrl.abort(), ms);\n"
"      try {\n"
"        const res = await fetch(url, {\n"
"          method: 'POST',\n"
"          cache: 'no-store',\n"
"          signal: ctrl.signal,\n"
"          headers: { 'Content-Type': 'application/json' },\n"
"          body: JSON.stringify(body || {})\n"
"        });\n"
"        const txt = await res.text();\n"
"        let js = null;\n"
"        try { js = JSON.parse(txt); } catch (_) {}\n"
"        if (!res.ok) {\n"
"          const err = new Error(js && js.error ? js.error : ('HTTP ' + res.status));\n"
"          err.status = res.status;\n"
"          err.body = js;\n"
"          throw err;\n"
"        }\n"
"        return js || { ok: true, raw: txt };\n"
"      } finally {\n"
"        clearTimeout(to);\n"
"      }\n"
"    }\n"
"\n"
"    let _sourceJobInProgress = false;\n"
"\n"
"    async function pollSourceJob(type, params, progressCb) {\n"
"      _sourceJobInProgress = true;\n"
"      try {\n"
"        const startRes = await postJson('/api/sources/jobs/start', Object.assign({ type }, params), { timeoutMs: 10000 });\n"
"        const jobId = startRes && startRes.jobId;\n"
"        if (!jobId) throw new Error('no_job_id');\n"
"        const maxWait = 90000;\n"
"        const started = Date.now();\n"
"        while (Date.now() - started < maxWait) {\n"
"          await new Promise(r => setTimeout(r, 1000));\n"
"          const st = await getJson('/api/sources/jobs/status?id=' + jobId, { timeoutMs: 10000 });\n"
"          if (progressCb && (st.state === 'pending' || st.state === 'running')) progressCb(st.state);\n"
"          if (st.state === 'done') {\n"
"            if (!st.result) throw new Error('empty_result');\n"
"            return st.result;\n"
"          }\n"
"          if (st.state === 'failed') {\n"
"            const e = new Error(st.error || 'job_failed');\n"
"            e.body = { error: st.error, message: st.message };\n"
"            e.status = st.httpStatus;\n"
"            throw e;\n"
"          }\n"
"        }\n"
"        throw new Error('job_timeout');\n"
"      } finally {\n"
"        _sourceJobInProgress = false;\n"
"      }\n"
"    }\n"
"\n"
"    function gameId(g) {\n"
"      return g.titleId || g.title_id || '';\n"
"    }\n"
"    function looksLikeTitleIdText(s) {\n"
"      const t = String(s || '').trim().toUpperCase();\n"
"      return /^(CUSA|PPSA|NPXS|ULUS|ULES|ULJS|ULKS|SLUS|SCUS|SLES|SCES|SLPS|SLPM|SCED|SLED|SCPS)[-_]?[0-9A-Z]{5}$/.test(t);\n"
"    }\n"
"    function isUnresolvedGameName(titleId, name) {\n"
"      const tid = cleanTitleId(titleId || '');\n"
"      const n = String(name || '').trim();\n"
"      if (!n) return true;\n"
"      if (tid && n.toUpperCase() === tid) return true;\n"
"      if (looksLikeTitleIdText(n)) return true;\n"
"      if (/^unknown(\\s+title)?$/i.test(n)) return true;\n"
"      return false;\n"
"    }\n"
"    function gameName(g) {\n"
"      const id = gameId(g);\n"
"      if (id && nameOverrides[id]) return nameOverrides[id];\n"
"      return g.titleName || g.title_name || g.titleId || g.title_id || 'Unknown';\n"
"    }\n"
"    function isGameTitleId(id) {\n"
"      id = String(id || '').toUpperCase();\n"
"      return /^(PPSA|CUSA|ULUS|ULES|ULJS|ULKS|SLUS|SCUS|SLES|SCES|SLPS|SLPM|SCED|SLED|SCPS)[0-9A-Z]{5}$/.test(id);\n"
"    }\n"
"    function gamePlatform(g) {\n"
"      return g.platform || (gameId(g).startsWith('PPSA') ? 'PS5' : (gameId(g).startsWith('CUSA') ? 'PS4' : 'APP'));\n"
"    }\n"
"    function gameVersion(g) {\n"
"      return g.version && g.version !== 'unknown' ? g.version : 'unknown';\n"
"    }\n"
"    function gameIcon(g) {\n"
"      if (g.iconUrl) return g.iconUrl;\n"
"      return '/appdb/icon?id=' + encodeURIComponent(gameId(g));\n"
"    }\n"
"\n"
"    function getGameVersionByTitleId(titleId) {\n"
"      const tid = cleanTitleId(titleId || '');\n"
"      if (!tid) return '';\n"
"      const g = gamesRaw.find(x => gameId(x) === tid);\n"
"      if (!g) return '';\n"
"      const v = gameVersion(g);\n"
"      return v === 'unknown' ? '' : v;\n"
"    }\n"
"\n"
"    async function pumpUnresolvedTitleLookupQueue() {\n"
"      if (unresolvedLookupBusy) return;\n"
"      unresolvedLookupBusy = true;\n"
"      while (unresolvedLookupQueue.length) {\n"
"        const tid = unresolvedLookupQueue.shift();\n"
"        if (!tid || unresolvedLookupDone.has(tid)) continue;\n"
"        try {\n"
"          const r = await getJson('/api/titles/lookup?titleId=' + encodeURIComponent(tid), { timeoutMs: 12000 });\n"
"          if (r && r.ok && r.name && !isUnresolvedGameName(tid, r.name)) {\n"
"            nameOverrides[tid] = String(r.name);\n"
"            const g = gamesRaw.find(x => gameId(x) === tid);\n"
"            if (g) g.titleName = String(r.name);\n"
"            applyFilters();\n"
"            renderGames();\n"
"            if (cheatTitleId === tid) renderCheatMenu();\n"
"            if (current && gameId(current) === tid) {\n"
"              const sub = document.getElementById('cheatModalSub');\n"
"              if (sub) sub.textContent = String(r.name) + ' (' + tid + ')';\n"
"            }\n"
"          }\n"
"        } catch (_) {}\n"
"        unresolvedLookupDone.add(tid);\n"
"      }\n"
"      unresolvedLookupBusy = false;\n"
"    }\n"
"\n"
"    function queueUnresolvedTitleLookup(g) {\n"
"      const tid = cleanTitleId(gameId(g));\n"
"      if (!tid || unresolvedLookupDone.has(tid) || unresolvedLookupQueued.has(tid)) return;\n"
"      const nm = gameName(g);\n"
"      if (!isUnresolvedGameName(tid, nm)) return;\n"
"      unresolvedLookupQueued.add(tid);\n"
"      unresolvedLookupQueue.push(tid);\n"
"      pumpUnresolvedTitleLookupQueue();\n"
"    }\n"
"\n"
"    function queueUnresolvedTitleLookups() {\n"
"      gamesRaw.forEach(g => queueUnresolvedTitleLookup(g));\n"
"    }\n"
"\n"
"    function scoreLabel(score) {\n"
"      const s = Number(score || 0);\n"
"      if (s >= 300) return 'Exact Match';\n"
"      if (s >= 220) return 'Compatible Version';\n"
"      return 'Title Match';\n"
"    }\n"
"\n"
"    function toCheatStateMap(mods) {\n"
"      const map = {};\n"
"      (mods || []).forEach(m => {\n"
"        const idx = Number(m.index);\n"
"        if (!Number.isFinite(idx)) return;\n"
"        const state = String(m.state || 'unknown').toLowerCase();\n"
"        map[idx] = {\n"
"          state,\n"
"          label: String(m.label || '').trim(),\n"
"          reason: String(m.reason || '').trim(),\n"
"          visualState: m.visualState != null ? String(m.visualState).toLowerCase() : null,\n"
"          canEnable: m.canEnable != null ? !!m.canEnable : null,\n"
"          canDisable: m.canDisable != null ? !!m.canDisable : null,\n"
"          canToggle: m.canToggle != null ? !!m.canToggle : null,\n"
"          nextAction: m.nextAction != null ? String(m.nextAction) : null,\n"
"          nextOn: m.nextOn != null ? !!m.nextOn : null,\n"
"          blockReason: m.blockReason != null ? String(m.blockReason) : null\n"
"        };\n"
"      });\n"
"      return map;\n"
"    }\n"
"\n"
"    function badgeForGame(g) {\n"
"      if (g.hasCheat) {\n"
"        const fmt = String(g.cheatFormat || '').toUpperCase();\n"
"        return '<span class=\"badge blue\">Cheats</span>' + (fmt ? ('<span class=\"badge\">' + escapeHtml(fmt) + '</span>') : '');\n"
"      }\n"
"      return '<span class=\"badge gray\">No Cheat</span>';\n"
"    }\n"
"\n"
"    function isApp(g) {\n"
"      return g.kind === 'app' || g.isApp === true || gamePlatform(g) === 'APP';\n"
"    }\n"
"\n"
"    function applyFilters() {\n"
"      const q = (document.getElementById('searchInput').value || '').trim().toLowerCase();\n"
"      const sort = document.getElementById('sortSelect').value;\n"
"\n"
"      gamesView = gamesRaw.filter(g => {\n"
"        const app = isApp(g);\n"
"        if (platformFilter === 'APP') { if (!app) return false; }\n"
"        else if (platformFilter === 'ALL') { if (app) return false; }\n"
"        else { if (app || gamePlatform(g) !== platformFilter) return false; }\n"
"        if (!q) return true;\n"
"        return gameName(g).toLowerCase().includes(q) || gameId(g).toLowerCase().includes(q);\n"
"      });\n"
"\n"
"      gamesView.sort((a, b) => {\n"
"        const an = gameName(a).toLowerCase();\n"
"        const bn = gameName(b).toLowerCase();\n"
"        const ai = gameId(a);\n"
"        const bi = gameId(b);\n"
"        if (sort === 'name_desc') return bn.localeCompare(an);\n"
"        if (sort === 'id_asc') return ai.localeCompare(bi);\n"
"        return an.localeCompare(bn);\n"
"      });\n"
"\n"
"      if (!current || !gamesView.find(g => gameId(g) === gameId(current))) {\n"
"        current = gamesView[0] || gamesRaw[0] || null;\n"
"      }\n"
"    }\n"
"\n"
"\n"
"    function renderGames() {\n"
"      const node = document.getElementById('games');\n"
"      if (!gamesView.length) {\n"
"        node.innerHTML = '<div class=\"status-item\" style=\"grid-column:1/-1\">No games match current filters.</div>';\n"
"        return;\n"
"      }\n"
"\n"
"      node.innerHTML = gamesView.map(g => {\n"
"        const id = gameId(g);\n"
"        const active = current && gameId(current) === id;\n"
"        const isLaunching = launchingId === id;\n"
"        const cls = 'game cr-game-tile' + (active ? ' active' : '') + (g.running ? ' running' : '') + (isLaunching ? ' is-launching' : '');\n"
"        const runningBadge = g.running ? '<span class=\"badge blue\"><span class=\"running-dot\"></span>Running</span>' : '';\n"
"        const dis = launchBusy ? ' disabled' : '';\n"
"        const launchOverlay = isLaunching ? '<div class=\"cr-launch-overlay\">LAUNCHING&hellip;</div>' : '';\n"
"\n"
"        return '<article class=\"' + cls + '\" data-id=\"' + id + '\">'\n"
"          + launchOverlay\n"
"          + '<img class=\"game-cover\" src=\"' + gameIcon(g) + '\" alt=\"' + id + '\" onerror=\"this.src=\\'/appdb/icon?id=' + id + '\\'\">'\n"
"          + '<div class=\"game-name\">' + escapeHtml(gameName(g)) + '</div>'\n"
"          + '<div class=\"game-sub\"><span>' + escapeHtml(gamePlatform(g)) + '</span><span>' + escapeHtml(id) + '</span></div>'\n"
"          + '<div class=\"game-badges\">' + badgeForGame(g) + runningBadge + '</div>'\n"
"          + '<div class=\"row\" style=\"margin-top:8px\">'\n"
"          + '<button class=\"btn\" data-launch=\"' + id + '\"' + dis + '>Play</button>'\n"
"          + (!isApp(g) || g.hasCheat ? '<button class=\"btn secondary\" data-cheats=\"' + id + '\">Cheats</button>' : '')\n"
"          + '</div>'\n"
"          + '</article>';\n"
"      }).join('');\n"
"\n"
"      node.querySelectorAll('[data-id]').forEach(el => {\n"
"        el.addEventListener('click', e => {\n"
"          if (e.target.closest('button')) return;\n"
"          const id = el.getAttribute('data-id');\n"
"          const g = gamesRaw.find(x => gameId(x) === id);\n"
"          if (!g) return;\n"
"          current = g;\n"
"          renderGames();\n"
"        });\n"
"      });\n"
"      node.querySelectorAll('[data-launch]').forEach(el => {\n"
"        el.addEventListener('click', e => {\n"
"          e.stopPropagation();\n"
"          launchTitle(el.getAttribute('data-launch'));\n"
"        });\n"
"      });\n"
"      node.querySelectorAll('[data-cheats]').forEach(el => {\n"
"        el.addEventListener('click', async e => {\n"
"          e.stopPropagation();\n"
"          const id = el.getAttribute('data-cheats');\n"
"          const g = gamesRaw.find(x => gameId(x) === id);\n"
"          if (g) current = g;\n"
"          openCheatModal('cheats');\n"
"          await loadCheatMenu(id);\n"
"        });\n"
"      });\n"
"    }\n"
"\n"
"    function stateClass(state) {\n"
"      if (state === 'on') return 'is-on';\n"
"      if (state === 'off' || state === 'off_unverified') return 'is-off';\n"
"      if (state === 'mixed') return 'is-mixed';\n"
"      if (state === 'mismatch') return 'is-error';\n"
"      if (state === 'read_failed') return 'is-error';\n"
"      if (state === 'crash_suspect') return 'is-error';\n"
"      if (state === 'address_unresolved') return 'is-unknown';\n"
"      if (state === 'format_needs_review') return 'is-unknown';\n"
"      if (state === 'baseline_unknown') return 'is-off';\n"
"      return 'is-unknown';\n"
"    }\n"
"\n"
"    function stateBadge(state, label) {\n"
"      if (state === 'on') return '<span class=\"badge blue\">ON</span>';\n"
"      if (state === 'off' || state === 'off_unverified') return '<span class=\"badge gray\">OFF</span>';\n"
"      if (state === 'mixed') return '<span class=\"badge yellow\">PARTIAL</span>';\n"
"      if (state === 'mismatch') return '<span class=\"badge red\">VERSION MISMATCH</span>';\n"
"      if (state === 'crash_suspect') return '<span class=\"badge red\">CRASH SUSPECT</span>';\n"
"      if (state === 'game_not_ready') return '<span class=\"badge yellow\">GAME NOT READY</span>';\n"
"      if (state === 'game_loading') return '<span class=\"badge yellow\">WAITING FOR GAME</span>';\n"
"      if (state === 'process_not_found') return '<span class=\"badge red\">PROCESS NOT FOUND</span>';\n"
"      if (state === 'base_not_ready') return '<span class=\"badge yellow\">BASE NOT READY</span>';\n"
"      if (state === 'read_failed') return '<span class=\"badge red\">READ FAILED</span>';\n"
"      if (state === 'invalid_cheat') return '<span class=\"badge red\">INVALID CHEAT</span>';\n"
"      if (state === 'baseline_unknown') return '<span class=\"badge gray\">OFF</span>';\n"
"      if (state === 'address_unresolved') return '<span class=\"badge yellow\">ADDRESS UNRESOLVED</span>';\n"
"      if (state === 'format_needs_review') return '<span class=\"badge yellow\">FORMAT NEEDS REVIEW</span>';\n"
"      return '<span class=\"badge yellow\">' + escapeHtml(label || 'UNKNOWN') + '</span>';\n"
"    }\n"
"\n"
"    function canToggleState(state) {\n"
"      if (state === 'crash_suspect') return false;\n"
"      if (state === 'off' || state === 'on' || state === 'mixed') return true;\n"
"      if (state === 'baseline_unknown' || state === 'off_unverified' || state === 'on_unverified') return true;\n"
"      return false;\n"
"    }\n"
"\n"
"    function canToggleFromRow(row, st) {\n"
"      if (row && row.canEnable !== null && row.canEnable !== undefined &&\n"
"          row.canDisable !== null && row.canDisable !== undefined) {\n"
"        const isOn = st === 'on' || st === 'on_unverified';\n"
"        return isOn ? (row.canDisable === true) : (row.canEnable === true);\n"
"      }\n"
"      return canToggleState(st);\n"
"    }\n"
"\n"
"    function getCheatVisualState(row) {\n"
"      if (row && row.visualState != null) return String(row.visualState).toLowerCase();\n"
"      const st = String((row && row.state) || 'unknown').toLowerCase();\n"
"      if (st === 'on') return 'on';\n"
"      if (st === 'crash_suspect') return 'error';\n"
"      if (st === 'mixed') return 'mixed';\n"
"      return 'off';\n"
"    }\n"
"\n"
"    function setModalTab(tab) {\n"
"      modalTab = tab === 'repos' ? 'repos' : 'cheats';\n"
"      const cheatsBtn  = document.getElementById('modalTabCheats');\n"
"      const reposBtn   = document.getElementById('modalTabRepos');\n"
"      const cheatPanel = document.getElementById('cheatPanel');\n"
"      const repoPanel  = document.getElementById('repoPanel');\n"
"      const copyCheatBtn = document.getElementById('copyCheatDebugBtn');\n"
"      const clearCrashBtn = document.getElementById('clearCrashFlagsBtn');\n"
"      if (cheatsBtn)  cheatsBtn.classList.toggle('active',  modalTab === 'cheats');\n"
"      if (reposBtn)   reposBtn.classList.toggle('active',   modalTab === 'repos');\n"
"      if (cheatPanel) cheatPanel.style.display = modalTab === 'cheats'  ? '' : 'none';\n"
"      if (repoPanel)  repoPanel.style.display  = modalTab === 'repos'   ? '' : 'none';\n"
"      if (copyCheatBtn) copyCheatBtn.style.display = modalTab === 'cheats' ? 'inline-flex' : 'none';\n"
"      if (clearCrashBtn) {\n"
"        if (modalTab !== 'cheats') {\n"
"          clearCrashBtn.style.display = 'none';\n"
"        } else {\n"
"          const hasCrashSuspect = Object.values(cheatState || {}).some(r => r && r.state === 'crash_suspect');\n"
"          clearCrashBtn.style.display = hasCrashSuspect ? 'inline-flex' : 'none';\n"
"        }\n"
"      }\n"
"    }\n"
"\n"
"    function renderCheatRemoteCandidates(emptyMessage) {\n"
"      const node = document.getElementById('cheatRemoteCandidates');\n"
"      if (!node) return;\n"
"      if (!cheatRemoteCandidates.length) {\n"
"        if (emptyMessage) {\n"
"          node.innerHTML = '<div class=\"cheat-empty\">' + escapeHtml(emptyMessage) + '</div>';\n"
"        } else {\n"
"          node.innerHTML = '';\n"
"        }\n"
"        return;\n"
"      }\n"
"      node.innerHTML = '<div class=\"cr-source-list\">' + cheatRemoteCandidates.map((c, i) => {\n"
"        const sizeTxt = Number(c.size || 0) > 0 ? (' size=' + String(c.size)) : '';\n"
"        return '<div class=\"cr-source-item\">'\n"
"          + '<div class=\"cr-source-main\">'\n"
"          + '<div class=\"cr-source-name\">' + escapeHtml(String(c.filename || '')) + '</div>'\n"
"          + '<div class=\"cr-source-actions\">'\n"
"          + '<span class=\"badge blue\">' + escapeHtml(scoreLabel(c.score)) + '</span>'\n"
"          + '<button class=\"btn\" data-cheat-download=\"' + String(i) + '\">Download</button>'\n"
"          + '</div>'\n"
"          + '</div>'\n"
"          + '<div class=\"cr-source-meta\">format=' + escapeHtml(String(c.format || ''))\n"
"          + ' version=' + escapeHtml(String(c.version || 'unknown'))\n"
"          + ' source=' + escapeHtml(String(c.source || ''))\n"
"          + sizeTxt + '</div>'\n"
"          + '</div>';\n"
"      }).join('') + '</div>';\n"
"      node.querySelectorAll('[data-cheat-download]').forEach(el => {\n"
"        el.addEventListener('click', async () => {\n"
"          const idx = Number(el.getAttribute('data-cheat-download'));\n"
"          if (!Number.isFinite(idx)) return;\n"
"          await downloadCheatCandidate(idx, false);\n"
"        });\n"
"      });\n"
"    }\n"
"\n"
"    function classifyFetchError(e) {\n"
"      if (!e) return { code: 'unknown', message: 'Request failed.' };\n"
"      const backendErr = e.body && e.body.error ? String(e.body.error).toLowerCase() : '';\n"
"      const backendMsg = e.body && e.body.message ? String(e.body.message) : '';\n"
"      const msg = String(e.message || e.name || '').toLowerCase();\n"
"      if (e.name === 'AbortError') {\n"
"        return { code: 'timeout', message: 'Request timed out. Try again.' };\n"
"      }\n"
"      if (msg === 'job_timeout') {\n"
"        return { code: 'timeout', message: 'Remote search timed out. Try again or use local files.' };\n"
"      }\n"
"      if (backendErr === 'source_not_found' || msg.includes('source_not_found')) {\n"
"        return { code: 'source_not_found', message: backendMsg || 'Remote source was not found. Check source configuration or try another source.' };\n"
"      }\n"
"      if (backendErr === 'rate_limited' || msg.includes('rate_limited')) {\n"
"        return { code: 'rate_limited', message: backendMsg || 'GitHub rate limit hit. Try again later or use local files.' };\n"
"      }\n"
"      if (backendErr === 'network_unavailable' || backendErr === 'network_error' ||\n"
"          msg.includes('network_unavailable') || msg.includes('network_error')) {\n"
"        return { code: 'network', message: backendMsg || 'Network unavailable. Check PS5 internet connection or use local files.' };\n"
"      }\n"
"      if (msg.includes('networkerror') || msg.includes('failed to fetch') || msg.includes('network request failed')) {\n"
"        if (_sourceJobInProgress) {\n"
"          return { code: 'busy', message: 'CheatRunner is busy fetching remote sources. Retrying...' };\n"
"        }\n"
"        return { code: 'network', message: backendMsg || 'Network request failed. Check PS5 internet connection or try again.' };\n"
"      }\n"
"      if (backendErr === 'too_many_requests' || e.status === 503) {\n"
"        return { code: 'busy', message: 'CheatRunner is busy. Retrying...' };\n"
"      }\n"
"      return { code: 'unknown', message: backendMsg || String(e.message || 'Request failed.') };\n"
"    }\n"
"\n"
"    function isLocalApiPath(path) {\n"
"      const p = String(path || '');\n"
"      return p.startsWith('/api/games') ||\n"
"             p.startsWith('/api/cheats/list') ||\n"
"             p.startsWith('/api/logs') ||\n"
"             p.startsWith('/api/health');\n"
"    }\n"
"\n"
"    async function searchRemoteCheats() {\n"
"      const tid = cleanTitleId(selectedTitleId());\n"
"      if (!tid) {\n"
"        showToast('Select a game or type title ID first.', 'warn');\n"
"        return;\n"
"      }\n"
"      const ver = getGameVersionByTitleId(tid);\n"
"      const btn = document.getElementById('downloadCheatsBtn');\n"
"      if (btn) { btn.disabled = true; btn.textContent = 'Searching...'; }\n"
"      showToast('[INFO] Searching cheat sources...', 'info');\n"
"      try {\n"
"        const r = await pollSourceJob('cheat_find', { titleId: tid, version: ver || '' });\n"
"        cheatRemoteCandidates = Array.isArray(r.candidates) ? r.candidates : [];\n"
"        if (!cheatRemoteCandidates.length) {\n"
"          renderCheatRemoteCandidates('No cheats found for this game in configured sources.');\n"
"          showToast('No cheats found for this title.', 'warn');\n"
"          return;\n"
"        }\n"
"        renderCheatRemoteCandidates('');\n"
"        showToast('Candidates found: ' + cheatRemoteCandidates.length, 'success');\n"
"      } catch (e) {\n"
"        cheatRemoteCandidates = [];\n"
"        const cls = classifyFetchError(e);\n"
"        renderCheatRemoteCandidates(cls.message);\n"
"        showToast(cls.message, cls.code === 'rate_limited' ? 'error' : 'warn');\n"
"      } finally {\n"
"        if (btn) { btn.disabled = false; btn.textContent = 'Download Cheats'; }\n"
"      }\n"
"    }\n"
"\n"
"    async function downloadCheatCandidate(idx, overwrite) {\n"
"      const c = cheatRemoteCandidates[idx];\n"
"      const tid = cleanTitleId(selectedTitleId());\n"
"      if (!c || !tid) return;\n"
"      const params = {\n"
"        source: c.sourceId || c.source,\n"
"        path: c.path,\n"
"        filename: c.filename,\n"
"        format: c.format,\n"
"        titleId: tid\n"
"      };\n"
"      if (overwrite) params.overwrite = true;\n"
"      try {\n"
"        const r = await pollSourceJob('cheat_download', params);\n"
"        if (!r.ok && r.error === 'file_exists') {\n"
"          if (window.confirm('Replace existing local cheat file?')) {\n"
"            await downloadCheatCandidate(idx, true);\n"
"          }\n"
"          return;\n"
"        }\n"
"        showToast('Cheat downloaded.', 'success');\n"
"        cheatRemoteCandidates = [];\n"
"        renderCheatRemoteCandidates('');\n"
"        await refreshGames(false);\n"
"        await loadCheatMenu(tid);\n"
"      } catch (e) {\n"
"        const cls = classifyFetchError(e);\n"
"        showToast('Cheat download failed: ' + cls.message, cls.code === 'unknown' ? 'error' : 'warn');\n"
"      }\n"
"    }\n"
"\n"
"    function renderCheatMenu() {\n"
"      const meta = document.getElementById('cheatMeta');\n"
"      const modsNode = document.getElementById('cheatMods');\n"
"      const emptyNode = document.getElementById('cheatEmpty');\n"
"      const emptyActions = document.getElementById('cheatEmptyActions');\n"
"\n"
"      if (!cheatDoc || !Array.isArray(cheatDoc.mods)) {\n"
"        meta.textContent = 'No cheat loaded.';\n"
"        modsNode.innerHTML = '';\n"
"        emptyNode.style.display = '';\n"
"        if (emptyActions) emptyActions.style.display = '';\n"
"        const candNodeE = document.getElementById('cheatCandidates');\n"
"        if (candNodeE) candNodeE.style.display = 'none';\n"
"        return;\n"
"      }\n"
"\n"
"      const name = cheatDoc.name || gameName(current || {}) || cheatTitleId;\n"
"      const cid = cheatDoc.id || cheatTitleId;\n"
"      const proc = cheatDoc.process || 'eboot.bin';\n"
"      const total = cheatDoc.mods.length;\n"
"      const game = cheatDebugData && cheatDebugData.game ? cheatDebugData.game : {};\n"
"      const gameCv = String(game.contentVersion || '');\n"
"      const gameAv = String(game.appVersion || '');\n"
"      const gamePid = Number(game.pid || -1);\n"
"      const gameBase = String(game.base || '0x0');\n"
"      const loadedPath = String((cheatDebugData && cheatDebugData.cheatPath) || '');\n"
"      const loadedFmt = String((cheatDebugData && cheatDebugData.cheatFormat) || '').toUpperCase();\n"
"      const cheatFname = loadedPath.split('/').pop() || '';\n"
"      /* Use server-provided version fields when available (server normalizes correctly) */\n"
"      const srvCheatVer = cheatDebugData && cheatDebugData.selectedCheatVersion && cheatDebugData.selectedCheatVersion !== 'unknown' ? cheatDebugData.selectedCheatVersion : null;\n"
"      const srvGameVer  = cheatDebugData && cheatDebugData.detectedVersion && cheatDebugData.detectedVersion !== 'unknown' ? cheatDebugData.detectedVersion : null;\n"
"      const srvVerMatch = cheatDebugData && cheatDebugData.versionMatch != null ? cheatDebugData.versionMatch : null;\n"
"      const cheatVerMatch = cheatFname.match(/_([\\d][\\d.]*?)(?:\\.[^.]+)$/);\n"
"      const cheatVer = srvCheatVer || (cheatVerMatch && cheatVerMatch[1]) || cheatDoc.version || 'unknown';\n"
"      const gameVer = srvGameVer || gameCv || gameAv || 'unknown';\n"
"      const verKnown = cheatVer !== 'unknown' && gameVer !== 'unknown';\n"
"      const verMatch = srvVerMatch != null ? srvVerMatch : (verKnown && cheatVer === gameVer);\n"
"      const verMismatch = verKnown && !verMatch;\n"
"      const verStatus = verKnown ? (verMismatch ? ' \\u26A0 MISMATCH' : ' \\u2714 match') : '';\n"
"\n"
"      meta.textContent = name + ' | ' + cid\n"
"        + ' | cheatVer: ' + cheatVer + verStatus\n"
"        + ' | gameVer: ' + gameVer\n"
"        + ' | format: ' + (loadedFmt || 'unknown')\n"
"        + ' | process: ' + proc\n"
"        + ' | pid: ' + (gamePid > 0 ? String(gamePid) : 'n/a')\n"
"        + ' | base: ' + gameBase\n"
"        + ' | mods: ' + total;\n"
"      document.getElementById('cheatModalSub').textContent = name + ' (' + cid + ')';\n"
"\n"
"      if (!total) {\n"
"        modsNode.innerHTML = '';\n"
"        emptyNode.style.display = '';\n"
"        if (emptyActions) emptyActions.style.display = '';\n"
"        return;\n"
"      }\n"
"\n"
"      emptyNode.style.display = 'none';\n"
"      if (emptyActions) emptyActions.style.display = 'none';\n"
"\n"
"      const hasCrashSuspect = Object.values(cheatState).some(r => r.state === 'crash_suspect');\n"
"      const crashFlagsBtn = document.getElementById('clearCrashFlagsBtn');\n"
"      if (crashFlagsBtn) crashFlagsBtn.style.display = (modalTab === 'cheats' && hasCrashSuspect) ? 'inline-flex' : 'none';\n"
"\n"
"      const doReveal = cheatModalJustOpened;\n"
"      cheatModalJustOpened = false;\n"
"\n"
"      modsNode.innerHTML = cheatDoc.mods.map((m, i) => {\n"
"        const row = cheatState[i] || { state: 'unknown', label: 'UNKNOWN', reason: '' };\n"
"        const st = String(row.state || 'unknown').toLowerCase();\n"
"        const vs = getCheatVisualState(row);\n"
"        const isApplying = applyingMods.has(i);\n"
"        const cls = stateClass(st) + (isApplying ? ' is-applying' : '');\n"
"        const title = escapeHtml((m && m.name) ? m.name : ('Mod #' + i));\n"
"        const canToggle = canToggleFromRow(row, st);\n"
"        const nextOn = normalizeNextOn(row.nextOn);\n"
"        const dataNext = nextOn !== null ? String(nextOn) : '';\n"
"        const swCls = (vs === 'on' ? 'is-on' : vs === 'mixed' ? 'is-mixed' : vs === 'error' ? 'is-error' : 'is-off') + (isApplying ? ' is-applying' : '');\n"
"        const swDisabled = (!isApplying && !canToggle) ? ' disabled' : '';\n"
"        const swTitle = (!isApplying && !canToggle && row.blockReason) ? ' title=\"' + escapeHtml(row.blockReason) + '\"' : '';\n"
"        const isOnSt = st === 'on' || st === 'on_unverified';\n"
"        const ariaPressed = isOnSt ? 'true' : 'false';\n"
"\n"
"        return '<div class=\"cr-cheat-row ' + cls + '\">'\n"
"          + '<div class=\"cr-cheat-main\">'\n"
"          + '<div class=\"cr-cheat-name\">' + title + '</div>'\n"
"          + (st === 'crash_suspect' ? '<div class=\"cr-cheat-status-chip cr-chip-error\">CRASH SUSPECT</div>' : '')\n"
"          + (st === 'mixed' ? '<div class=\"cr-cheat-status-chip cr-chip-mixed\">PARTIAL PATCH</div>' : '')\n"
"          + '</div>'\n"
"          + '<button class=\"cr-cheat-switch ' + swCls + '\"' + swDisabled + swTitle + ' data-toggle=\"' + i + '\" data-next=\"' + dataNext + '\" data-disabled=\"' + (canToggle ? '0' : '1') + '\" aria-pressed=\"' + ariaPressed + '\" aria-label=\"Toggle ' + title + '\">'\n"
"          + '<span class=\"cr-cheat-switch-track\">'\n"
"          + '<span class=\"cr-cheat-switch-fill\"></span>'\n"
"          + '<span class=\"cr-cheat-switch-label cr-cheat-switch-label-off\">OFF</span>'\n"
"          + '<span class=\"cr-cheat-switch-label cr-cheat-switch-label-on\">ON</span>'\n"
"          + '</span>'\n"
"          + '</button>'\n"
"          + '</div>';\n"
"      }).join('');\n"
"\n"
"      if (doReveal) {\n"
"        modsNode.classList.add('cr-mods-appear');\n"
"        setTimeout(() => modsNode.classList.remove('cr-mods-appear'), 600);\n"
"      }\n"
"\n"
"      renderCheatCandidates();\n"
"\n"
"      modsNode.querySelectorAll('[data-toggle]').forEach(el => {\n"
"        el.addEventListener('click', async () => {\n"
"          const idx = parseInt(el.getAttribute('data-toggle'), 10);\n"
"          if (!Number.isFinite(idx) || applyingMods.has(idx)) return;\n"
"          if (el.getAttribute('data-disabled') === '1') {\n"
"            showToast('Cheat cannot be enabled in current state.', 'warn');\n"
"            return;\n"
"          }\n"
"          const nextOn = normalizeNextOn(el.getAttribute('data-next'));\n"
"          if (nextOn === null) {\n"
"            const row = cheatState[idx] || {};\n"
"            showToast(row.blockReason || 'Cheat cannot be toggled right now.', 'warn');\n"
"            return;\n"
"          }\n"
"          applyingMods.add(idx);\n"
"          renderCheatMenu();\n"
"          try {\n"
"            await toggleCheatMod(idx, nextOn, { minimumDelay: SWITCH_MIN_MS });\n"
"          } finally {\n"
"            applyingMods.delete(idx);\n"
"            renderCheatMenu();\n"
"          }\n"
"        });\n"
"      });\n"
"    }\n"
"\n"
"    function renderCheatCandidates() {\n"
"      const node = document.getElementById('cheatCandidates');\n"
"      if (!node) return;\n"
"      const cands = cheatDebugData && Array.isArray(cheatDebugData.candidates) ? cheatDebugData.candidates : [];\n"
"      const selMode = cheatDebugData && cheatDebugData.selectionMode ? cheatDebugData.selectionMode : null;\n"
"      const tid = cheatTitleId || selectedTitleId() || '';\n"
"      /* Show only when there are multiple candidates or a manual/wrong-version selection is active */\n"
"      const hasMismatch = cands.some(c => c.match === 'wrong_version');\n"
"      const isManual = selMode === 'manual';\n"
"      if (cands.length < 2 && !hasMismatch && !isManual) { node.style.display = 'none'; return; }\n"
"      node.style.display = '';\n"
"      const matchLabel = { exact: 'EXACT', wrong_version: 'WRONG VER', generic: 'GENERIC', unknown: 'UNKNOWN' };\n"
"      const matchBadgeCls = { exact: 'exact', wrong_version: 'wrong', generic: 'generic', unknown: 'generic' };\n"
"      let html = '<div class=\"cr-cand-list\">';\n"
"      cands.forEach((c, i) => {\n"
"        const fname = (c.filename || c.path || '').split('/').pop() || ('file ' + i);\n"
"        const fmt = String(c.format || '').toUpperCase();\n"
"        const match = c.match || 'unknown';\n"
"        const isWrong = match === 'wrong_version';\n"
"        const isSel = !!c.selected;\n"
"        const rowCls = 'cr-cand-row' + (isSel ? ' is-selected' : '') + (isWrong && !isSel ? ' is-wrong-ver' : '');\n"
"        const selBadge = isSel ? ('<span class=\"cr-cand-badge ' + (isManual ? 'manual' : 'selected') + '\">' + (isManual ? 'MANUAL' : 'SELECTED') + '</span>') : '';\n"
"        const matchBadge = '<span class=\"cr-cand-badge ' + (matchBadgeCls[match] || 'generic') + '\">' + (matchLabel[match] || match.toUpperCase()) + '</span>';\n"
"        const fmtBadge = fmt ? '<span class=\"cr-cand-badge fmt\">' + escapeHtml(fmt) + '</span>' : '';\n"
"        let actionBtn = '';\n"
"        if (!isSel && tid) {\n"
"          const safeP = encodeURIComponent(c.path || '');\n"
"          if (isWrong) {\n"
"            actionBtn = '<button class=\"btn secondary cr-cand-select-btn\" data-cand-path=\"' + escapeHtml(c.path || '') + '\" data-cand-wrong=\"1\">Force&hellip;</button>';\n"
"          } else {\n"
"            actionBtn = '<button class=\"btn secondary cr-cand-select-btn\" data-cand-path=\"' + escapeHtml(c.path || '') + '\" data-cand-wrong=\"0\">Select</button>';\n"
"          }\n"
"        }\n"
"        const cver = c.version && c.version !== 'unknown' ? c.version : null;\n"
"        const metaTxt = [fmt, cver ? 'v' + cver : null].filter(Boolean).join(' · ');\n"
"        html += '<div class=\"' + rowCls + '\">';\n"
"        html += '<div style=\"flex:1;min-width:0;\">';\n"
"        html += '<span class=\"cr-cand-fname\" title=\"' + escapeHtml(c.path || '') + '\">' + escapeHtml(fname) + '</span>';\n"
"        if (metaTxt) html += '<div class=\"cr-cand-meta\">' + escapeHtml(metaTxt) + '</div>';\n"
"        html += '</div>';\n"
"        html += '<div style=\"display:flex;gap:4px;align-items:center;flex-shrink:0;\">';\n"
"        html += fmtBadge + matchBadge + selBadge;\n"
"        html += actionBtn;\n"
"        html += '</div>';\n"
"        html += '</div>';\n"
"      });\n"
"      /* Auto button (shown when manual selection is active) */\n"
"      if (isManual && tid) {\n"
"        html += '<div style=\"margin-top:4px;\">';\n"
"        html += '<button class=\"btn cr-cand-auto-btn\" id=\"candAutoBtn\">Reset to Auto-select</button>';\n"
"        html += '</div>';\n"
"      }\n"
"      html += '</div>';\n"
"      node.innerHTML = html;\n"
"      /* Wire up select buttons */\n"
"      node.querySelectorAll('.cr-cand-select-btn').forEach(btn => {\n"
"        btn.addEventListener('click', async () => {\n"
"          const path = btn.getAttribute('data-cand-path');\n"
"          const isWrong = btn.getAttribute('data-cand-wrong') === '1';\n"
"          if (isWrong) {\n"
"            if (!confirm('This file has a different version than the running game.\\nForce-load it anyway?')) return;\n"
"          }\n"
"          try {\n"
"            btn.disabled = true;\n"
"            const forceParam = isWrong ? '&force=1' : '';\n"
"            await postJson('/api/cheats/select?titleId=' + encodeURIComponent(tid) + '&path=' + encodeURIComponent(path) + forceParam);\n"
"            await reloadCheatMenuForCurrentSelection(tid);\n"
"            showToast('Cheat file selected.', 'success');\n"
"          } catch (e) {\n"
"            showToast('Select failed: ' + (e && e.message ? e.message : String(e)), 'error');\n"
"          } finally { btn.disabled = false; }\n"
"        });\n"
"      });\n"
"      const autoBtn = document.getElementById('candAutoBtn');\n"
"      if (autoBtn) {\n"
"        autoBtn.addEventListener('click', async () => {\n"
"          try {\n"
"            autoBtn.disabled = true;\n"
"            await postJson('/api/cheats/select/auto?titleId=' + encodeURIComponent(tid));\n"
"            await reloadCheatMenuForCurrentSelection(tid);\n"
"            showToast('Auto-select restored.', 'success');\n"
"          } catch (e) {\n"
"            showToast('Reset failed: ' + (e && e.message ? e.message : String(e)), 'error');\n"
"          } finally { autoBtn.disabled = false; }\n"
"        });\n"
"      }\n"
"    }\n"
"\n"
"    function openCheatModal(tab) {\n"
"      document.getElementById('cheatModal').classList.add('show');\n"
"      setModalTab(tab || 'cheats');\n"
"      cheatModalJustOpened = true;\n"
"      const id = selectedTitleId();\n"
"      if (id) document.getElementById('cheatModalSub').textContent = 'Loading ' + id + '...';\n"
"    }\n"
"    function closeCheatModal() {\n"
"      document.getElementById('cheatModal').classList.remove('show');\n"
"    }\n"
"\n"
"    async function refreshCheatState(titleId) {\n"
"      const tid = cleanTitleId(titleId || cheatTitleId || selectedTitleId());\n"
"      if (!tid) return;\n"
"      try {\n"
"        const st = await getJson('/api/cheats/state?titleId=' + encodeURIComponent(tid) + '&debug=1');\n"
"        cheatDebugData = st;\n"
"        cheatStateRows = Array.isArray(st.mods) ? st.mods : [];\n"
"        cheatState = toCheatStateMap(st.mods || []);\n"
"      } catch (_) {}\n"
"    }\n"
"\n"
"    async function reloadCheatMenuForCurrentSelection(titleId) {\n"
"      const tid = cleanTitleId(titleId || cheatTitleId || selectedTitleId());\n"
"      if (!tid) return;\n"
"      try {\n"
"        const doc = await getJson('/api/cheats?titleId=' + encodeURIComponent(tid));\n"
"        cheatDoc = doc;\n"
"        cheatTitleId = tid;\n"
"        cheatState = {};\n"
"        if (doc && Array.isArray(doc.mods)) {\n"
"          doc.mods.forEach((_, i) => { cheatState[i] = { state: 'unknown', label: 'UNKNOWN', reason: '' }; });\n"
"        }\n"
"        await refreshCheatState(tid);\n"
"        renderCheatMenu();\n"
"      } catch (e) {\n"
"        renderCheatMenu();\n"
"      }\n"
"    }\n"
"\n"
"    function buildCheatDebugText() {\n"
"      const d = cheatDebugData || {};\n"
"      const game = d.game || {};\n"
"      const lines = [];\n"
"      lines.push('CheatRunner Debug');\n"
"      lines.push('titleId=' + (d.titleId || cheatTitleId || '')); \n"
"      lines.push('cheatPath=' + (d.cheatPath || ''));\n"
"      lines.push('cheatFormat=' + (d.cheatFormat || ''));\n"
"      lines.push('running=' + String(!!game.running));\n"
"      lines.push('runningTitleId=' + (game.runningTitleId || ''));\n"
"      lines.push('pid=' + String(game.pid || ''));\n"
"      lines.push('base=' + (game.base || ''));\n"
"      lines.push('contentVersion=' + (game.contentVersion || ''));\n"
"      lines.push('appVersion=' + (game.appVersion || ''));\n"
"      lines.push('mods:');\n"
"      (cheatStateRows || []).forEach(m => {\n"
"        lines.push('  [' + m.index + '] ' + (m.name || 'mod') + ' state=' + (m.state || 'unknown') + ' label=' + (m.label || '') + ' reason=' + (m.reason || ''));\n"
"      });\n"
"      const mm = Array.isArray(d.mismatches) ? d.mismatches : [];\n"
"      if (mm.length) {\n"
"        lines.push('mismatches:');\n"
"        mm.forEach(x => {\n"
"          lines.push('  mod=' + (x.mod || '') + ' writeIndex=' + String(x.writeIndex || 0)\n"
"            + ' offset=' + (x.offset || '') + ' addr=' + (x.address || '')\n"
"            + ' expected=' + (x.expected || '') + ' current=' + (x.current || '') + ' on=' + (x.on || ''));\n"
"        });\n"
"      }\n"
"      if (lastLogsText) {\n"
"        lines.push('recent logs:');\n"
"        lines.push(lastLogsText);\n"
"      }\n"
"      return lines.join('\\n');\n"
"    }\n"
"\n"
"    async function loadCheatMenu(titleId) {\n"
"      const tid = cleanTitleId(titleId || selectedTitleId());\n"
"      if (!tid) {\n"
"        showToast('Type a title ID first.', 'warn');\n"
"        return;\n"
"      }\n"
"\n"
"      document.getElementById('titleId').value = tid;\n"
"      document.getElementById('cheatModalSub').textContent = 'Loading cheats for ' + tid + '...';\n"
"\n"
"      try {\n"
"        const doc = await getJson('/api/cheats?titleId=' + encodeURIComponent(tid));\n"
"        cheatDoc = doc;\n"
"        cheatTitleId = tid;\n"
"        cheatRemoteCandidates = [];\n"
"        renderCheatRemoteCandidates('');\n"
"        cheatState = {};\n"
"        cheatDebugData = null;\n"
"        if (doc && Array.isArray(doc.mods)) doc.mods.forEach((_, i) => { cheatState[i] = { state: 'unknown', label: 'UNKNOWN', reason: '' }; });\n"
"        await refreshCheatState(tid);\n"
"        renderCheatMenu();\n"
"        showToast('Cheat menu loaded: ' + tid, 'info');\n"
"      } catch (e) {\n"
"        cheatDoc = null;\n"
"        cheatTitleId = tid;\n"
"        cheatState = {};\n"
"        cheatDebugData = null;\n"
"        renderCheatMenu();\n"
"        const msg = String(e.message || '');\n"
"        if (msg.includes('no cheat file') || msg.includes('no_cheat_file')) {\n"
"          showToast('No local cheat file found.', 'warn');\n"
"          renderCheatRemoteCandidates('No local cheat file found. Click Download Cheats to search sources.');\n"
"          return;\n"
"        }\n"
"        showToast('Load failed: ' + (e.message || tid), 'error');\n"
"      }\n"
"    }\n"
"\n"
"    async function toggleCheatMod(index, on, opts) {\n"
"      const minMs = (opts && opts.minimumDelay) || 0;\n"
"      const t0 = minMs ? Date.now() : 0;\n"
"      if (!cheatDoc || !cheatTitleId) {\n"
"        showToast('Load a cheat menu first.', 'warn');\n"
"        return;\n"
"      }\n"
"      let isErr = false, errMsg = '';\n"
"      try {\n"
"        await getJson('/api/cheats/toggle?titleId=' + encodeURIComponent(cheatTitleId)\n"
"          + '&index=' + encodeURIComponent(String(index))\n"
"          + '&on=' + (on ? '1' : '0'));\n"
"        await refreshCheatState(cheatTitleId);\n"
"      } catch (e) {\n"
"        isErr = true;\n"
"        errMsg = String(e.message || 'Toggle failed');\n"
"        await refreshCheatState(cheatTitleId);\n"
"      }\n"
"      if (minMs) {\n"
"        const elapsed = Date.now() - t0;\n"
"        if (elapsed < minMs) await sleep(minMs - elapsed);\n"
"      }\n"
"      if (!isErr) {\n"
"        showToast(on ? 'Cheat enabled.' : 'Cheat disabled.', 'success');\n"
"      } else {\n"
"        const msg = errMsg.toLowerCase();\n"
"        if (msg.includes('version_mismatch') || msg.includes('mismatch')) {\n"
"          showToast('Version mismatch - cheat does not match current game bytes.', 'error');\n"
"        } else if (msg.includes('crash_suspect')) {\n"
"          showToast('Cannot enable - this cheat crashed the game previously. Click Clear Crash Flags to retry.', 'error');\n"
"        } else if (msg.includes('baseline_unknown')) {\n"
"          showToast('MC4/SHN legacy format — state cannot be verified. Manual apply is allowed when allow_legacy_mc4_without_expected is enabled.', 'warn');\n"
"        } else if (msg.includes('address_unresolved')) {\n"
"          showToast('Address unresolved - use /api/cheats/address-debug or mc4-debug to diagnose.', 'warn');\n"
"        } else if (msg.includes('format_needs_review')) {\n"
"          showToast('Format needs review - cheat file may have parsing issues.', 'warn');\n"
"        } else if (msg.includes('apply_in_progress')) {\n"
"          showToast('Apply in progress — try again in a moment.', 'warn');\n"
"        } else if (msg.includes('game_not_ready') || msg.includes('game loading')) {\n"
"          showToast('Game not ready yet. Wait a few seconds after launch.', 'warn');\n"
"        } else showToast(errMsg, 'error');\n"
"      }\n"
"    }\n"
"\n"
"    async function runCheatAction(kind) {\n"
"      const titleId = selectedTitleId();\n"
"      if ((kind === 'find' || kind === 'load' || kind === 'delete') && !titleId) {\n"
"        showToast('Select a game or type title ID first.', 'warn');\n"
"        return;\n"
"      }\n"
"      document.getElementById('titleId').value = titleId;\n"
"\n"
"      try {\n"
"        if (kind === 'find') {\n"
"          await getJson('/api/cheats/find?titleId=' + encodeURIComponent(titleId));\n"
"          showToast('Cheat lookup done.', 'info');\n"
"        } else if (kind === 'load') {\n"
"          await loadCheatMenu(titleId);\n"
"        } else if (kind === 'delete') {\n"
"          await getJson('/api/cheats/delete?titleId=' + encodeURIComponent(titleId));\n"
"          cheatDoc = null;\n"
"          cheatTitleId = '';\n"
"          cheatState = {};\n"
"          cheatDebugData = null;\n"
"          renderCheatMenu();\n"
"          showToast('Local cheat removed.', 'warn');\n"
"          await refreshGames();\n"
"        } else {\n"
"          const r = await getJson('/api/cheats/list');\n"
"          const total = (r.items || r.cheats || []).length;\n"
"          showToast('Local cheat files: ' + total, 'info');\n"
"        }\n"
"      } catch (e) {\n"
"        showToast('Cheat request failed: ' + (e.message || String(e)), 'error');\n"
"      }\n"
"    }\n"
"\n"
"    async function isPayloadAlive() {\n"
"      try { await getJson('/api/health', { timeoutMs: 3000, retries: 0 }); return true; } catch (_) { return false; }\n"
"    }\n"
"\n"
"    async function launchTitle(id) {\n"
"      if (!id) return;\n"
"      try {\n"
"        launchBusy = true;\n"
"        launchingId = id;\n"
"        renderGames();\n"
"        await refreshLaunchStatus();\n"
"        const r = await getJson('/launch?titleId=' + encodeURIComponent(id));\n"
"        if (r && r.ok) {\n"
"          showToast('Launching ' + id + '...', 'success');\n"
"          const started = Date.now();\n"
"          let statusFails = 0;\n"
"          while (Date.now() - started < 40000) {\n"
"            let ls = null;\n"
"            try {\n"
"              ls = await getJson('/api/launch/status', { timeoutMs: 5000 });\n"
"              statusFails = 0;\n"
"              launchBusy = !!ls.busy;\n"
"              if (ls.busy) {\n"
"                const _lmsg = String(ls.message || ls.phase || 'Launching...');\n"
"                document.getElementById('headRunning').textContent = _lmsg;\n"
"                document.getElementById('headRunning').className = 'cr-pill blue';\n"
"              }\n"
"            } catch (_) {\n"
"              statusFails++;\n"
"              if (statusFails >= 3) {\n"
"                const alive = await isPayloadAlive();\n"
"                if (!alive) { showToast('CheatRunner stopped responding during launch.', 'warn'); break; }\n"
"                statusFails = 0;\n"
"              }\n"
"              await new Promise(r => setTimeout(r, 800));\n"
"              continue;\n"
"            }\n"
"            if (!ls.busy) {\n"
"              if (ls.phase === 'timeout' || ls.stale) {\n"
"                showToast('Launch timed out — check if the game started manually.', 'warn');\n"
"              } else if (String(ls.phase || '') === 'ready' || ls.verified) {\n"
"                showToast(ls.message || 'Game launched.', 'success');\n"
"              } else {\n"
"                showToast('Launch failed: ' + String(ls.message || id), 'error');\n"
"              }\n"
"              break;\n"
"            }\n"
"            await new Promise(r => setTimeout(r, 800));\n"
"          }\n"
"          await refreshStatus();\n"
"          await refreshGlobalState();\n"
"          await refreshGames(true);\n"
"          const cheatModalOpen = document.getElementById('cheatModal')?.classList.contains('show');\n"
"          if (cheatTitleId && cheatModalOpen) await reloadCheatMenuForCurrentSelection(cheatTitleId);\n"
"        } else {\n"
"          showToast('Launch failed: ' + id, 'error');\n"
"        }\n"
"      } catch (e) {\n"
"        const cl = classifyFetchError(e);\n"
"        if (cl.code === 'busy') {\n"
"          showToast('CheatRunner is busy. Game may still be launching.', 'warn');\n"
"        } else if (cl.code === 'network' || cl.code === 'unknown') {\n"
"          const alive = await isPayloadAlive();\n"
"          showToast(alive\n"
"            ? 'Game may be launching -- CheatRunner is still running.'\n"
"            : 'CheatRunner payload is not responding.', alive ? 'info' : 'warn');\n"
"        } else {\n"
"          showToast('Launch failed: ' + cl.message, 'error');\n"
"        }\n"
"      } finally {\n"
"        launchBusy = false;\n"
"        launchingId = null;\n"
"        renderGames();\n"
"        await refreshLaunchStatus();\n"
"      }\n"
"    }\n"
"\n"
"    async function refreshStatus() {\n"
"      if (statusRefreshInFlight) return;\n"
"      statusRefreshInFlight = true;\n"
"      try {\n"
"        const s = await getJson('/api/status');\n"
"        const rawTitle = s.titleId || s.title_id || 'No game running';\n"
"        const title = isGameTitleId(rawTitle) ? rawTitle : 'No game running';\n"
"        const url = s.browserUrl || s.browser_url || (location.origin + '/');\n"
"\n"
"        document.getElementById('sTitle').textContent = title;\n"
"        document.getElementById('sUrl').textContent = url;\n"
"\n"
"        document.getElementById('headRunning').textContent = title === 'No game running' ? 'No game' : title;\n"
"        document.getElementById('headRunning').className = 'cr-pill ' + (title === 'No game running' ? '' : 'blue');\n"
"\n"
"        if (title !== lastRunningTitle) {\n"
"          lastRunningTitle = title;\n"
"          const running = gamesRaw.find(g => gameId(g) === title);\n"
"          gamesRaw.forEach(g => { g.running = !!running && gameId(g) === title; });\n"
"          if (running) current = running;\n"
"          applyFilters();\n"
"          renderGames();\n"
"        }\n"
"      } catch (_) {\n"
"        document.getElementById('sTitle').textContent = 'Status unavailable';\n"
"      } finally {\n"
"        statusRefreshInFlight = false;\n"
"      }\n"
"    }\n"
"\n"
"    async function refreshLaunchStatus() {\n"
"      if (launchStatusRefreshInFlight) return;\n"
"      launchStatusRefreshInFlight = true;\n"
"      try {\n"
"        const ls = await getJson('/api/launch/status');\n"
"        const wasBusy = launchBusy;\n"
"        launchBusy = !!ls.busy;\n"
"        if (wasBusy && !launchBusy && ls.phase === 'timeout') {\n"
"          showToast('Launch timed out — check if the game started.', 'warn');\n"
"        }\n"
"        if (wasBusy !== launchBusy) {\n"
"          renderGames();\n"
"        }\n"
"        if (launchBusy) {\n"
"          const msg = String(ls.message || ls.phase || 'Launching...');\n"
"          document.getElementById('headRunning').textContent = msg;\n"
"          document.getElementById('headRunning').className = 'cr-pill blue';\n"
"        }\n"
"      } catch (_) {}\n"
"      finally { launchStatusRefreshInFlight = false; }\n"
"    }\n"
"\n"
"    async function refreshGlobalState() {\n"
"      if (globalStateRefreshInFlight) return;\n"
"      globalStateRefreshInFlight = true;\n"
"      try {\n"
"        const s = await getJson('/api/state');\n"
"        const enabled = !!(s.cheats && s.cheats.engine);\n"
"        const version = s.version || 'unknown';\n"
"        const dev = s.dev || {};\n"
"        devReloadEnabled = !!dev.reloadEnabled;\n"
"        devShutdownDelayMs = Number(dev.shutdownDelayMs || 700);\n"
"        document.getElementById('sEngine').textContent = enabled ? 'Enabled' : 'Disabled';\n"
"        document.getElementById('headEngine').textContent = enabled ? 'Engine ON' : 'Engine OFF';\n"
"        document.getElementById('headEngine').className = 'cr-pill ' + (enabled ? 'blue' : 'red');\n"
"        document.getElementById('headVersion').textContent = formatVersion(version);\n"
"        const restartBtn = document.getElementById('restartPayloadBtn');\n"
"        if (restartBtn) {\n"
"          restartBtn.style.display = devReloadEnabled ? 'inline-flex' : 'none';\n"
"          restartBtn.disabled = !devReloadEnabled;\n"
"        }\n"
"      } catch (_) {}\n"
"      finally { globalStateRefreshInFlight = false; }\n"
"    }\n"
"\n"
"    async function requestPayloadRestart() {\n"
"      if (!devReloadEnabled) {\n"
"        setRestartPayloadStatus('Dev reload mode is disabled in config.ini.', 'error');\n"
"        showToast('Dev reload mode is disabled in config.ini.', 'error');\n"
"        return;\n"
"      }\n"
"      const ok = window.confirm(\n"
"        'Shutdown Payload will stop the current CheatRunner instance.\\n'\n"
"        + 'You will need to send the new CheatRunner.elf from your PC.\\n'\n"
"        + 'Continue?'\n"
"      );\n"
"      if (!ok) return;\n"
"\n"
"      setRestartPayloadStatus('Sending shutdown request...', 'info');\n"
"      try {\n"
"        const res = await fetch('/api/dev/shutdown', {\n"
"          method: 'POST',\n"
"          cache: 'no-store'\n"
"        });\n"
"        let data = null;\n"
"        try { data = await res.json(); } catch (_) {}\n"
"        if (res.ok && data && data.ok) {\n"
"          showToast('Shutdown request sent.', 'info');\n"
"          setRestartPayloadStatus('CheatRunner is shutting down.\\nSend the new CheatRunner.elf from your PC.\\n\\nWaiting for CheatRunner to come back online...', 'info');\n"
"          waitForCheatRunnerOnline();\n"
"          return;\n"
"        }\n"
"        const err = (data && data.error) ? String(data.error) : ('HTTP ' + res.status);\n"
"        if (err === 'dev_reload_disabled') {\n"
"          setRestartPayloadStatus('Dev reload mode is disabled in config.ini.', 'error');\n"
"          showToast('Dev reload mode is disabled in config.ini.', 'error');\n"
"        } else {\n"
"          setRestartPayloadStatus('Could not contact CheatRunner shutdown endpoint.', 'error');\n"
"          showToast('Could not contact CheatRunner shutdown endpoint.', 'error');\n"
"        }\n"
"      } catch (_) {\n"
"        showToast('CheatRunner may already be shutting down. Waiting for it to come back online...', 'warn');\n"
"        setRestartPayloadStatus('CheatRunner is shutting down.\\nSend the new CheatRunner.elf from your PC.\\n\\nWaiting for CheatRunner to come back online...', 'info');\n"
"        waitForCheatRunnerOnline();\n"
"      }\n"
"    }\n"
"\n"
"    let lastLogsText = '';\n"
"    let logsLastSeq = -1;\n"
"    let logsCache = [];\n"
"    let logsSeenSeq = new Set();\n"
"\n"
"    function formatLogEntry(x) {\n"
"      const level = String(x.level || 'info').toLowerCase();\n"
"      return '[' + level + '] [' + String(x.tag || 'core') + '] ' + String(x.message || '');\n"
"    }\n"
"\n"
"    async function copyToClipboard(text, okMessage) {\n"
"      const value = String(text || '');\n"
"      if (!value.trim()) {\n"
"        showToast('No logs to copy.', 'warn');\n"
"        return false;\n"
"      }\n"
"      try {\n"
"        if (navigator.clipboard && navigator.clipboard.writeText) {\n"
"          await navigator.clipboard.writeText(value);\n"
"          showToast(okMessage || 'Copied.', 'success');\n"
"          return true;\n"
"        }\n"
"      } catch (_) {}\n"
"      try {\n"
"        const ta = document.createElement('textarea');\n"
"        ta.value = value;\n"
"        ta.setAttribute('readonly', 'readonly');\n"
"        ta.style.position = 'fixed';\n"
"        ta.style.left = '-9999px';\n"
"        ta.style.top = '0';\n"
"        document.body.appendChild(ta);\n"
"        ta.focus();\n"
"        ta.select();\n"
"        const ok = document.execCommand('copy');\n"
"        document.body.removeChild(ta);\n"
"        if (ok) {\n"
"          showToast(okMessage || 'Copied.', 'success');\n"
"          return true;\n"
"        }\n"
"      } catch (_) {}\n"
"      showToast('Copy failed. Select the log text manually.', 'error');\n"
"      return false;\n"
"    }\n"
"\n"
"    async function refreshLogs() {\n"
"      if (logsRefreshInFlight) return;\n"
"      logsRefreshInFlight = true;\n"
"      try {\n"
"        const q = (logsLastSeq >= 0)\n"
"          ? ('/api/logs?since=' + encodeURIComponent(String(logsLastSeq)) + '&limit=200')\n"
"          : '/api/logs?limit=200';\n"
"        const d = await getJson(q, { timeoutMs: 8000 });\n"
"        const newLastSeq = typeof d.lastSeq === 'number' ? d.lastSeq : -1;\n"
"        if (newLastSeq >= 0 && logsLastSeq >= 0 && newLastSeq < logsLastSeq) {\n"
"          logsCache = []; logsSeenSeq = new Set(); logsLastSeq = -1;\n"
"        }\n"
"        const chunk = d.logs || [];\n"
"        if (logsLastSeq < 0) {\n"
"          logsCache = chunk.slice();\n"
"          logsSeenSeq = new Set(logsCache.map(x => x.seq).filter(s => typeof s === 'number'));\n"
"        } else if (chunk.length) {\n"
"          const fresh = chunk.filter(x => typeof x.seq !== 'number' || !logsSeenSeq.has(x.seq));\n"
"          fresh.forEach(x => { if (typeof x.seq === 'number') logsSeenSeq.add(x.seq); });\n"
"          logsCache = logsCache.concat(fresh);\n"
"        }\n"
"        if (newLastSeq >= 0) logsLastSeq = newLastSeq;\n"
"        if (logsCache.length > 4000) {\n"
"          logsCache = logsCache.slice(-4000);\n"
"          logsSeenSeq = new Set(logsCache.map(x => x.seq).filter(s => typeof s === 'number'));\n"
"        }\n"
"        lastLogsText = logsCache.map(formatLogEntry).join('\\n');\n"
"        const logs = logsCache.slice(-LOG_RENDER_LIMIT);\n"
"        const note = logsCache.length > LOG_RENDER_LIMIT\n"
"          ? '<div class=\"logs-line info\" style=\"opacity:.55;margin-bottom:4px\">[Showing latest ' + LOG_RENDER_LIMIT + ' / ' + logsCache.length + ' entries - Copy Logs exports all]</div>'\n"
"          : '';\n"
"        const html = logs.map(x => {\n"
"          const level = String(x.level || 'info').toLowerCase();\n"
"          return '<div class=\"logs-line ' + escapeHtml(level) + '\">' + escapeHtml(formatLogEntry(x)) + '</div>';\n"
"        }).join('');\n"
"        document.getElementById('logsOut').innerHTML = note + (html || 'No logs.');\n"
"      } catch (_) {}\n"
"      finally { logsRefreshInFlight = false; }\n"
"    }\n"
"\n"
"    async function refreshGames(force) {\n"
"      if (launchBusy && !force) return;\n"
"      if (gamesRefreshInFlight) return gamesRefreshInFlight;\n"
"      const node = document.getElementById('games');\n"
"      node.innerHTML = '<div class=\"status-item\" style=\"grid-column:1/-1\">Loading games...</div>';\n"
"      gamesRefreshInFlight = (async () => {\n"
"        try {\n"
"          let d = null;\n"
"          for (let i = 0; i < 4; i++) {\n"
"            try {\n"
"              d = await getJson(force ? '/api/games?refresh=1' : '/api/games', { timeoutMs: 15000 });\n"
"              break;\n"
"            } catch (e) {\n"
"              const isNet = e.name === 'AbortError' ||\n"
"                /networkerror|failed to fetch|network request failed/i.test(String(e.message || e.name || ''));\n"
"              if (!isNet || i >= 3) throw e;\n"
"              node.innerHTML = '<div class=\"status-item\" style=\"grid-column:1/-1\">CheatRunner is busy. Retrying game list...</div>';\n"
"              await new Promise(r => setTimeout(r, (i + 1) * 1000));\n"
"            }\n"
"          }\n"
"          const titles = (d.games || d.titles || []).filter(g => isGameTitleId(gameId(g)));\n"
"\n"
"          gamesRaw = titles.map(g => ({\n"
"            titleId: gameId(g),\n"
"            titleName: gameName(g),\n"
"            platform: gamePlatform(g),\n"
"            version: gameVersion(g),\n"
"            contentId: g.contentId || '',\n"
"            iconUrl: gameIcon(g),\n"
"            hasCheat: !!g.hasCheat,\n"
"            cheatFormat: g.cheatFormat || '',\n"
"            running: !!g.running\n"
"          }));\n"
"\n"
"          const run = gamesRaw.find(g => g.running);\n"
"          if (run) current = run;\n"
"          else if (!current && gamesRaw.length) current = gamesRaw[0];\n"
"\n"
"          applyFilters();\n"
"          renderGames();\n"
"          queueUnresolvedTitleLookups();\n"
"        } catch (e) {\n"
"          const _gCls = classifyFetchError(e);\n"
"          let errMsg = 'Game list temporarily unavailable.';\n"
"          if (_gCls.code === 'busy') {\n"
"            errMsg = 'CheatRunner is busy. Please wait.';\n"
"          } else {\n"
"            try { await getJson('/api/health', { timeoutMs: 3000, retries: 0 }); } catch (_) { errMsg = 'CheatRunner is not responding.'; }\n"
"          }\n"
"          node.innerHTML = '<div class=\"status-item\" style=\"grid-column:1/-1\">' + escapeHtml(errMsg) + '</div>';\n"
"          showToast(errMsg, _gCls.code === 'busy' ? 'warn' : 'error');\n"
"        } finally {\n"
"          gamesRefreshInFlight = null;\n"
"        }\n"
"      })();\n"
"      return gamesRefreshInFlight;\n"
"    }\n"
"\n"
"    function bindClick(id, handler) {\n"
"      const el = document.getElementById(id);\n"
"      if (el) el.addEventListener('click', handler);\n"
"    }\n"
"\n"
"    document.getElementById('searchInput').addEventListener('input', () => {\n"
"      applyFilters();\n"
"      renderGames();\n"
"    });\n"
"    document.getElementById('sortSelect').addEventListener('change', () => {\n"
"      applyFilters();\n"
