"        var cl = 16; ctx.lineWidth = 3;\n"
"        [[bx, by, 1, 1], [bx + bs, by, -1, 1], [bx, by + bs, 1, -1], [bx + bs, by + bs, -1, -1]].forEach(function(c) {\n"
"          ctx.beginPath(); ctx.moveTo(c[0] + c[2] * cl, c[1]); ctx.lineTo(c[0], c[1]); ctx.lineTo(c[0], c[1] + c[3] * cl); ctx.stroke();\n"
"        });\n"
