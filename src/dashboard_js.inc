"          };\n"
"          img.src = e.target.result;\n"
"        };\n"
"        reader.readAsDataURL(file);\n"
"      }\n"
"      function _closeCrop() {\n"
"        var m = document.getElementById('cropModal');\n"
"        if (m) m.style.display = 'none';\n"
"      }\n"
"      (function() {\n"
"        var cv = document.getElementById('cropCanvas');\n"
"        if (cv) {\n"
"          cv.addEventListener('mousedown', function(e) { _cd = true; _clx = e.clientX; _cly = e.clientY; cv.classList.add('dragging'); e.preventDefault(); });\n"
"          cv.addEventListener('wheel', function(e) { e.preventDefault(); _csetscale(_cs * (e.deltaY < 0 ? 1.08 : 0.93)); }, { passive: false });\n"
