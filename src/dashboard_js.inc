"\n"
"\n"
"    let gamesCountShown = 0;\n"
"    let gamesCountRaf = 0;\n"
"    function animateGamesCount(to) {\n"
"      const el = document.getElementById('gamesCount');\n"
"      if (!el) return;\n"
"      to = Math.max(0, to | 0);\n"
"      if (gamesCountRaf) { cancelAnimationFrame(gamesCountRaf); gamesCountRaf = 0; }\n"
"      const from = gamesCountShown;\n"
"      if (from === to) { el.textContent = String(to); return; }\n"
"      const reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;\n"
"      if (reduce) { gamesCountShown = to; el.textContent = String(to); return; }\n"
"      const start = performance.now();\n"
"      const dur = 360;\n"
"      const step = (now) => {\n"
"        const t = Math.min(1, (now - start) / dur);\n"
"        const eased = 1 - Math.pow(1 - t, 3);\n"
"        const val = Math.round(from + (to - from) * eased);\n"
"        el.textContent = String(val);\n"
"        if (t < 1) { gamesCountRaf = requestAnimationFrame(step); }\n"
"        else { gamesCountShown = to; gamesCountRaf = 0; }\n"
"      };\n"
"      gamesCountRaf = requestAnimationFrame(step);\n"
"    }\n"
"\n"
"    function renderGames(animate) {\n"
