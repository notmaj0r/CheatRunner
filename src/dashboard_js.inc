"    (function() {\n"
"      const dz = document.getElementById('cheatDropzone');\n"
"      if (!dz) return;\n"
"      const ALLOWED_EXT = ['.mc4', '.shn', '.json'];\n"
"      function isDzFile(f) { return f && ALLOWED_EXT.some(ext => f.name.toLowerCase().endsWith(ext)); }\n"
"      dz.addEventListener('dragover', e => { e.preventDefault(); dz.classList.add('drag-over'); });\n"
"      dz.addEventListener('dragleave', () => dz.classList.remove('drag-over'));\n"
"      dz.addEventListener('drop', async e => {\n"
"        e.preventDefault();\n"
"        dz.classList.remove('drag-over');\n"
"        const file = e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files[0];\n"
"        if (!file) return;\n"
"        if (!isDzFile(file)) { showToast('Unsupported file. Use .mc4, .shn, or .json', 'warn'); return; }\n"
"        await handleCheatFileUpload(file);\n"
"      });\n"
"      dz.addEventListener('click', () => {\n"
"        const inp = document.createElement('input');\n"
"        inp.type = 'file';\n"
"        inp.accept = '.mc4,.shn,.json';\n"
"        inp.onchange = async () => { if (inp.files && inp.files[0]) await handleCheatFileUpload(inp.files[0]); };\n"
"        inp.click();\n"
"      });\n"
"    })();\n"
"\n"
"    async function handleCheatFileUpload(file) {\n"
"      const tid = cheatTitleId || selectedTitleId();\n"
"      if (!tid) { showToast('Load a game first so we know the title ID.', 'warn'); return; }\n"
"      try {\n"
"        const body = await file.arrayBuffer();\n"
"        const res = await fetch('/api/cheats/upload?titleId=' + encodeURIComponent(tid)\n"
"          + '&filename=' + encodeURIComponent(file.name), {\n"
"          method: 'POST',\n"
"          body,\n"
"          cache: 'no-store'\n"
"        });\n"
"        if (res.status === 404) {\n"
"          showToast('Upload endpoint not available. Copy the file to /data/cheatrunner/cheats/ manually.', 'warn');\n"
"          return;\n"
"        }\n"
"        if (!res.ok) {\n"
"          let msg = 'Upload failed (HTTP ' + res.status + ')';\n"
"          try { const j = await res.json(); if (j && j.error) msg = j.error; } catch (_) {}\n"
"          showToast(msg, 'error');\n"
"          return;\n"
"        }\n"
"        showToast('Cheat file uploaded. Reloading...', 'success');\n"
"        await loadCheatMenu(tid);\n"
"        await refreshGames();\n"
"      } catch (_) {\n"
"        showToast('Upload endpoint not available. Copy the file to /data/cheatrunner/cheats/ manually.', 'warn');\n"
"      }\n"
"    }\n"
"\n"
"    /* ---- Repositories tab ---- */\n"
"    let repoPolling = false;\n"
"\n"
"    const REPO_WARN_TEXT = {\n"
"      git_tree_truncated: 'File tree truncated — some cheat files may be missing',\n"
"      contents_fallback: 'Using directory listing fallback',\n"
"    };\n"
"    function repoStatusText(st) {\n"
"      if (!st || !st.state || st.state === 'idle') return '';\n"
"      const dl = Number(st.downloaded || 0), sk = Number(st.skipped || 0);\n"
"      const fa = Number(st.failed || 0), ve = Number(st.verified || 0);\n"
"      const tot = Number(st.total || 0);\n"
"      const si = Number(st.sourceIndex || 0), stot = Number(st.sourceTotal || 0);\n"
"      const srcp = stot > 1 ? (' | Source: ' + si + '/' + stot) : '';\n"
"      const warnText = st.warning ? (REPO_WARN_TEXT[st.warning] || st.warning) : '';\n"
"      const warnp = warnText ? ' | ' + warnText : '';\n"
"      return 'Downloaded: ' + dl + ' | Skipped: ' + sk + ' | Failed: ' + fa +\n"
"             (tot > 0 ? ' | Total: ' + tot : '') +\n"
"             (ve > 0 ? ' | Verified: ' + ve : '') + srcp + warnp;\n"
"    }\n"
"\n"
"    function renderRepoProgress(st) {\n"
"      const prog = document.getElementById('repoProgress');\n"
"      const bar  = document.getElementById('repoProgressBar');\n"
"      const line = document.getElementById('repoStatusLine');\n"
"      const cur  = document.getElementById('repoCurrentFile');\n"
"      const res  = document.getElementById('repoResult');\n"
"      if (!st || st.state === 'idle') {\n"
"        if (prog) prog.style.display = 'none';\n"
"        return;\n"
"      }\n"
"      if (prog) prog.style.display = '';\n"
"      const pct = Math.min(100, Number(st.pct || 0));\n"
"      if (bar)  bar.style.width = pct + '%';\n"
"      if (line) line.textContent = repoStatusText(st);\n"
"      if (cur)  cur.textContent  = st.current ? 'Current: ' + st.current : '';\n"
"      if (res) {\n"
"        if (st.state === 'done') {\n"
"          const dl = Number(st.downloaded || 0);\n"
"          let extra = '';\n"
"          if (st.warning) extra = ' Warning: ' + st.warning;\n"
"          if (st.complete === false) extra += (extra ? ' | ' : ' ') + 'Warning: GitHub returned a truncated file tree. Some files may be missing.';\n"
"          res.textContent = (dl > 0 ? '\\u2705 Done. ' + dl + ' cheat file(s) saved.' : '\\u2713 Done (all cheat files already up to date).') + extra;\n"
"          res.style.color = 'var(--success-color, #4caf50)';\n"
"        } else if (st.state === 'error') {\n"
"          res.textContent = '\\u274c Error: ' + (st.error || 'download failed');\n"
"          res.style.color = 'var(--danger-color, #f44336)';\n"
"        } else {\n"
"          res.textContent = '';\n"
"          res.style.color = '';\n"
"        }\n"
"      }\n"
"    }\n"
"\n"
"    async function pollRepoDownload() {\n"
"      if (repoPolling) return;\n"
"      repoPolling = true;\n"
"      try {\n"
"        while (true) {\n"
"          const st = await getJson('/api/cheats/repo/download/status', { timeoutMs: 8000 }).catch(() => null);\n"
"          renderRepoProgress(st);\n"
"          if (!st || st.state !== 'running') break;\n"
"          await new Promise(r => setTimeout(r, 1500));\n"
"        }\n"
"      } finally {\n"
"        repoPolling = false;\n"
"      }\n"
"    }\n"
"\n"
"    async function startRepoDownload(sourceOverride) {\n"
"      const src = sourceOverride || (document.getElementById('repoSource') || {}).value || 'hencollection';\n"
"      const ovr = (document.getElementById('repoOverwrite') || {}).checked ? '1' : '0';\n"
"      const res  = document.getElementById('repoResult');\n"
"      if (res) { res.textContent = 'Starting...'; res.style.color = ''; }\n"
"      try {\n"
"        const data = await fetch('/api/cheats/repo/download?source=' + encodeURIComponent(src) + '&overwrite=' + ovr, {\n"
"          method: 'POST', cache: 'no-store'\n"
"        });\n"
"        const j = await data.json().catch(() => ({}));\n"
"        if (j && (j.state === 'running' || j.ok)) {\n"
"          if (res) { res.textContent = ''; }\n"
"          pollRepoDownload();\n"
"        } else {\n"
"          if (res) { res.textContent = (j && j.message) || (j && j.error) || 'Start failed.'; res.style.color = 'var(--danger-color,#f44336)'; }\n"
"          /* If already running, still poll for status */\n"
"          if (j && j.state === 'running') pollRepoDownload();\n"
"        }\n"
"      } catch (_) {\n"
"        if (res) { res.textContent = 'Request failed.'; res.style.color = 'var(--danger-color,#f44336)'; }\n"
"      }\n"
"    }\n"
"\n"
"    bindClick('repoDownloadBtn', () => startRepoDownload(''));\n"
"    bindClick('repoDownloadAllBtn', () => startRepoDownload('all'));\n"
"    /* ---- Patches tab ---- */\n"
"    /* Manual PS-Game-Patch XML listing and application are supported.\n"
"     * Auto-apply patches is intentionally not implemented. */\n"
"    let patchData = null;\n"
"    let patchGlobalEnabled = true;\n"
"\n"
"    async function loadPatchList(titleId) {\n"
"      const node = document.getElementById('patchList');\n"
"      if (!node) return;\n"
"      if (!titleId) {\n"
"        node.innerHTML = '<div class=\"cr-patch-info\">Select a game first, then open the Patches tab.</div>';\n"
"        return;\n"
"      }\n"
"      node.innerHTML = '<div class=\"cr-patch-info\">Loading patches for ' + escapeHtml(titleId) + '\\u2026</div>';\n"
"      try {\n"
"        const [pd, pg] = await Promise.all([\n"
"          getJson('/api/patches?titleId=' + encodeURIComponent(titleId), { timeoutMs: 10000 }),\n"
"          getJson('/api/patches/global').catch(() => ({ enabled: true }))\n"
"        ]);\n"
"        patchData = pd;\n"
"        patchGlobalEnabled = !!(pg && pg.enabled);\n"
"      } catch (e) {\n"
"        const msg = String(e.message || e);\n"
"        node.innerHTML = '<div class=\"cr-patch-info\">Failed to load patches: ' + escapeHtml(msg) + '</div>';\n"
"        showToast('Failed to load patches: ' + msg, 'error');\n"
"        return;\n"
"      }\n"
"      renderPatchList();\n"
"      if (!patchData || !patchData.hasPatchFile) {\n"
"        showToast('No patch file found for ' + titleId + '.', 'warn');\n"
"      } else {\n"
"        const n = (patchData.entries || []).length;\n"
"        showToast(n + ' patch entr' + (n !== 1 ? 'ies' : 'y') + ' found for ' + titleId + '.', 'info');\n"
"      }\n"
"    }\n"
"\n"
"    function blockReasonLabel(br, e) {\n"
"      if (br === 'missing_game')        return 'Start the game first';\n"
"      if (br === 'no_supported_lines')  return 'No supported patch lines';\n"
"      if (br === 'unsupported_line_type') {\n"
"        const types = (e.unsupportedTypes || []).join(', ');\n"
"        return 'Contains unsupported line types' + (types ? ': ' + escapeHtml(types) : '') + '. Patch cannot be applied safely.';\n"
"      }\n"
"      if (br === 'parse_error')         return 'Patch file parse error';\n"
"      if (br === 'version_mismatch')    return 'Version mismatch';\n"
"      return br || '';\n"
"    }\n"
"\n"
"    function renderPatchList() {\n"
"      const node = document.getElementById('patchList');\n"
"      if (!node || !patchData) return;\n"
"      const d = patchData;\n"
"      const globalToggleHtml = '<div class=\"row\" style=\"margin-bottom:10px;\">'\n"
"        + '<button class=\"btn ' + (patchGlobalEnabled ? 'danger' : '') + ' compact\" id=\"patchGlobalToggleBtn\">'\n"
"        + (patchGlobalEnabled ? 'Disable All Patches' : 'Enable All Patches') + '</button>'\n"
"        + '<span style=\"font-size:12px;opacity:.6;align-self:center;margin-left:8px;\">'\n"
"        + (patchGlobalEnabled ? 'Patches are active' : '\\u26a0 All patch directories disabled') + '</span>'\n"
"        + '</div>';\n"
"      function bindGlobalBtn() {\n"
"        const gb = node.querySelector('#patchGlobalToggleBtn');\n"
"        if (gb) gb.addEventListener('click', () => togglePatchGlobal());\n"
"      }\n"
"      if (!d.hasPatchFile) {\n"
"        node.innerHTML = globalToggleHtml + '<div class=\"cr-patch-info\">No patch file found for ' + escapeHtml(d.titleId || '') + '.<br>'\n"
"          + 'Place PS-Game-Patch XML files in <code>/data/cheatrunner/patches/xml_prospero</code>, '\n"
"          + '<code>/data/cheatrunner/patches/xml</code>, or <code>/data/elf-arsenal/patches/xml</code>.</div>';\n"
"        bindGlobalBtn(); return;\n"
"      }\n"
"      const entries = d.entries || [];\n"
"      if (!entries.length) {\n"
"        node.innerHTML = globalToggleHtml + '<div class=\"cr-patch-info\">Patch file found but contains no entries for ' + escapeHtml(d.titleId || '') + '.</div>';\n"
"        bindGlobalBtn(); return;\n"
"      }\n"
"      const gv = d.detectedGameVersion && d.detectedGameVersion !== 'unknown' ? d.detectedGameVersion : '';\n"
"      let html = globalToggleHtml + '<div class=\"cr-patch-info\">'\n"
"        + escapeHtml(d.gameTitle || d.titleId || '') + (gv ? ' &mdash; Game v' + escapeHtml(gv) : '')\n"
"        + (d.gameRunning ? '' : ' &mdash; <span style=\"color:var(--cr-red)\">game not running</span>')\n"
"        + '</div><div class=\"cr-patch-list\">';\n"
"      entries.forEach((e, i) => {\n"
"        const vs = e.versionStatus || '';\n"
"        const rowCls = 'cr-patch-row' + (e.applied ? ' is-applied' : vs === 'match' ? ' ver-match' : vs === 'mask' ? ' ver-mask' : vs === 'mismatch' ? ' ver-miss' : '');\n"
"        const verLabel = vs === 'mask'     ? '\\u{1F50D} Any version (mask scan)'\n"
"                       : vs === 'match'    ? '\\u2714 v' + escapeHtml(e.appVer)\n"
"                       : vs === 'mismatch' ? '\\u2717 needs v' + escapeHtml(e.appVer)\n"
"                       : e.appVer          ? 'v' + escapeHtml(e.appVer) : 'any version';\n"
"        const verCls   = vs === 'mask' ? 'mask' : vs === 'match' ? 'match' : vs === 'mismatch' ? 'miss' : 'unk';\n"
"        const br = e.blockReason || '';\n"
"        let actionHtml;\n"
"        if (e.applied) {\n"
"          actionHtml = '<span class=\"cr-patch-applied-chip\">\\u2714 Applied</span>'\n"
"            + ' <button class=\"btn compact\" data-patch-restore=\"' + i + '\" data-patch-eid=\"' + escapeHtml(e.entryId || '') + '\">Restore</button>';\n"
"        } else if (e.canApply) {\n"
"          actionHtml = '<button class=\"btn compact\" data-patch-apply=\"' + i + '\" data-patch-eid=\"' + escapeHtml(e.entryId || '') + '\">Apply</button>';\n"
"        } else if (br === 'version_mismatch') {\n"
"          actionHtml = '<button class=\"btn compact\" data-patch-force=\"' + i + '\" data-patch-eid=\"' + escapeHtml(e.entryId || '') + '\" style=\"opacity:.55\" title=\"Version mismatch &mdash; force apply\">Force&hellip;</button>';\n"
"        } else {\n"
"          actionHtml = '<div class=\"cr-patch-blocked\" title=\"' + escapeHtml(blockReasonLabel(br, e)) + '\">' + escapeHtml(blockReasonLabel(br, e)) + '</div>';\n"
"        }\n"
"        /* Source info */\n"
"        const srcLabel = e.sourceKindLabel ? '[' + escapeHtml(e.sourceKindLabel) + '] ' + escapeHtml(e.sourceFile || '') : '';\n"
"        html += '<div class=\"' + rowCls + '\">'\n"
"          + '<div class=\"cr-patch-body\">'\n"
"          + '<div class=\"cr-patch-name\">' + escapeHtml(e.name) + '</div>'\n"
"          + '<div class=\"cr-patch-meta\">by ' + escapeHtml(e.author || '?') + ' &middot; ' + (e.supportedLineCount || e.lineCount || 0) + ' write' + ((e.supportedLineCount || e.lineCount || 0) !== 1 ? 's' : '') + (srcLabel ? ' &middot; ' + srcLabel : '') + '</div>'\n"
"          + (e.note ? '<div class=\"cr-patch-note\">' + escapeHtml(e.note) + '</div>' : '')\n"
"          + '<div class=\"cr-patch-ver ' + verCls + '\">' + verLabel + '</div>'\n"
"          + (e.hasUnsupported ? '<div class=\"cr-patch-unsup\">\\u26a0 Contains unsupported line types; patch cannot be applied safely.</div>' : '')\n"
"          + (e.hasPartialOverwriteWarning ? '<div class=\"cr-patch-unsup\">\\u26a0 Mask scan patch: value shorter than pattern &mdash; may misalign instructions.</div>' : '')\n"
"          + '</div>'\n"
"          + '<div class=\"cr-patch-action\">' + actionHtml + '</div>'\n"
"          + '</div>';\n"
"      });\n"
"      html += '</div>';\n"
"      node.innerHTML = html;\n"
"      bindGlobalBtn();\n"
"      node.querySelectorAll('[data-patch-apply]').forEach(btn => {\n"
"        btn.addEventListener('click', async () => {\n"
"          const idx = Number(btn.getAttribute('data-patch-apply'));\n"
"          const eid = btn.getAttribute('data-patch-eid') || '';\n"
"          await applyPatch(idx, eid, false);\n"
"        });\n"
"      });\n"
"      node.querySelectorAll('[data-patch-force]').forEach(btn => {\n"
"        btn.addEventListener('click', async () => {\n"
"          const idx = Number(btn.getAttribute('data-patch-force'));\n"
"          const eid = btn.getAttribute('data-patch-eid') || '';\n"
"          const e = patchData && patchData.entries && patchData.entries[idx];\n"
"          if (!e) return;\n"
"          if (!confirm('Force-apply patch \"' + e.name + '\"?\\nVersion mismatch: patch needs v' + e.appVer + '. This may crash the game.')) return;\n"
"          await applyPatch(idx, eid, true);\n"
"        });\n"
"      });\n"
"      node.querySelectorAll('[data-patch-restore]').forEach(btn => {\n"
"        btn.addEventListener('click', async () => {\n"
"          const idx = Number(btn.getAttribute('data-patch-restore'));\n"
"          const eid = btn.getAttribute('data-patch-eid') || '';\n"
"          await restorePatch(idx, eid);\n"
"        });\n"
"      });\n"
"      const globalBtn = node.querySelector('#patchGlobalToggleBtn');\n"
"      if (globalBtn) globalBtn.addEventListener('click', () => togglePatchGlobal());\n"
"    }\n"
"\n"
"    async function togglePatchGlobal() {\n"
"      const btn = document.getElementById('patchGlobalToggleBtn');\n"
"      if (btn) { btn.disabled = true; btn.textContent = '\\u2026'; }\n"
"      try {\n"
"        const newState = patchGlobalEnabled ? 0 : 1;\n"
"        const r = await getJson('/api/patches/global/set?on=' + newState);\n"
"        if (r && r.ok) {\n"
"          patchGlobalEnabled = !!r.enabled;\n"
"          showToast(patchGlobalEnabled ? '\\u2714 Patches enabled.' : '\\u26a0 All patches disabled.', patchGlobalEnabled ? 'success' : 'warn');\n"
"          const tid = cheatTitleId || selectedTitleId();\n"
"          if (tid) await loadPatchList(tid);\n"
"        } else {\n"
"          showToast('Patch toggle failed.', 'error');\n"
"          if (btn) { btn.disabled = false; btn.textContent = patchGlobalEnabled ? 'Disable All Patches' : 'Enable All Patches'; }\n"
"        }\n"
"      } catch (e) {\n"
"        showToast('Patch toggle error: ' + (e.message || e), 'error');\n"
"        if (btn) { btn.disabled = false; btn.textContent = patchGlobalEnabled ? 'Disable All Patches' : 'Enable All Patches'; }\n"
"      }\n"
"    }\n"
"\n"
"    async function applyPatch(idx, entryId, force) {\n"
"      const tid = cheatTitleId || selectedTitleId();\n"
"      if (!tid) { showToast('Select a game first.', 'warn'); return; }\n"
"      const btn = document.querySelector('[data-patch-apply=\"' + idx + '\"], [data-patch-force=\"' + idx + '\"]');\n"
"      if (btn) { btn.disabled = true; btn.textContent = 'Applying\\u2026'; }\n"
"      try {\n"
"        const idPart = entryId ? ('&entryId=' + encodeURIComponent(entryId)) : ('&index=' + idx);\n"
"        const url = '/api/patches/apply?titleId=' + encodeURIComponent(tid) + idPart + (force ? '&force=1' : '');\n"
"        const r = await getJson(url);\n"
"        if (r && r.ok) {\n"
"          showToast('\\u2714 Patch applied: ' + (r.name || ''), 'success');\n"
"          await loadPatchList(tid);\n"
"        } else {\n"
"          const msg = (r && r.message) || (r && r.error) || 'Apply failed';\n"
"          showToast(msg, 'error');\n"
"          if (btn) { btn.disabled = false; btn.textContent = force ? 'Force\\u2026' : 'Apply'; }\n"
"        }\n"
"      } catch (e) {\n"
"        const cls = classifyFetchError(e);\n"
"        showToast('Patch apply failed: ' + cls.message, 'error');\n"
"        if (btn) { btn.disabled = false; btn.textContent = force ? 'Force\\u2026' : 'Apply'; }\n"
"      }\n"
"    }\n"
"\n"
"    async function restorePatch(idx, entryId) {\n"
"      const tid = cheatTitleId || selectedTitleId();\n"
"      if (!tid) { showToast('Select a game first.', 'warn'); return; }\n"
"      const e = patchData && patchData.entries && patchData.entries[idx];\n"
"      const btn = document.querySelector('[data-patch-restore=\"' + idx + '\"]');\n"
"      if (btn) { btn.disabled = true; btn.textContent = 'Restoring\\u2026'; }\n"
"      try {\n"
"        const idPart = entryId ? ('&entryId=' + encodeURIComponent(entryId)) : ('&index=' + idx);\n"
"        const url = '/api/patches/restore?titleId=' + encodeURIComponent(tid) + idPart;\n"
"        const r = await getJson(url, { timeoutMs: 15000 });\n"
"        if (r && r.ok) {\n"
"          showToast('\\u2714 Patch restored: ' + (e && e.name || ''), 'success');\n"
"          await loadPatchList(tid);\n"
"        } else {\n"
"          const msg = (r && r.message) || (r && r.error) || 'Restore failed';\n"
"          showToast(msg, 'error');\n"
"          if (btn) { btn.disabled = false; btn.textContent = 'Restore'; }\n"
"        }\n"
"      } catch (ex) {\n"
"        const cls = classifyFetchError(ex);\n"
"        showToast('Patch restore failed: ' + cls.message, 'error');\n"
"        if (btn) { btn.disabled = false; btn.textContent = 'Restore'; }\n"
"      }\n"
"    }\n"
"\n"
"    bindClick('modalTabPatches', async () => {\n"
"      setModalTab('patches');\n"
"      const tid = cheatTitleId || selectedTitleId();\n"
"      await loadPatchList(tid);\n"
"    });\n"
"\n"
"    bindClick('modalTabRepos', async () => {\n"
"      setModalTab('repos');\n"
"      /* Resume polling if a download is already running */\n"
"      try {\n"
"        const st = await getJson('/api/cheats/repo/download/status', { timeoutMs: 4000 }).catch(() => null);\n"
"        renderRepoProgress(st);\n"
