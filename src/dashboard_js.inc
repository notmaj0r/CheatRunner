"        finally { picApply.disabled = false; }\n"
"      });\n"
"      // === Crop Modal ===\n"
"      var _ci = null, _cs = 1, _cmin = 1, _cox = 0, _coy = 0, _cd = false, _clx = 0, _cly = 0, _cpd = 0;\n"
"      function _cbs(cv) { return Math.floor(Math.min(cv.width, cv.height) * 0.82); }\n"
"      function _cdraw() {\n"
"        var cv = document.getElementById('cropCanvas');\n"
"        if (!cv || !_ci) return;\n"
"        var ctx = cv.getContext('2d'), W = cv.width, H = cv.height;\n"
"        var bs = _cbs(cv), bx = Math.floor((W - bs) / 2), by = Math.floor((H - bs) / 2);\n"
"        var iw = _ci.naturalWidth * _cs, ih = _ci.naturalHeight * _cs;\n"
"        var ix = W / 2 + _cox - iw / 2, iy = H / 2 + _coy - ih / 2;\n"
"        ctx.clearRect(0, 0, W, H);\n"
"        ctx.drawImage(_ci, ix, iy, iw, ih);\n"
"        ctx.fillStyle = 'rgba(0,0,0,.55)';\n"
"        ctx.fillRect(0, 0, W, by); ctx.fillRect(0, by + bs, W, H - by - bs);\n"
"        ctx.fillRect(0, by, bx, bs); ctx.fillRect(bx + bs, by, W - bx - bs, bs);\n"
"        ctx.strokeStyle = 'rgba(255,255,255,.2)'; ctx.lineWidth = 1;\n"
"        for (var i = 1; i < 3; i++) {\n"
"          ctx.beginPath(); ctx.moveTo(bx + bs * i / 3, by); ctx.lineTo(bx + bs * i / 3, by + bs); ctx.stroke();\n"
"          ctx.beginPath(); ctx.moveTo(bx, by + bs * i / 3); ctx.lineTo(bx + bs, by + bs * i / 3); ctx.stroke();\n"
