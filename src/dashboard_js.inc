"        const af = isFav(gameId(a)) ? 0 : 1, bf = isFav(gameId(b)) ? 0 : 1;\n"
"        if (af !== bf) return af - bf;\n"
"        const an = gameName(a).toLowerCase();\n"
"        const bn = gameName(b).toLowerCase();\n"
"        const ai = gameId(a);\n"
"        const bi = gameId(b);\n"
