"\n"
"    function initPanelCollapse() {\n"
"      document.querySelectorAll('.cr-collapse-btn[data-for]').forEach(function(btn) {\n"
"        var id = btn.getAttribute('data-for');\n"
"        var body = document.getElementById(id);\n"
"        if (!body) return;\n"
"        var hdr = btn.closest('.cr-panel-hdr');\n"
"        var stored = localStorage.getItem('cr_panel_' + id);\n"
"        if (stored === '1') {\n"
"          body.style.transition = 'none';\n"
"          body.classList.add('collapsed');\n"
"          btn.classList.add('collapsed');\n"
"          btn.setAttribute('aria-expanded', 'false');\n"
"          requestAnimationFrame(function() { body.style.transition = ''; });\n"
"        }\n"
"        function doToggle() {\n"
"          var isNowCollapsed = body.classList.toggle('collapsed');\n"
"          btn.classList.toggle('collapsed', isNowCollapsed);\n"
"          btn.setAttribute('aria-expanded', isNowCollapsed ? 'false' : 'true');\n"
"          try { localStorage.setItem('cr_panel_' + id, isNowCollapsed ? '1' : '0'); } catch(_) {}\n"
"        }\n"
"        btn.addEventListener('click', function(e) { e.stopPropagation(); doToggle(); });\n"
"        if (hdr) hdr.addEventListener('click', doToggle);\n"
"      });\n"
"    }\n"
"    initPanelCollapse();\n"
"\n"
"    // PS5 browser has no JIT: continuous fetch+parse is the main lag source.\n"
"    // Pollers pause when the tab is hidden, skip work when their panel is\n"
"    // collapsed, and back off on repeated failures instead of hammering.\n"
"    function crStartPoller(fn, baseMs, shouldRun) {\n"
"      var fails = 0;\n"
"      async function tick() {\n"
"        var delay = baseMs;\n"
"        if (document.hidden) {\n"
"          delay = baseMs * 3;\n"
"        } else if (shouldRun && !shouldRun()) {\n"
"          delay = baseMs;\n"
"        } else {\n"
"          try { await fn(); fails = 0; }\n"
"          catch (_) { fails++; }\n"
"          if (fails) delay = Math.min(baseMs * (1 << Math.min(fails, 4)), 60000);\n"
"        }\n"
"        setTimeout(tick, delay);\n"
"      }\n"
"      setTimeout(tick, baseMs);\n"
"    }\n"
"    function crPanelOpen(id) {\n"
"      var e = document.getElementById(id);\n"
"      return !!e && !e.classList.contains('collapsed');\n"
"    }\n"
"    crStartPoller(refreshStatus, 7000);\n"
"    crStartPoller(refreshLaunchStatus, 3000);\n"
"    crStartPoller(refreshGlobalState, 10000);\n"
"    crStartPoller(refreshLogs, 6000, function() { return crPanelOpen('pb_logs'); });\n"
"    crStartPoller(refreshFan, 4000, function() { return crPanelOpen('pb_thermal'); });\n"
"    // Returning to the foreground: refresh the always-on panels immediately\n"
"    // instead of waiting out the (slowed) hidden interval.\n"
"    document.addEventListener('visibilitychange', function() {\n"
"      if (!document.hidden) { refreshStatus(); refreshGlobalState(); refreshLaunchStatus(); }\n"
"    });\n"
