"      function _cclamp() {\n"
"        var cv = document.getElementById('cropCanvas');\n"
"        if (!cv || !_ci) return;\n"
"        var W = cv.width, H = cv.height, bs = _cbs(cv);\n"
"        var bx = (W - bs) / 2, by = (H - bs) / 2;\n"
