"    function renderOnboardChecks() {\n"
"      const node = document.getElementById('onboardChecks');\n"
"      if (!node) return;\n"
"      const s = g_stateData || {};\n"
"      const engineOk = !!(s.cheats && s.cheats.engine);\n"
"      const canPatch = !!(s.cheats && s.cheats.canPatchGameMemory);\n"
"      const privOk   = !!(s.privileges && s.privileges.uid_ok && s.privileges.authid_ok);\n"
"      function item(label, val, cls) { return '<div class=\"cr-health-item\"><div class=\"cr-health-dot ' + cls + '\"></div><div class=\"cr-health-label\">' + escapeHtml(label) + '</div><div class=\"cr-health-val\">' + escapeHtml(val) + '</div></div>'; }\n"
"      node.innerHTML = item('Jailbreak privileges', privOk ? 'OK' : 'Check', privOk ? 'ok' : 'warn')\n"
"        + item('Cheat engine', engineOk ? 'Ready' : 'Off', engineOk ? 'ok' : 'warn')\n"
"        + item('Memory patching', canPatch ? 'Ready' : 'Not ready', canPatch ? 'ok' : 'warn');\n"
"    }\n"
"    function finishOnboarding() { try { localStorage.setItem('cr_onboarded', '1'); } catch(_) {} const o = document.getElementById('onboardOverlay'); if (o) o.style.display = 'none'; }\n"
"    function maybeShowOnboarding() {\n"
