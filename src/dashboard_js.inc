"\n"
"    setModalTab('cheats');\n"
"\n"
"    (async function startup() {\n"
"      await loadFavRecent();\n"
"      try { const r = await fetch('/api/config', {cache:'no-store'}); if (r.ok) { cfgData = await r.json(); applyTheme(cfgData.theme); } } catch(_) {}\n"
"      await Promise.all([\n"
"        refreshLaunchStatus().catch(() => {}),\n"
"        refreshStatus().catch(() => {}),\n"
"        refreshGlobalState().catch(() => {}),\n"
"        refreshLogs().catch(() => {}),\n"
"      ]);\n"
"      await refreshGames(false).catch(() => {});\n"
"      maybeShowOnboarding();\n"
"      const hash = location.hash;\n"
"      if (hash && hash.startsWith('#trainer=')) {\n"
"        const tid = cleanTitleId(hash.slice(9));\n"
"        if (tid) {\n"
"          const g = gamesRaw.find(x => gameId(x) === tid);\n"
"          if (g) current = g;\n"
"          document.getElementById('titleId').value = tid;\n"
"          openCheatModal('cheats');\n"
"          setTimeout(() => loadCheatMenu(tid), 0);\n"
"        }\n"
"      }\n"
"    })();\n"
"\n"
"    let fanUserAdjusting = false;\n"
"    let fanUseFahrenheit = (localStorage.getItem('cr_fan_unit') === 'F');\n"
"    const toDispTemp = c => fanUseFahrenheit ? Math.round(c * 9 / 5 + 32) : c;\n"
"    const fanDegStr = () => fanUseFahrenheit ? '\\u00b0F' : '\\u00b0C';\n"
"    const updateFanUnitBtn = () => { const b = document.getElementById('fanUnitBtn'); if (!b) return; b.textContent = fanDegStr(); b.classList.toggle('active', fanUseFahrenheit); };\n"
"    async function refreshFan() {\n"
"      try {\n"
"        const r = await getJson('/api/fan/temp', { timeoutMs: 6000 });\n"
"        const warmC = r.warmC || 65, hotC = r.hotC || 80;\n"
"        const tempCls = c => c == null ? '' : c >= hotC ? 'hot' : c >= warmC ? 'warm' : 'cool';\n"
"        const setTxt = (id, c) => {\n"
"          const el = document.getElementById(id); if (!el) return;\n"
"          el.textContent = (c == null ? '\\u2014' : toDispTemp(c) + fanDegStr());\n"
"          el.classList.remove('cool', 'warm', 'hot');\n"
"          const cls = tempCls(c); if (cls) el.classList.add(cls);\n"
"        };\n"
"        setTxt('tCpu', r.cpuC); setTxt('tSoc', r.socC); setTxt('tM2', r.m2C);\n"
"        const range = document.getElementById('fanThRange');\n"
"        const thVal = document.getElementById('fanThVal');\n"
"        const minC = r.minC || 30, maxC = r.maxC || 90;\n"
"        if (range) { range.min = minC; range.max = maxC; }\n"
"        const th = r.thresholdC || 0;\n"
"        if (!fanUserAdjusting) {\n"
"          if (th >= minC && th <= maxC) { if (range) range.value = th; if (thVal) thVal.textContent = toDispTemp(th) + fanDegStr(); }\n"
"          else if (thVal) thVal.textContent = 'Auto';\n"
"        }\n"
