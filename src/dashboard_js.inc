"      try { await refreshStatus(); } catch (_) { anyError = true; }\n"
"      try { await refreshGlobalState(); } catch (_) { anyError = true; }\n"
"      try { await refreshGames(!!force); } catch (_) { anyError = true; }\n"
"      try { await refreshLogs(); } catch (_) { anyError = true; }\n"
"      try { await getJson('/api/patches/rescan'); } catch (_) { anyError = true; }\n"
"      try {\n"
"        const tid = cheatTitleId || cleanTitleId((document.getElementById('titleId') || {}).value || '') || selectedTitleId();\n"
"        if (tid) await reloadCheatMenuForCurrentSelection(tid);\n"
